<fmxmlsnippet type="FMObjectList">

	<Step enable="True" id="89" name="# (comment)">
		<Text>PURPOSE: Close the SO picker card, return focus to the caller window, and clear shared state.
Called from web viewer JS after a successful transfer (via onTransferResult → setTimeout).</Text>
	</Step>

	<Step enable="True" id="85" name="Allow User Abort">
		<Set state="False"/>
	</Step>
	<Step enable="True" id="86" name="Set Error Capture">
		<Set state="True"/>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$callerWindow</Name>
		<Value><Calculation><![CDATA[JSONGetElement ( Globals::ServiceOrderSelector ; "currentWindow" )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="121" name="Close Window">
		<LimitToWindowsOfCurrentFile state="True"/>
		<Window value="Current"/>
	</Step>

	<Step enable="True" id="123" name="Select Window">
		<LimitToWindowsOfCurrentFile state="True"/>
		<Window value="ByName"/>
		<Name>
			<Calculation><![CDATA[$callerWindow]]></Calculation>
		</Name>
	</Step>

	<Step enable="True" id="76" name="Set Field">
		<Calculation><![CDATA[""]]></Calculation>
		<Field table="Globals" id="0" name="ServiceOrderSelector"/>
	</Step>

	<Step enable="True" id="103" name="Exit Script">
		<Calculation><![CDATA[JSONSetElement ( "{}" ; "status" ; "closed" ; JSONString )]]></Calculation>
	</Step>

</fmxmlsnippet>

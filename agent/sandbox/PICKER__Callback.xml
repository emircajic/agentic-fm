<fmxmlsnippet type="FMObjectList">

	<Step enable="True" id="89" name="# (comment)">
		<Text>PURPOSE: Generic picker callback dispatcher.
Runs the domain script, closes the card on success, or pushes an error back to the web viewer on failure.</Text>
	</Step>
	<Step enable="False" id="61" name="Insert Text">
		<SelectAll state="False"/>
		<Text>PARAMS: callbackScript (text, required) | callbackContext (object, optional) | stavkePKs (array, required)</Text>
		<Field>$README</Field>
	</Step>

	<Step enable="True" id="85" name="Allow User Abort">
		<Set state="False"/>
	</Step>
	<Step enable="True" id="86" name="Set Error Capture">
		<Set state="True"/>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Params.parse ( Get ( ScriptParameter ) ; "callbackScript|callbackContext|stavkePKs" )]]></Calculation></Value>
	</Step>

	<Step enable="False" id="89" name="# (comment)">
		<Text>MARK: Build callback param — callbackContext with stavkePKs merged in</Text>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$callbackParam</Name>
		<Value><Calculation><![CDATA[JSONSetElement (
	If ( IsEmpty ( $callbackContext ) ; "{}" ; $callbackContext ) ;
	"stavkePKs" ; $stavkePKs ; JSONArray
)]]></Calculation></Value>
	</Step>

	<Step enable="False" id="89" name="# (comment)">
		<Text>MARK: Run domain script</Text>
	</Step>

	<Step enable="True" id="1" name="Perform Script">
		<Calculated>
			<Calculation><![CDATA[$callbackScript]]></Calculation>
		</Calculated>
		<Calculation><![CDATA[$callbackParam]]></Calculation>
	</Step>
	<Step enable="True" id="141" name="Set Variable">
		<Name>$r</Name>
		<Value><Calculation><![CDATA[Get ( ScriptResult )]]></Calculation></Value>
	</Step>

	<Step enable="False" id="89" name="# (comment)">
		<Text>MARK: Close on success, push error back to web viewer on failure</Text>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[Response_HasErrors ( $r )]]></Calculation>
	</Step>
		<Step enable="True" id="175" name="Perform JavaScript in Web Viewer">
			<ObjectName>
				<Calculation><![CDATA["wv_PrimkaPicker"]]></Calculation>
			</ObjectName>
			<FunctionName>
				<Calculation><![CDATA["receiveError"]]></Calculation>
			</FunctionName>
			<Parameters Count="1">
				<P>
					<Calculation><![CDATA[JSONGetElement ( $r ; "errors[0].message" )]]></Calculation>
				</P>
			</Parameters>
		</Step>
	<Step enable="True" id="67" name="Else"/>
		<Step enable="True" id="121" name="Close Window">
			<LimitToWindowsOfCurrentFile state="True"/>
			<Window value="Current"/>
		</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="103" name="Exit Script">
		<Calculation><![CDATA[JSONSetElement ( "{}" ; "status" ; "ok" ; JSONString )]]></Calculation>
	</Step>

</fmxmlsnippet>

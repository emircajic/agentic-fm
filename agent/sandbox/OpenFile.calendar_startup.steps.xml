<?xml version="1.0"?>
<fmxmlsnippet type="FMObjectList">
  <Step enable="True" id="89" name="# (comment)">
    <Text>PURPOSE: Runs on OnFirstWindowOpen; loads cached settings, routes to Calendar via Navigation_, and applies platform/UI startup state.</Text>
  </Step>
  <Step enable="True" id="1" name="Perform Script">
    <Calculated>
      <Calculation><![CDATA["SETTINGS__EnsureLoaded"]]></Calculation>
    </Calculated>
    <Calculation><![CDATA[""]]></Calculation>
  </Step>
  <Step enable="True" id="1" name="Perform Script">
    <Calculated>
      <Calculation><![CDATA["Navigation_"]]></Calculation>
    </Calculated>
    <Calculation><![CDATA["calendar"]]></Calculation>
  </Step>
  <Step enable="True" id="76" name="Set Field">
    <Field table="Admin" id="25" name="Logo Global"/>
    <Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
    <Calculation><![CDATA[Admin::Logo]]></Calculation>
  </Step>
  <Step enable="True" id="76" name="Set Field">
    <Field table="Admin" id="51" name="Company Name Global"/>
    <Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
    <Calculation><![CDATA[Admin::Company Name]]></Calculation>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[Settings_Get ( "app.statusbarHidden" ; "" )]]></Calculation>
    </Value>
    <Name>$hideStatusBarFlag</Name>
  </Step>
  <Step enable="True" id="76" name="Set Field">
    <Field table="Admin" id="46" name="Item Sort Global"/>
    <Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
    <Calculation><![CDATA[Settings_Get ( "app.sort.item" ; "" )]]></Calculation>
  </Step>
  <Step enable="True" id="76" name="Set Field">
    <Field table="Admin" id="47" name="Service Orders Sort Global"/>
    <Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
    <Calculation><![CDATA[Settings_Get ( "app.sort.serviceorders" ; "" )]]></Calculation>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[Get ( SystemPlatform )]]></Calculation>
    </Value>
    <Name>$platform</Name>
  </Step>
  <Step enable="True" id="68" name="If">
    <Restore state="False"/>
    <Calculation><![CDATA[$platform = 4]]></Calculation>
  </Step>
  <Step enable="True" id="98" name="Show/Hide Menubar">
    <Show hide="True"/>
    <Lock state="True"/>
  </Step>
  <Step enable="True" id="99" name="Show/Hide Toolbars">
    <Lock state="True"/>
    <Show hide="True"/>
    <IncludeEditRecordToolbar state="True"/>
  </Step>
  <Step enable="True" id="121" name="Else If">
    <Restore state="False"/>
    <Calculation><![CDATA[$platform &lt; 3]]></Calculation>
  </Step>
  <Step enable="True" id="22" name="Adjust Window"/>
  <Step enable="True" id="121" name="Else If">
    <Restore state="False"/>
    <Calculation><![CDATA[$platform = 3]]></Calculation>
  </Step>
  <Step enable="True" id="98" name="Show/Hide Menubar">
    <Show hide="True"/>
    <Lock state="True"/>
  </Step>
  <Step enable="True" id="99" name="Show/Hide Toolbars">
    <Lock state="True"/>
    <Show hide="True"/>
    <IncludeEditRecordToolbar state="True"/>
  </Step>
  <Step enable="True" id="97" name="Set Zoom Level">
    <Lock state="True"/>
    <Percent value="100"/>
  </Step>
  <Step enable="True" id="70" name="End If"/>
</fmxmlsnippet>

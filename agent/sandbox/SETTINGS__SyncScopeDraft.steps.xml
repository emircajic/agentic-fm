<?xml version="1.0"?>
<fmxmlsnippet type="FMObjectList">
  <Step enable="True" id="89" name="# (comment)">
    <Text>PURPOSE: Synchronize a scope draft object back to committed settings keys.</Text>
  </Step>
  <Step enable="True" id="86" name="Set Error Capture">
    <Set state="True"/>
  </Step>
  <Step enable="True" id="85" name="Allow User Abort">
    <Set state="False"/>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[Get ( ScriptParameter )]]></Calculation>
    </Value>
    <Name>$input</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[Response_Init ( "{}" )]]></Calculation>
    </Value>
    <Name>$response</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[JSONGetElement ( $input ; "scope" )]]></Calculation>
    </Value>
    <Name>$scope</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[JSONGetElement ( $input ; "scopeId" )]]></Calculation>
    </Value>
    <Name>$scopeId</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[JSONGetElement ( $input ; "draft" )]]></Calculation>
    </Value>
    <Name>$draft</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[Let (
[
    ~type = JSONGetElementType ( $input ; "reload" ) ;
    ~raw = JSONGetElement ( $input ; "reload" )
] ;
    If ( ~type = JSONBoolean ; GetAsBoolean ( ~raw ) ; True )
)]]></Calculation>
    </Value>
    <Name>$reload</Name>
  </Step>
  <Step enable="True" id="68" name="If">
    <Restore state="False"/>
    <Calculation><![CDATA[IsEmpty ( $scope ) or IsEmpty ( $scopeId )]]></Calculation>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[Response_AddError (
    "SETTINGS_SCOPE_MISSING" ;
    "Both scope and scopeId are required." ;
    "scope" ;
    "{}" ;
    Get ( ScriptName )
)]]></Calculation>
    </Value>
    <Name>$response</Name>
  </Step>
  <Step enable="True" id="70" name="End If"/>
  <Step enable="True" id="68" name="If">
    <Restore state="False"/>
    <Calculation><![CDATA[JSONGetElement ( $response ; "status" ) ≠ "fail" and JSONGetElementType ( $draft ; "" ) ≠ JSONObject]]></Calculation>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[Response_AddError (
    "SETTINGS_DRAFT_INVALID" ;
    "Draft must be a JSON object." ;
    "draft" ;
    "{}" ;
    Get ( ScriptName )
)]]></Calculation>
    </Value>
    <Name>$response</Name>
  </Step>
  <Step enable="True" id="70" name="End If"/>
  <Step enable="True" id="68" name="If">
    <Restore state="False"/>
    <Calculation><![CDATA[JSONGetElement ( $response ; "status" ) ≠ "fail"]]></Calculation>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[$scope & "." & $scopeId]]></Calculation>
    </Value>
    <Name>$prefix</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[Settings_GetObject ( $prefix ; "{}" )]]></Calculation>
    </Value>
    <Name>$committed</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[JSONListKeys ( $draft ; "" )]]></Calculation>
    </Value>
    <Name>$keys</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[1]]></Calculation>
    </Value>
    <Name>$i</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[0]]></Calculation>
    </Value>
    <Name>$processed</Name>
  </Step>
  <Step enable="True" id="71" name="Loop">
    <Restore state="False"/>
    <FlushType value="Always"/>
  </Step>
  <Step enable="True" id="72" name="Exit Loop If">
    <Calculation><![CDATA[$i > ValueCount ( $keys ) or JSONGetElement ( $response ; "status" ) = "fail"]]></Calculation>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[GetValue ( $keys ; $i )]]></Calculation>
    </Value>
    <Name>$childKey</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[$prefix & "." & $childKey]]></Calculation>
    </Value>
    <Name>$fullKey</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[JSONGetElement ( $draft ; $childKey )]]></Calculation>
    </Value>
    <Name>$draftValue</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[JSONGetElement ( $committed ; $childKey )]]></Calculation>
    </Value>
    <Name>$committedValue</Name>
  </Step>
  <Step enable="True" id="68" name="If">
    <Restore state="False"/>
    <Calculation><![CDATA[JSONFormatElements ( JSONSetElement ( "{}" ; "v" ; $draftValue ; JSONRaw ) ) ≠ JSONFormatElements ( JSONSetElement ( "{}" ; "v" ; $committedValue ; JSONRaw ) )]]></Calculation>
  </Step>
  <Step enable="True" id="1" name="Perform Script">
    <Calculated>
      <Calculation><![CDATA["SETTINGS__SetValue"]]></Calculation>
    </Calculated>
    <Calculation><![CDATA[JSONSetElement (
    "{}" ;
    [ "key" ; $fullKey ; JSONString ] ;
    [ "value" ; $draftValue ; JSONString ] ;
    [ "valueType" ; JSONGetElementType ( $draft ; $childKey ) ; JSONNumber ] ;
    [ "reload" ; False ; JSONBoolean ]
)]]></Calculation>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[Get ( ScriptResult )]]></Calculation>
    </Value>
    <Name>$writeResult</Name>
  </Step>
  <Step enable="True" id="68" name="If">
    <Restore state="False"/>
    <Calculation><![CDATA[JSONGetElement ( $writeResult ; "status" ) = "fail"]]></Calculation>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[Response_AddError (
    "SETTINGS_SCOPE_SYNC_FAILED" ;
    "Failed while syncing scope draft." ;
    $fullKey ;
    JSONSetElement (
        "{}" ;
        [ "key" ; $fullKey ; JSONString ] ;
        [ "result" ; $writeResult ; JSONObject ]
    ) ;
    Get ( ScriptName )
)]]></Calculation>
    </Value>
    <Name>$response</Name>
  </Step>
  <Step enable="True" id="69" name="Else">
    <Restore state="False"/>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[$processed + 1]]></Calculation>
    </Value>
    <Name>$processed</Name>
  </Step>
  <Step enable="True" id="70" name="End If"/>
  <Step enable="True" id="70" name="End If"/>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[$i + 1]]></Calculation>
    </Value>
    <Name>$i</Name>
  </Step>
  <Step enable="True" id="73" name="End Loop"/>
  <Step enable="True" id="68" name="If">
    <Restore state="False"/>
    <Calculation><![CDATA[JSONGetElement ( $response ; "status" ) ≠ "fail" and $reload]]></Calculation>
  </Step>
  <Step enable="True" id="1" name="Perform Script">
    <Calculated>
      <Calculation><![CDATA["SETTINGS__Load"]]></Calculation>
    </Calculated>
    <Calculation><![CDATA[""]]></Calculation>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[Get ( ScriptResult )]]></Calculation>
    </Value>
    <Name>$loadResult</Name>
  </Step>
  <Step enable="True" id="68" name="If">
    <Restore state="False"/>
    <Calculation><![CDATA[JSONGetElement ( $loadResult ; "status" ) = "fail"]]></Calculation>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[Response_AddError (
    "SETTINGS_SCOPE_RELOAD_FAILED" ;
    "Scope sync succeeded, but settings reload failed." ;
    "SETTINGS__Load" ;
    $loadResult ;
    Get ( ScriptName )
)]]></Calculation>
    </Value>
    <Name>$response</Name>
  </Step>
  <Step enable="True" id="70" name="End If"/>
  <Step enable="True" id="70" name="End If"/>
  <Step enable="True" id="68" name="If">
    <Restore state="False"/>
    <Calculation><![CDATA[JSONGetElement ( $response ; "status" ) ≠ "fail"]]></Calculation>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[Response_SetData (
    JSONSetElement (
        "{}" ;
        [ "scope" ; $scope ; JSONString ] ;
        [ "scopeId" ; $scopeId ; JSONString ] ;
        [ "prefix" ; $prefix ; JSONString ] ;
        [ "processed" ; $processed ; JSONNumber ] ;
        [ "reload" ; $reload ; JSONBoolean ]
    )
)]]></Calculation>
    </Value>
    <Name>$response</Name>
  </Step>
  <Step enable="True" id="70" name="End If"/>
  <Step enable="True" id="70" name="End If"/>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[Response_Finalize]]></Calculation>
    </Value>
    <Name>$response</Name>
  </Step>
  <Step enable="True" id="103" name="Exit Script">
    <Calculation><![CDATA[$response]]></Calculation>
  </Step>
</fmxmlsnippet>

<fmxmlsnippet type="FMObjectList">

  <Step enable="True" id="89" name="# (comment)">
    <Text>PURPOSE: Post KretanjeRobe entries for all Roba lines of the current Invoices record.
Račun → Tip "IZLAZ" (goods out to customer).
Reklamacija → Tip "POVRAT_KUP" (goods returned from customer, back to stock).
Must be called while positioned on the target Invoices record.
Returns $response via Response framework.</Text>
  </Step>

  <Step enable="False" id="61" name="Insert Text">
    <SelectAll state="False"/>
    <Text>PRECONDITIONS:&#xD;  - Current layout is based on Invoices (or a TO of it).&#xD;  - Invoices::Locked must be 0 (not already posted).&#xD;  - InvoiceLines::ForeignKeyStavkaUlazneFakture must be populated for Roba lines.&#xD;&#xD;RETURNS: $response&#xD;  data: { "posted": N, "failed": N }&#xD;  status: "success" | "partial_success" | "fail"</Text>
    <Field>$README</Field>
  </Step>

  <Step enable="True" id="89" name="# (comment)"/>

  <Step enable="False" id="89" name="# (comment)">
    <Text>MARK: Init</Text>
  </Step>

  <Step enable="True" id="86" name="Set Error Capture">
    <Set state="True"/>
  </Step>

  <Step enable="True" id="85" name="Allow User Abort">
    <Set state="False"/>
  </Step>

  <Step enable="True" id="141" name="Set Variable">
    <Name>$response</Name>
    <Value><Calculation><![CDATA[Response_Init ( "{}" )]]></Calculation></Value>
  </Step>

  <Step enable="True" id="141" name="Set Variable">
    <Name>$dokID</Name>
    <Value><Calculation><![CDATA[Invoices::PrimaryKey]]></Calculation></Value>
  </Step>

  <Step enable="True" id="141" name="Set Variable">
    <Name>$dokDatum</Name>
    <Value><Calculation><![CDATA[GetAsText ( Invoices::Datum )]]></Calculation></Value>
  </Step>

  <Step enable="True" id="141" name="Set Variable">
    <Name>$statusDokumenta</Name>
    <Value><Calculation><![CDATA[Invoices::StatusDokumenta]]></Calculation></Value>
  </Step>

  <Step enable="True" id="141" name="Set Variable">
    <Name>$posted</Name>
    <Value><Calculation><![CDATA[0]]></Calculation></Value>
  </Step>

  <Step enable="True" id="141" name="Set Variable">
    <Name>$failed</Name>
    <Value><Calculation><![CDATA[0]]></Calculation></Value>
  </Step>

  <Step enable="True" id="89" name="# (comment)"/>

  <Step enable="False" id="89" name="# (comment)">
    <Text>MARK: Validate</Text>
  </Step>

  <Step enable="True" id="68" name="If">
    <Calculation><![CDATA[Invoices::Locked = 1]]></Calculation>
  </Step>

    <Step enable="True" id="141" name="Set Variable">
      <Name>$response</Name>
      <Value><Calculation><![CDATA[Response_AddError (
	"INV_STOCK_ALREADY_LOCKED" ;
	"Invoice is already locked/posted — stock movements cannot be re-posted." ;
	"Invoices::Locked" ;
	"{}" ;
	Get ( ScriptName )
)]]></Calculation></Value>
    </Step>

  <Step enable="True" id="70" name="End If"/>

  <Step enable="True" id="68" name="If">
    <Calculation><![CDATA[JSONGetElement ( $response ; "status" ) ≠ "fail"
and ( IsEmpty ( $dokID ) or IsEmpty ( $dokDatum ) )]]></Calculation>
  </Step>

    <Step enable="True" id="141" name="Set Variable">
      <Name>$response</Name>
      <Value><Calculation><![CDATA[Response_AddError (
	"INV_STOCK_MISSING_DOC" ;
	"Invoice PrimaryKey or Datum is empty — cannot post stock movements." ;
	"Invoices::PrimaryKey" ;
	"{}" ;
	Get ( ScriptName )
)]]></Calculation></Value>
    </Step>

  <Step enable="True" id="70" name="End If"/>

  <Step enable="True" id="141" name="Set Variable">
    <Name>$tip</Name>
    <Value><Calculation><![CDATA[Case (
	$statusDokumenta = "Račun"       ; "IZLAZ" ;
	$statusDokumenta = "Reklamacija" ; "POVRAT_KUP" ;
	""
)]]></Calculation></Value>
  </Step>

  <Step enable="True" id="68" name="If">
    <Calculation><![CDATA[JSONGetElement ( $response ; "status" ) ≠ "fail"
and IsEmpty ( $tip )]]></Calculation>
  </Step>

    <Step enable="True" id="141" name="Set Variable">
      <Name>$response</Name>
      <Value><Calculation><![CDATA[Response_AddError (
	"INV_STOCK_UNSUPPORTED_STATUS" ;
	"StatusDokumenta "" & $statusDokumenta & "" is not supported — expected Račun or Reklamacija." ;
	"Invoices::StatusDokumenta" ;
	JSONSetElement ( "{}" ; [ "statusDokumenta" ; $statusDokumenta ; JSONString ] ) ;
	Get ( ScriptName )
)]]></Calculation></Value>
    </Step>

  <Step enable="True" id="70" name="End If"/>

  <Step enable="True" id="89" name="# (comment)"/>

  <Step enable="False" id="89" name="# (comment)">
    <Text>MARK: Loop lines</Text>
  </Step>

  <Step enable="True" id="68" name="If">
    <Calculation><![CDATA[JSONGetElement ( $response ; "status" ) ≠ "fail"]]></Calculation>
  </Step>

    <Step enable="True" id="79" name="Freeze Window"/>

    <Step enable="True" id="141" name="Set Variable">
      <Name>$returnLayout</Name>
      <Value><Calculation><![CDATA[Get ( LayoutName )]]></Calculation></Value>
    </Step>

    <Step enable="True" id="74" name="Go to Related Record">
      <Option state="True"/>
      <Table id="0" name="InvoiceLines"/>
      <LayoutDestination value="SelectedLayout">
        <Layout id="225" name="Dev InvoiceLines"/>
      </LayoutDestination>
      <Animation value="None"/>
    </Step>

    <Step enable="True" id="68" name="If">
      <Calculation><![CDATA[Get ( LastError ) ≠ 0]]></Calculation>
    </Step>

      <Step enable="True" id="141" name="Set Variable">
        <Name>$response</Name>
        <Value><Calculation><![CDATA[Response_AddError (
	"INV_STOCK_NO_LINES" ;
	"No related InvoiceLines found for this invoice." ;
	"InvoiceLines::ForeignKeyInvoiceID" ;
	JSONSetElement ( "{}" ; [ "invoiceID" ; $dokID ; JSONString ] ) ;
	Get ( ScriptName )
)]]></Calculation></Value>
      </Step>

    <Step enable="True" id="69" name="Else"/>

      <Step enable="True" id="16" name="Go to Record/Request/Page">
        <RowPageLocation value="First"/>
      </Step>

      <Step enable="True" id="71" name="Loop">
        <FlushType value="Always"/>
      </Step>

        <Step enable="True" id="68" name="If">
          <Calculation><![CDATA[IsEmpty ( InvoiceLines::ForeignKeyArtikal )
or InvoiceLines::VrstaStavke ≠ "Roba"]]></Calculation>
        </Step>

          <Step enable="True" id="16" name="Go to Record/Request/Page">
            <RowPageLocation value="Next"/>
            <Exit state="True"/>
          </Step>

        <Step enable="True" id="70" name="End If"/>

        <Step enable="True" id="141" name="Set Variable">
          <Name>$lineID</Name>
          <Value><Calculation><![CDATA[InvoiceLines::PrimaryKey]]></Calculation></Value>
        </Step>

        <Step enable="True" id="141" name="Set Variable">
          <Name>$artikalID</Name>
          <Value><Calculation><![CDATA[InvoiceLines::ForeignKeyArtikal]]></Calculation></Value>
        </Step>

        <Step enable="True" id="141" name="Set Variable">
          <Name>$qty</Name>
          <Value><Calculation><![CDATA[InvoiceLines::Qty]]></Calculation></Value>
        </Step>

        <Step enable="True" id="141" name="Set Variable">
          <Name>$batchID</Name>
          <Value><Calculation><![CDATA[InvoiceLines::ForeignKeyStavkaUlazneFakture]]></Calculation></Value>
        </Step>

        <Step enable="True" id="68" name="If">
          <Calculation><![CDATA[IsEmpty ( $batchID )]]></Calculation>
        </Step>

          <Step enable="True" id="141" name="Set Variable">
            <Name>$failed</Name>
            <Value><Calculation><![CDATA[$failed + 1]]></Calculation></Value>
          </Step>

          <Step enable="True" id="141" name="Set Variable">
            <Name>$response</Name>
            <Value><Calculation><![CDATA[Response_AddError (
	"INV_STOCK_MISSING_BATCH" ;
	"Roba line is missing ForeignKeyStavkaUlazneFakture — batch link required for " & $tip & "." ;
	"InvoiceLines::ForeignKeyStavkaUlazneFakture" ;
	JSONSetElement ( "{}" ;
		[ "lineID"    ; $lineID    ; JSONString ] ;
		[ "artikalID" ; $artikalID ; JSONString ]
	) ;
	Get ( ScriptName )
)]]></Calculation></Value>
          </Step>

          <Step enable="True" id="16" name="Go to Record/Request/Page">
            <RowPageLocation value="Next"/>
            <Exit state="True"/>
          </Step>

        <Step enable="True" id="70" name="End If"/>

        <Step enable="True" id="141" name="Set Variable">
          <Name>$j</Name>
          <Value><Calculation><![CDATA[JSONSetElement ( "{}" ;
	[ "ArtikalID"        ; $artikalID    ; JSONString ] ;
	[ "Datum"            ; $dokDatum     ; JSONString ] ;
	[ "Tip"              ; $tip          ; JSONString ] ;
	[ "Kolicina"         ; Abs ( $qty )  ; JSONNumber ] ;
	[ "DokumentTip"      ; "InvoiceLines" ; JSONString ] ;
	[ "DokumentID"       ; $dokID        ; JSONString ] ;
	[ "DokumentStavkaID" ; $lineID       ; JSONString ] ;
	[ "StavkaUlazaID"    ; $batchID      ; JSONString ]
)]]></Calculation></Value>
        </Step>

        <Step enable="True" id="1" name="Perform Script">
          <Calculation><![CDATA[$j]]></Calculation>
          <Script id="657" name="S__Knjiženje"/>
        </Step>

        <Step enable="True" id="141" name="Set Variable">
          <Name>$res</Name>
          <Value><Calculation><![CDATA[Get ( ScriptResult )]]></Calculation></Value>
        </Step>

        <Step enable="True" id="68" name="If">
          <Calculation><![CDATA[JSONGetElement ( $res ; "ok" ) = 1]]></Calculation>
        </Step>

          <Step enable="True" id="141" name="Set Variable">
            <Name>$posted</Name>
            <Value><Calculation><![CDATA[$posted + 1]]></Calculation></Value>
          </Step>

        <Step enable="True" id="69" name="Else"/>

          <Step enable="True" id="141" name="Set Variable">
            <Name>$failed</Name>
            <Value><Calculation><![CDATA[$failed + 1]]></Calculation></Value>
          </Step>

          <Step enable="True" id="141" name="Set Variable">
            <Name>$response</Name>
            <Value><Calculation><![CDATA[Response_AddError (
	"INV_STOCK_KNJIZENJE_FAILED" ;
	"S__Knjiženje failed for line " & $lineID & "." ;
	"InvoiceLines::PrimaryKey" ;
	JSONSetElement ( "{}" ;
		[ "lineID"    ; $lineID    ; JSONString ] ;
		[ "artikalID" ; $artikalID ; JSONString ] ;
		[ "tip"       ; $tip       ; JSONString ] ;
		[ "result"    ; $res       ; JSONObject ]
	) ;
	Get ( ScriptName )
)]]></Calculation></Value>
          </Step>

        <Step enable="True" id="70" name="End If"/>

        <Step enable="True" id="16" name="Go to Record/Request/Page">
          <RowPageLocation value="Next"/>
          <Exit state="True"/>
        </Step>

      <Step enable="True" id="73" name="End Loop"/>

    <Step enable="True" id="70" name="End If"/>

    <Step enable="True" id="6" name="Go to Layout">
      <LayoutDestination value="LayoutNameByCalculation">
        <Layout id="0" name=""/>
        <Calculation><![CDATA[$returnLayout]]></Calculation>
      </LayoutDestination>
      <Animation value="None"/>
    </Step>

  <Step enable="True" id="70" name="End If"/>

  <Step enable="True" id="89" name="# (comment)"/>

  <Step enable="False" id="89" name="# (comment)">
    <Text>MARK: Finalise</Text>
  </Step>

  <Step enable="True" id="141" name="Set Variable">
    <Name>$response</Name>
    <Value><Calculation><![CDATA[Response_SetData (
	JSONSetElement ( "{}" ;
		[ "posted" ; $posted ; JSONNumber ] ;
		[ "failed" ; $failed ; JSONNumber ]
	)
)]]></Calculation></Value>
  </Step>

  <Step enable="True" id="68" name="If">
    <Calculation><![CDATA[$failed = 0 and $posted > 0]]></Calculation>
  </Step>

    <Step enable="True" id="76" name="Set Field">
      <Calculation><![CDATA[1]]></Calculation>
      <Field table="Invoices" id="31" name="Locked"/>
    </Step>

    <Step enable="True" id="75" name="Commit Records/Requests">
      <NoInteract state="True"/>
    </Step>

    <Step enable="True" id="68" name="If">
      <Calculation><![CDATA[Get ( LastError ) ≠ 0]]></Calculation>
    </Step>

      <Step enable="True" id="141" name="Set Variable">
        <Name>$response</Name>
        <Value><Calculation><![CDATA[Response_AddError (
	"INV_STOCK_LOCK_FAILED" ;
	"All lines posted but invoice lock/commit failed." ;
	"Invoices::Locked" ;
	JSONSetElement ( "{}" ; [ "invoiceID" ; $dokID ; JSONString ] ) ;
	Get ( ScriptName )
)]]></Calculation></Value>
      </Step>

    <Step enable="True" id="70" name="End If"/>

  <Step enable="True" id="70" name="End If"/>

  <Step enable="True" id="141" name="Set Variable">
    <Name>$response</Name>
    <Value><Calculation><![CDATA[Response_Finalize]]></Calculation></Value>
  </Step>

  <Step enable="True" id="103" name="Exit Script">
    <Calculation><![CDATA[$response]]></Calculation>
  </Step>

  <Step enable="True" id="89" name="# (comment)">
    <Text>Call from Handle Success Response after fiscal success, positioned on the Invoices record:</Text>
  </Step>

  <Step enable="False" id="1" name="Perform Script">
    <Calculation><![CDATA[""]]></Calculation>
    <Script id="0" name="INV__PostStockMovements"/>
  </Step>

  <Step enable="False" id="141" name="Set Variable">
    <Name>$stockResult</Name>
    <Value><Calculation><![CDATA[Get ( ScriptResult )]]></Calculation></Value>
  </Step>

  <Step enable="False" id="68" name="If">
    <Calculation><![CDATA[JSONGetElement ( $stockResult ; "status" ) ≠ "success"]]></Calculation>
  </Step>

    <Step enable="False" id="89" name="# (comment)">
      <Text>handle partial failure — inspect $stockResult.messages for details</Text>
    </Step>

  <Step enable="False" id="70" name="End If"/>

</fmxmlsnippet>

<?xml version="1.0"?>
<fmxmlsnippet type="FMObjectList">
<Step enable="True" id="89" name="# (comment)">
      <Text>PURPOSE: Build one queued AgentExports record and return structured JSON for the callback script.</Text>
    </Step>
    <Step enable="True" id="86" name="Set Error Capture">
      <Set state="True"/>
    </Step>
    <Step enable="True" id="85" name="Allow User Abort">
      <Set state="False"/>
    </Step>
    <Step enable="True" id="141" name="Set Variable">
      <Value>
        <Calculation><![CDATA[Response_Init ( "{}" )]]></Calculation>
      </Value>
      <Name>$response</Name>
    </Step>
    <Step enable="True" id="141" name="Set Variable">
      <Value>
        <Calculation><![CDATA[Get ( ScriptParameter )]]></Calculation>
      </Value>
      <Name>$param</Name>
    </Step>
    <Step enable="True" id="141" name="Set Variable">
      <Value>
        <Calculation><![CDATA[JSONGetElement ( $param ; "id" )]]></Calculation>
      </Value>
      <Name>$id</Name>
    </Step>
    <Step enable="True" id="68" name="If">
      <Restore state="False"/>
      <Calculation><![CDATA[IsEmpty ( $id )]]></Calculation>
    </Step>
    <Step enable="True" id="141" name="Set Variable">
      <Value>
        <Calculation><![CDATA[Response_AddError (
    "AGENT_BUILD_ID_MISSING" ;
    "AgentExports id is required." ;
    "Get ( ScriptParameter )" ;
    "{}" ;
    Get ( ScriptName )
)]]></Calculation>
      </Value>
      <Name>$response</Name>
    </Step>
    <Step enable="True" id="69" name="Else">
      <Restore state="False"/>
    </Step>
    <Step enable="True" id="6" name="Go to Layout">
      <LayoutDestination value="SelectedLayout"/>
      <Layout id="250" name="AgentExports"/>
      <Animation value=""/>
    </Step>
    <Step enable="True" id="22" name="Enter Find Mode">
      <Pause state="False"/>
      <Restore state="False"/>
    </Step>
    <Step enable="True" id="76" name="Set Field">
      <Calculation><![CDATA["=" & $id]]></Calculation>
      <Field table="AgentExports" id="1" name="id"/>
    </Step>
    <Step enable="True" id="28" name="Perform Find">
      <Restore state="False"/>
    </Step>
    <Step enable="True" id="68" name="If">
      <Restore state="False"/>
      <Calculation><![CDATA[Get ( FoundCount ) ≠ 1]]></Calculation>
    </Step>
    <Step enable="True" id="141" name="Set Variable">
      <Value>
        <Calculation><![CDATA[Response_AddError (
    "AGENT_BUILD_NOT_FOUND" ;
    "Expected exactly one AgentExports row for the supplied id." ;
    "AgentExports::id" ;
    JSONSetElement ( "{}" ; [ "id" ; $id ; JSONString ] ) ;
    Get ( ScriptName )
)]]></Calculation>
      </Value>
      <Name>$response</Name>
    </Step>
    <Step enable="True" id="69" name="Else">
      <Restore state="False"/>
    </Step>
    <Step enable="True" id="76" name="Set Field">
      <Calculation><![CDATA["assembling"]]></Calculation>
      <Field table="AgentExports" id="15" name="Status"/>
    </Step>
    <Step enable="True" id="76" name="Set Field">
      <Calculation><![CDATA[Get ( CurrentTimestamp )]]></Calculation>
      <Field table="AgentExports" id="22" name="startedOn"/>
    </Step>
    <Step enable="True" id="76" name="Set Field">
      <Calculation><![CDATA[""]]></Calculation>
      <Field table="AgentExports" id="25" name="Error"/>
    </Step>
    <Step enable="True" id="75" name="Commit Records/Requests">
      <NoInteract state="True"/>
      <Option state="False"/>
      <ESSForceCommit state="False"/>
    </Step>
    <Step enable="True" id="141" name="Set Variable">
      <Value>
        <Calculation><![CDATA[Case ( IsEmpty ( AgentExports::Filename ) ; AgentExports::Solution & ".xml" ; AgentExports::Filename )]]></Calculation>
      </Value>
      <Name>$xmlFilename</Name>
    </Step>
    <Step enable="True" id="141" name="Set Variable">
      <Value>
        <Calculation><![CDATA[Get ( TemporaryPath ) & AgentExports::id & "__" & $xmlFilename]]></Calculation>
      </Value>
      <Name>$xmlFmPath</Name>
    </Step>
    <Step enable="True" id="141" name="Set Variable">
      <Value>
        <Calculation><![CDATA[ConvertFromFileMakerPath ( $xmlFmPath ; 1 )]]></Calculation>
      </Value>
      <Name>$xmlNativePath</Name>
    </Step>
    <Step enable="True" id="3" name="Save a Copy as XML">
      <Calculation><![CDATA[Get ( WindowName )]]></Calculation>
      <UniversalPathList>
        <ObjectList>
          <Location><![CDATA[$xmlFmPath]]></Location>
        </ObjectList>
      </UniversalPathList>
    </Step>
    <Step enable="True" id="141" name="Set Variable">
      <Value>
        <Calculation><![CDATA[Get ( LastError )]]></Calculation>
      </Value>
      <Name>$saveError</Name>
    </Step>
    <Step enable="True" id="68" name="If">
      <Restore state="False"/>
      <Calculation><![CDATA[$saveError ≠ 0]]></Calculation>
    </Step>
    <Step enable="True" id="76" name="Set Field">
      <Calculation><![CDATA["failed"]]></Calculation>
      <Field table="AgentExports" id="15" name="Status"/>
    </Step>
    <Step enable="True" id="76" name="Set Field">
      <Calculation><![CDATA[Get ( CurrentTimestamp )]]></Calculation>
      <Field table="AgentExports" id="23" name="finishedOn"/>
    </Step>
    <Step enable="True" id="76" name="Set Field">
      <Calculation><![CDATA["Save as XML failed (error " & $saveError & ")."]]></Calculation>
      <Field table="AgentExports" id="25" name="Error"/>
    </Step>
    <Step enable="True" id="75" name="Commit Records/Requests">
      <NoInteract state="True"/>
      <Option state="False"/>
      <ESSForceCommit state="False"/>
    </Step>
    <Step enable="True" id="141" name="Set Variable">
      <Value>
        <Calculation><![CDATA[Response_AddError (
    "AGENT_BUILD_SAVE_XML_FAILED" ;
    "Save a Copy as XML failed." ;
    "Save a Copy as XML" ;
    JSONSetElement (
        "{}" ;
        [ "id" ; AgentExports::id ; JSONString ] ;
        [ "error" ; $saveError ; JSONNumber ] ;
        [ "path" ; $xmlFmPath ; JSONString ]
    ) ;
    Get ( ScriptName )
)]]></Calculation>
      </Value>
      <Name>$response</Name>
    </Step>
    <Step enable="True" id="69" name="Else If">
      <Restore state="False"/>
      <Calculation><![CDATA[not BE_FileExists ( $xmlNativePath )]]></Calculation>
    </Step>
    <Step enable="True" id="76" name="Set Field">
      <Calculation><![CDATA["failed"]]></Calculation>
      <Field table="AgentExports" id="15" name="Status"/>
    </Step>
    <Step enable="True" id="76" name="Set Field">
      <Calculation><![CDATA[Get ( CurrentTimestamp )]]></Calculation>
      <Field table="AgentExports" id="23" name="finishedOn"/>
    </Step>
    <Step enable="True" id="76" name="Set Field">
      <Calculation><![CDATA["The XML file was not found after export."]]></Calculation>
      <Field table="AgentExports" id="25" name="Error"/>
    </Step>
    <Step enable="True" id="75" name="Commit Records/Requests">
      <NoInteract state="True"/>
      <Option state="False"/>
      <ESSForceCommit state="False"/>
    </Step>
    <Step enable="True" id="141" name="Set Variable">
      <Value>
        <Calculation><![CDATA[Response_AddError (
    "AGENT_BUILD_FILE_MISSING" ;
    "XML export path does not exist after Save a Copy as XML." ;
    "$xmlNativePath" ;
    JSONSetElement (
        "{}" ;
        [ "id" ; AgentExports::id ; JSONString ] ;
        [ "path" ; $xmlNativePath ; JSONString ]
    ) ;
    Get ( ScriptName )
)]]></Calculation>
      </Value>
      <Name>$response</Name>
    </Step>
    <Step enable="True" id="69" name="Else">
      <Restore state="False"/>
    </Step>
    <Step enable="True" id="76" name="Set Field">
      <Calculation><![CDATA[BE_FileImport ( $xmlNativePath )]]></Calculation>
      <Field table="AgentExports" id="17" name="Payload"/>
    </Step>
    <Step enable="True" id="75" name="Commit Records/Requests">
      <NoInteract state="True"/>
      <Option state="False"/>
      <ESSForceCommit state="False"/>
    </Step>
    <Step enable="True" id="141" name="Set Variable">
      <Value>
        <Calculation><![CDATA[Get ( LastError )]]></Calculation>
      </Value>
      <Name>$payloadError</Name>
    </Step>
    <Step enable="True" id="68" name="If">
      <Restore state="False"/>
      <Calculation><![CDATA[$payloadError ≠ 0]]></Calculation>
    </Step>
    <Step enable="True" id="76" name="Set Field">
      <Calculation><![CDATA["failed"]]></Calculation>
      <Field table="AgentExports" id="15" name="Status"/>
    </Step>
    <Step enable="True" id="76" name="Set Field">
      <Calculation><![CDATA[Get ( CurrentTimestamp )]]></Calculation>
      <Field table="AgentExports" id="23" name="finishedOn"/>
    </Step>
    <Step enable="True" id="76" name="Set Field">
      <Calculation><![CDATA["Failed to import XML into AgentExports::Payload (error " & $payloadError & ")."]]></Calculation>
      <Field table="AgentExports" id="25" name="Error"/>
    </Step>
    <Step enable="True" id="75" name="Commit Records/Requests">
      <NoInteract state="True"/>
      <Option state="False"/>
      <ESSForceCommit state="False"/>
    </Step>
    <Step enable="True" id="141" name="Set Variable">
      <Value>
        <Calculation><![CDATA[Response_AddError (
    "AGENT_BUILD_IMPORT_FAILED" ;
    "Failed to import XML into AgentExports::Payload." ;
    "AgentExports::Payload" ;
    JSONSetElement (
        "{}" ;
        [ "id" ; AgentExports::id ; JSONString ] ;
        [ "error" ; $payloadError ; JSONNumber ]
    ) ;
    Get ( ScriptName )
)]]></Calculation>
      </Value>
      <Name>$response</Name>
    </Step>
    <Step enable="True" id="69" name="Else">
      <Restore state="False"/>
    </Step>
    <Step enable="True" id="76" name="Set Field">
      <Calculation><![CDATA[GetContainerAttribute ( AgentExports::Payload ; "size" )]]></Calculation>
      <Field table="AgentExports" id="18" name="Bytes"/>
    </Step>
    <Step enable="True" id="76" name="Set Field">
      <Calculation><![CDATA[CryptDigest ( Base64EncodeRFC ( AgentExports::Payload ; 0 ) ; "SHA256" )]]></Calculation>
      <Field table="AgentExports" id="19" name="Sha256"/>
    </Step>
    <Step enable="True" id="76" name="Set Field">
      <Calculation><![CDATA["ready"]]></Calculation>
      <Field table="AgentExports" id="15" name="Status"/>
    </Step>
    <Step enable="True" id="76" name="Set Field">
      <Calculation><![CDATA[Get ( CurrentTimestamp )]]></Calculation>
      <Field table="AgentExports" id="23" name="finishedOn"/>
    </Step>
    <Step enable="True" id="76" name="Set Field">
      <Calculation><![CDATA[""]]></Calculation>
      <Field table="AgentExports" id="25" name="Error"/>
    </Step>
    <Step enable="True" id="75" name="Commit Records/Requests">
      <NoInteract state="True"/>
      <Option state="False"/>
      <ESSForceCommit state="False"/>
    </Step>
    <Step enable="True" id="141" name="Set Variable">
      <Value>
        <Calculation><![CDATA[BE_FileDelete ( $xmlNativePath )]]></Calculation>
      </Value>
      <Name>$deleteResult</Name>
    </Step>
    <Step enable="True" id="141" name="Set Variable">
      <Value>
        <Calculation><![CDATA[Response_SetData (
    JSONSetElement (
        "{}" ;
        [ "id" ; AgentExports::id ; JSONString ] ;
        [ "status" ; AgentExports::Status ; JSONString ] ;
        [ "filename" ; AgentExports::Filename ; JSONString ] ;
        [ "bytes" ; AgentExports::Bytes ; JSONNumber ] ;
        [ "sha256" ; AgentExports::Sha256 ; JSONString ]
    )
)]]></Calculation>
      </Value>
      <Name>$response</Name>
    </Step>
    <Step enable="True" id="70" name="End If"/>
    <Step enable="True" id="70" name="End If"/>
    <Step enable="True" id="70" name="End If"/>
    <Step enable="True" id="141" name="Set Variable">
      <Value>
        <Calculation><![CDATA[Response_Finalize]]></Calculation>
      </Value>
      <Name>$response</Name>
    </Step>
    <Step enable="True" id="103" name="Exit Script">
      <Calculation><![CDATA[$response]]></Calculation>
    </Step>
</fmxmlsnippet>

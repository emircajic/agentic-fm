<fmxmlsnippet type="FMObjectList">

	<Step enable="True" id="89" name="# (comment)">
		<Text>PURPOSE: Receive selected SO from picker, close card, store PK+number in shared state, trigger domain callback.
Called by web viewer when user clicks a service order card.</Text>
	</Step>
	<Step enable="False" id="61" name="Insert Text">
		<SelectAll state="False"/>
		<Text>PARAMS: JSON object
  pk     (text, required) — PrimaryKey of the chosen ServiceOrder
  number (text, required) — ServiceOrderNumber for display in success dialog</Text>
		<Field>$README</Field>
	</Step>

	<Step enable="True" id="85" name="Allow User Abort">
		<Set state="False"/>
	</Step>
	<Step enable="True" id="86" name="Set Error Capture">
		<Set state="True"/>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$p</Name>
		<Value><Calculation><![CDATA[Get ( ScriptParameter )]]></Calculation></Value>
	</Step>
	<Step enable="True" id="141" name="Set Variable">
		<Name>$selectedSOPK</Name>
		<Value><Calculation><![CDATA[JSONGetElement ( $p ; "pk" )]]></Calculation></Value>
	</Step>
	<Step enable="True" id="141" name="Set Variable">
		<Name>$selectedSONumber</Name>
		<Value><Calculation><![CDATA[JSONGetElement ( $p ; "number" )]]></Calculation></Value>
	</Step>

	<Step enable="False" id="89" name="# (comment)">
		<Text>MARK: Close picker card — returns script to parent window context</Text>
	</Step>
	<Step enable="True" id="121" name="Close Window">
		<LimitToWindowsOfCurrentFile state="True"/>
		<Window value="Current"/>
	</Step>

	<Step enable="False" id="89" name="# (comment)">
		<Text>MARK: Select caller window, then store PK+number in shared state</Text>
	</Step>
	<Step enable="True" id="123" name="Select Window">
		<LimitToWindowsOfCurrentFile state="True"/>
		<Window value="ByName"/>
		<Name>
			<Calculation><![CDATA[JSONGetElement ( Globals::ServiceOrderSelector ; "currentWindow" )]]></Calculation>
		</Name>
	</Step>

	<Step enable="True" id="76" name="Set Field">
		<Calculation><![CDATA[JSONSetElement ( Globals::ServiceOrderSelector ;
	["selectedServiceOrder"       ; $selectedSOPK     ; JSONString] ;
	["selectedServiceOrderNumber" ; $selectedSONumber  ; JSONString]
)]]></Calculation>
		<Field table="Globals" id="0" name="ServiceOrderSelector"/>
	</Step>

	<Step enable="False" id="89" name="# (comment)">
		<Text>MARK: Dispatch to domain script CONFIRM phase</Text>
	</Step>
	<Step enable="True" id="1" name="Perform Script">
		<Calculated>
			<Calculation><![CDATA[JSONGetElement ( Globals::ServiceOrderSelector ; "callbackScript" )]]></Calculation>
		</Calculated>
		<Calculation><![CDATA["confirm"]]></Calculation>
	</Step>

	<Step enable="True" id="103" name="Exit Script">
		<Calculation><![CDATA[Get ( ScriptResult )]]></Calculation>
	</Step>

</fmxmlsnippet>

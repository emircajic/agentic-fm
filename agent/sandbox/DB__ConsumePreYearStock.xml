<fmxmlsnippet type="FMObjectList">

	<Step enable="True" id="89" name="# (comment)">
		<Text>PURPOSE: ONE-SHOT CLEANUP — Create a dummy ServiceOrder dated 2025-12-31 17:00-18:00,
then attach all unconsumed StavkePrimke from before 2026-01-01 as ServiceOrderLines,
consuming them out of available inventory via the existing KretanjeRobe flow.
Run once. After success verify via S__FinalizeConsumption.</Text>
	</Step>

	<Step enable="True" id="85" name="Allow User Abort">
		<Set state="False"/>
	</Step>

	<Step enable="True" id="86" name="Set Error Capture">
		<Set state="True"/>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$soID</Name>
		<Value><Calculation><![CDATA[""]]></Calculation></Value>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$createdLines</Name>
		<Value><Calculation><![CDATA[0]]></Calculation></Value>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$failedLines</Name>
		<Value><Calculation><![CDATA[0]]></Calculation></Value>
	</Step>

	<Step enable="True" id="89" name="# (comment)">
		<Text>── Create the dummy ServiceOrder ─────────────────────────────────────────</Text>
	</Step>

	<Step enable="True" id="6" name="Go to Layout">
		<LayoutDestination value="SelectedLayout"/>
		<Layout id="29" name="Dev Service Orders"/>
		<Animation value="None"/>
	</Step>

	<Step enable="True" id="7" name="New Record/Request"/>

	<Step enable="True" id="76" name="Set Field">
		<Calculation><![CDATA[Date ( 12 ; 31 ; 2025 )]]></Calculation>
		<Field table="ServiceOrders" id="29" name="Date"/>
	</Step>

	<Step enable="True" id="76" name="Set Field">
		<Calculation><![CDATA[Date ( 12 ; 31 ; 2025 )]]></Calculation>
		<Field table="ServiceOrders" id="41" name="JobDate"/>
	</Step>

	<Step enable="True" id="76" name="Set Field">
		<Calculation><![CDATA[Time ( 17 ; 0 ; 0 )]]></Calculation>
		<Field table="ServiceOrders" id="35" name="JobTime"/>
	</Step>

	<Step enable="True" id="76" name="Set Field">
		<Calculation><![CDATA[Time ( 18 ; 0 ; 0 )]]></Calculation>
		<Field table="ServiceOrders" id="53" name="JobTimeEnd"/>
	</Step>

	<Step enable="True" id="76" name="Set Field">
		<Calculation><![CDATA["Završen"]]></Calculation>
		<Field table="ServiceOrders" id="11" name="Status"/>
	</Step>

	<Step enable="True" id="76" name="Set Field">
		<Calculation><![CDATA["ZATVARANJE-ZALIHA-2025"]]></Calculation>
		<Field table="ServiceOrders" id="33" name="ServiceOrderNumber"/>
	</Step>

	<Step enable="True" id="76" name="Set Field">
		<Calculation><![CDATA["Zatvaranje zaliha - roba primljena do 31.12.2025."]]></Calculation>
		<Field table="ServiceOrders" id="31" name="Description"/>
	</Step>

	<Step enable="True" id="75" name="Commit Records/Requests">
		<NoInteract state="True"/>
		<Option state="False"/>
		<ESSForceCommit state="False"/>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$fmError</Name>
		<Value><Calculation><![CDATA[Get ( LastError )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[$fmError ≠ 0]]></Calculation>
	</Step>
	<Step enable="True" id="103" name="Exit Script">
		<Calculation><![CDATA[JSONSetElement ( "{}" ;
	[ "status"  ; "fail" ; JSONString ] ;
	[ "step"    ; "create_so" ; JSONString ] ;
	[ "fmError" ; $fmError ; JSONNumber ]
)]]></Calculation>
	</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$soID</Name>
		<Value><Calculation><![CDATA[ServiceOrders::PrimaryKey]]></Calculation></Value>
	</Step>

	<Step enable="True" id="89" name="# (comment)">
		<Text>── Query unconsumed StavkePrimke from before 2026 ────────────────────────</Text>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$sql</Name>
		<Value><Calculation><![CDATA["SELECT
	sp.PrimaryKey,
	sp.ForeignKeyArtikalID,
	sp.Kolicina,
	sp.NabavnaCijenaStavke,
	sp.ProdajnaCijena,
	COALESCE( ( SELECT SUM(sol.Qty) FROM ServiceOrderLines sol WHERE sol.ForeignKeyStavkaPrimkeID = sp.PrimaryKey ) , 0 ) AS qty_used,
	COALESCE( ( SELECT SUM(sv.Kolicina) FROM StavkePovrata sv WHERE sv.ForeignKeyStavkaPrimkeID = sp.PrimaryKey ) , 0 ) AS qty_returned
FROM StavkePrimke sp
JOIN Primke p ON p.PrimaryKey = sp.ForeignKeyFakturaID
WHERE p.DatumPrimitka < '1/1/2026'
  AND sp.Kolicina > 0"]]></Calculation></Value>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$rows</Name>
		<Value><Calculation><![CDATA[ExecuteSQL ( $sql ; "|" ; "¶" )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[IsEmpty ( $rows ) or Left ( $rows ; 1 ) = "?"]]></Calculation>
	</Step>
	<Step enable="True" id="103" name="Exit Script">
		<Calculation><![CDATA[JSONSetElement ( "{}" ;
	[ "status" ; "fail" ; JSONString ] ;
	[ "step"   ; "query_stavke" ; JSONString ] ;
	[ "soID"   ; $soID ; JSONString ] ;
	[ "note"   ; "SQL returned no rows or error — check subquery syntax" ; JSONString ]
)]]></Calculation>
	</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$rowCount</Name>
		<Value><Calculation><![CDATA[ValueCount ( $rows )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$i</Name>
		<Value><Calculation><![CDATA[0]]></Calculation></Value>
	</Step>

	<Step enable="True" id="89" name="# (comment)">
		<Text>── Loop rows — create SOL for each row with qtyAvailable > 0 ─────────────</Text>
	</Step>

	<Step enable="True" id="6" name="Go to Layout">
		<LayoutDestination value="SelectedLayout"/>
		<Layout id="31" name="Dev Service Order Lines"/>
		<Animation value="None"/>
	</Step>

	<Step enable="True" id="71" name="Loop">
		<FlushType value="Always"/>
	</Step>

	<Step enable="True" id="72" name="Exit Loop If">
		<Calculation><![CDATA[$i >= $rowCount]]></Calculation>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$i</Name>
		<Value><Calculation><![CDATA[$i + 1]]></Calculation></Value>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$row</Name>
		<Value><Calculation><![CDATA[Substitute ( GetValue ( $rows ; $i ) ; "|" ; Char ( 13 ) )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$stavkaID</Name>
		<Value><Calculation><![CDATA[GetValue ( $row ; 1 )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$artikalID</Name>
		<Value><Calculation><![CDATA[GetValue ( $row ; 2 )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$kolicina</Name>
		<Value><Calculation><![CDATA[GetAsNumber ( GetValue ( $row ; 3 ) )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$nabavna</Name>
		<Value><Calculation><![CDATA[GetAsNumber ( GetValue ( $row ; 4 ) )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$prodajna</Name>
		<Value><Calculation><![CDATA[GetAsNumber ( GetValue ( $row ; 5 ) )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$qtyUsed</Name>
		<Value><Calculation><![CDATA[GetAsNumber ( GetValue ( $row ; 6 ) )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$qtyReturned</Name>
		<Value><Calculation><![CDATA[GetAsNumber ( GetValue ( $row ; 7 ) )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$qtyAvailable</Name>
		<Value><Calculation><![CDATA[$kolicina - $qtyUsed - $qtyReturned]]></Calculation></Value>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[$qtyAvailable > 0]]></Calculation>
	</Step>

	<Step enable="True" id="7" name="New Record/Request"/>

	<Step enable="True" id="76" name="Set Field">
		<Calculation><![CDATA[$soID]]></Calculation>
		<Field table="ServiceOrderLines" id="28" name="ForeignKeyServiceOrder"/>
	</Step>

	<Step enable="True" id="76" name="Set Field">
		<Calculation><![CDATA[$artikalID]]></Calculation>
		<Field table="ServiceOrderLines" id="49" name="ForeignKeyArtikalID"/>
	</Step>

	<Step enable="True" id="76" name="Set Field">
		<Calculation><![CDATA[$stavkaID]]></Calculation>
		<Field table="ServiceOrderLines" id="52" name="ForeignKeyStavkaPrimkeID"/>
	</Step>

	<Step enable="True" id="76" name="Set Field">
		<Calculation><![CDATA[$qtyAvailable]]></Calculation>
		<Field table="ServiceOrderLines" id="32" name="Qty"/>
	</Step>

	<Step enable="True" id="76" name="Set Field">
		<Calculation><![CDATA[$nabavna]]></Calculation>
		<Field table="ServiceOrderLines" id="50" name="NabavnaCijena_Stvarna"/>
	</Step>

	<Step enable="True" id="76" name="Set Field">
		<Calculation><![CDATA[$prodajna]]></Calculation>
		<Field table="ServiceOrderLines" id="34" name="Rate"/>
	</Step>

	<Step enable="True" id="76" name="Set Field">
		<Calculation><![CDATA["Zatvaranje zaliha 2025"]]></Calculation>
		<Field table="ServiceOrderLines" id="41" name="Description"/>
	</Step>

	<Step enable="True" id="75" name="Commit Records/Requests">
		<NoInteract state="True"/>
		<Option state="False"/>
		<ESSForceCommit state="False"/>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[Get ( LastError ) = 0]]></Calculation>
	</Step>
	<Step enable="True" id="141" name="Set Variable">
		<Name>$createdLines</Name>
		<Value><Calculation><![CDATA[$createdLines + 1]]></Calculation></Value>
	</Step>
	<Step enable="True" id="69" name="Else">
	</Step>
	<Step enable="True" id="141" name="Set Variable">
		<Name>$failedLines</Name>
		<Value><Calculation><![CDATA[$failedLines + 1]]></Calculation></Value>
	</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="73" name="End Loop"/>

	<Step enable="True" id="89" name="# (comment)">
		<Text>── Navigate back to the ServiceOrder and call FinalizeConsumption ─────────</Text>
	</Step>

	<Step enable="True" id="6" name="Go to Layout">
		<LayoutDestination value="SelectedLayout"/>
		<Layout id="29" name="Dev Service Orders"/>
		<Animation value="None"/>
	</Step>

	<Step enable="True" id="22" name="Enter Find Mode">
		<Pause state="False"/>
	</Step>

	<Step enable="True" id="76" name="Set Field">
		<Calculation><![CDATA[$soID]]></Calculation>
		<Field table="ServiceOrders" id="1" name="PrimaryKey"/>
	</Step>

	<Step enable="True" id="31" name="Perform Find">
		<Restore state="False"/>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[$failedLines > 0 or $createdLines = 0]]></Calculation>
	</Step>
	<Step enable="True" id="103" name="Exit Script">
		<Calculation><![CDATA[JSONSetElement ( "{}" ;
	[ "status"       ; If ( $createdLines > 0 ; "partial" ; "fail" ) ; JSONString ] ;
	[ "soID"         ; $soID ; JSONString ] ;
	[ "createdLines" ; $createdLines ; JSONNumber ] ;
	[ "failedLines"  ; $failedLines ; JSONNumber ] ;
	[ "note"         ; "Review failures before running FinalizeConsumption" ; JSONString ]
)]]></Calculation>
	</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="25" name="Perform Script">
		<Script id="660" name="S__ServiceOrder__FinalizeConsumption"/>
		<Calculation><![CDATA[""]]></Calculation>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$finalizeResult</Name>
		<Value><Calculation><![CDATA[Get ( ScriptResult )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="103" name="Exit Script">
		<Calculation><![CDATA[JSONSetElement ( "{}" ;
	[ "status"          ; If ( JSONGetElement ( $finalizeResult ; "ok" ) = 1 ; "success" ; "partial" ) ; JSONString ] ;
	[ "soID"            ; $soID ; JSONString ] ;
	[ "createdLines"    ; $createdLines ; JSONNumber ] ;
	[ "finalizeResult"  ; $finalizeResult ; JSONObject ]
)]]></Calculation>
	</Step>

</fmxmlsnippet>

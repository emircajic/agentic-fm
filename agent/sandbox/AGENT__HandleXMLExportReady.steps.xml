<?xml version="1.0"?>
<fmxmlsnippet type="FMObjectList">
  <Step enable="True" id="89" name="# (comment)">
    <Text>PURPOSE: Client callback handler for PSOS XML export completion.</Text>
  </Step>
  <Step enable="True" id="86" name="Set Error Capture">
    <Set state="True"/>
  </Step>
  <Step enable="True" id="85" name="Allow User Abort">
    <Set state="False"/>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[Response_Init ( "{}" )]]></Calculation>
    </Value>
    <Name>$response</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[Get ( ScriptParameter )]]></Calculation>
    </Value>
    <Name>$id</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[Get ( ScriptResult )]]></Calculation>
    </Value>
    <Name>$serverResult</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[JSONGetElement ( $serverResult ; "data.status" )]]></Calculation>
    </Value>
    <Name>$status</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[Get ( LayoutName )]]></Calculation>
    </Value>
    <Name>$originLayout</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[JSONGetElement ( $$AGENTIC.FM ; "companion_url" )]]></Calculation>
    </Value>
    <Name>$companionUrl</Name>
  </Step>
  <Step enable="True" id="68" name="If">
    <Restore state="False"/>
    <Calculation><![CDATA[IsEmpty ( $id )]]></Calculation>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[Response_AddError (
    "AGENT_CALLBACK_ID_MISSING" ;
    "Callback did not receive an AgentExports id." ;
    "Get ( ScriptParameter )" ;
    "{}" ;
    Get ( ScriptName )
)]]></Calculation>
    </Value>
    <Name>$response</Name>
  </Step>
  <Step enable="True" id="69" name="Else If">
    <Restore state="False"/>
    <Calculation><![CDATA[JSONGetElementType ( $serverResult ; "" ) ≠ JSONObject]]></Calculation>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[Response_AddError (
    "AGENT_CALLBACK_RESULT_INVALID" ;
    "Callback did not receive a valid JSON script result." ;
    "Get ( ScriptResult )" ;
    JSONSetElement ( "{}" ; [ "result" ; $serverResult ; JSONString ] ) ;
    Get ( ScriptName )
)]]></Calculation>
    </Value>
    <Name>$response</Name>
  </Step>
  <Step enable="True" id="69" name="Else If">
    <Restore state="False"/>
    <Calculation><![CDATA[JSONGetElement ( $serverResult ; "status" ) = "fail"]]></Calculation>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[Response_AddError (
    "AGENT_BUILD_FAILED" ;
    "Server XML build failed." ;
    "AGENT__BuildXMLExport" ;
    $serverResult ;
    Get ( ScriptName )
)]]></Calculation>
    </Value>
    <Name>$response</Name>
  </Step>
  <Step enable="True" id="69" name="Else">
    <Restore state="False"/>
  </Step>
  <Step enable="True" id="6" name="Go to Layout">
    <LayoutDestination value="SelectedLayout"/>
    <Layout id="250" name="AgentExports"/>
    <Animation value=""/>
  </Step>
  <Step enable="True" id="22" name="Enter Find Mode">
    <Pause state="False"/>
    <Restore state="False"/>
  </Step>
  <Step enable="True" id="76" name="Set Field">
    <Calculation><![CDATA["=" & $id]]></Calculation>
    <Field table="AgentExports" id="1" name="id"/>
  </Step>
  <Step enable="True" id="28" name="Perform Find">
    <Restore state="False"/>
  </Step>
  <Step enable="True" id="68" name="If">
    <Restore state="False"/>
    <Calculation><![CDATA[Get ( FoundCount ) = 1]]></Calculation>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[Case (
    JSONGetElementType ( AgentExports::Notes ; "" ) = JSONObject ;
    AgentExports::Notes ;
    JSONSetElement ( "{}" ; [ "buildNotes" ; AgentExports::Notes ; JSONString ] )
)]]></Calculation>
    </Value>
    <Name>$notes</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[JSONSetElement (
    $notes ;
    [ "callback.receivedOn" ; Get ( CurrentTimestamp ) ; JSONString ] ;
    [ "callback.status" ; $status ; JSONString ] ;
    [ "callback.result" ; $serverResult ; JSONObject ]
)]]></Calculation>
    </Value>
    <Name>$notes</Name>
  </Step>
  <Step enable="True" id="76" name="Set Field">
    <Calculation><![CDATA[$notes]]></Calculation>
    <Field table="AgentExports" id="26" name="Notes"/>
  </Step>
  <Step enable="True" id="75" name="Commit Records/Requests">
    <NoInteract state="True"/>
    <Option state="False"/>
    <ESSForceCommit state="False"/>
  </Step>
  <Step enable="True" id="70" name="End If"/>
  <Step enable="True" id="6" name="Go to Layout">
    <LayoutDestination value="By calculation"/>
    <Calculation><![CDATA[$originLayout]]></Calculation>
    <Animation value=""/>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[JSONSetElement (
    "{}" ;
    [ "id" ; $id ; JSONString ] ;
    [ "solution_name" ; Get ( FileName ) ; JSONString ] ;
    [ "repo_path" ; JSONGetElement ( $$AGENTIC.FM ; "path" ) ; JSONString ]
)]]></Calculation>
    </Value>
    <Name>$callbackPayload</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[""]]></Calculation>
    </Value>
    <Name>$consumeResult</Name>
  </Step>
  <Step enable="True" id="68" name="If">
    <Restore state="False"/>
    <Calculation><![CDATA[not IsEmpty ( $companionUrl )]]></Calculation>
  </Step>
  <Step enable="True" id="149" name="Insert from URL">
    <SelectEntireContents state="False"/>
    <Target type="Variable">$consumeResult</Target>
    <WithDialog state="False"/>
    <URL>
      <Calculation><![CDATA[$companionUrl & "/agentexports/consume"]]></Calculation>
    </URL>
    <SpecifyCurlOptions state="True">
      <Calculation><![CDATA["--header " & Quote ( "Content-Type: application/json" ) & " --request POST --data " & Quote ( $callbackPayload )]]></Calculation>
    </SpecifyCurlOptions>
    <VerifySSLCertificates state="True"/>
  </Step>
  <Step enable="True" id="70" name="End If"/>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[Response_SetData (
    JSONSetElement (
        "{}" ;
        [ "id" ; $id ; JSONString ] ;
        [ "status" ; $status ; JSONString ] ;
        [ "serverResult" ; $serverResult ; JSONObject ] ;
        [ "consumeResult" ; $consumeResult ; JSONString ]
    )
)]]></Calculation>
    </Value>
    <Name>$response</Name>
  </Step>
  <Step enable="True" id="70" name="End If"/>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[Response_Finalize]]></Calculation>
    </Value>
    <Name>$response</Name>
  </Step>
  <Step enable="True" id="103" name="Exit Script">
    <Calculation><![CDATA[$response]]></Calculation>
  </Step>
</fmxmlsnippet>

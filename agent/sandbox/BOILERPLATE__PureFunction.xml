<fmxmlsnippet type="FMObjectList">

	<Step enable="True" id="89" name="# (comment)">
		<Text>PURPOSE: [Describe what is computed/validated — e.g. "Read and validate X, return Y"]
No side effects. No layout navigation. No record commits.</Text>
	</Step>

	<Step enable="False" id="61" name="Insert Text">
		<SelectAll state="False"/>
		<Text>PARAMS: inputID (text, required) | threshold (number, optional)
RETURNS: data.isValid (boolean) | data.total (number)</Text>
		<Field table="" id="0" name="$README"/>
	</Step>

	<Step enable="True" id="85" name="Allow User Abort">
		<Set state="False"/>
	</Step>

	<Step enable="True" id="86" name="Set Error Capture">
		<Set state="True"/>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Params.parse ( Get ( ScriptParameter ) ; "inputID|threshold" )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Response_Init ( "{}" )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Log.add ( "info" ; "SCRIPT_START" ; "Evaluating inputID=" & $inputID ; $params )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="89" name="# (comment)">
		<Text>── Validate ──────────────────────────────────────────────────────────────</Text>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[IsEmpty ( $inputID )]]></Calculation>
	</Step>
		<Step enable="True" id="141" name="Set Variable">
			<Name>$void</Name>
			<Value><Calculation><![CDATA[Response_AddError ( "MISSING_PARAM" ; "inputID is required" ; "inputID" ; "{}" ; "" )]]></Calculation></Value>
		</Step>
		<Step enable="True" id="68" name="If">
			<Calculation><![CDATA[$isRoot]]></Calculation>
		</Step>
			<Step enable="True" id="25" name="Perform Script">
				<Script id="780" name="UTIL__FlushLog"/>
				<Calculation><![CDATA[JSONSetElement ( "{}" ; "traceID" ; $traceID ; JSONString )]]></Calculation>
			</Step>
		<Step enable="True" id="70" name="End If"/>
		<Step enable="True" id="103" name="Exit Script">
			<Calculation><![CDATA[Response_Finalize]]></Calculation>
		</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="89" name="# (comment)">
		<Text>── Read data via SQL (no layout navigation) ──────────────────────────────</Text>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$total</Name>
		<Value><Calculation><![CDATA[ExecuteSQL (
	"SELECT SUM(AmountField) FROM \"TargetTable\" WHERE ForeignKeyParentID = ?" ;
	"" ; "" ;
	$inputID
)]]></Calculation></Value>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[$total = "?" or IsEmpty ( $total )]]></Calculation>
	</Step>
		<Step enable="True" id="141" name="Set Variable">
			<Name>$void</Name>
			<Value><Calculation><![CDATA[Response_AddError ( "SQL_FAILED" ; "Could not read data for inputID: " & $inputID ; "" ; "{}" ; "" )]]></Calculation></Value>
		</Step>
		<Step enable="True" id="68" name="If">
			<Calculation><![CDATA[$isRoot]]></Calculation>
		</Step>
			<Step enable="True" id="25" name="Perform Script">
				<Script id="780" name="UTIL__FlushLog"/>
				<Calculation><![CDATA[JSONSetElement ( "{}" ; "traceID" ; $traceID ; JSONString )]]></Calculation>
			</Step>
		<Step enable="True" id="70" name="End If"/>
		<Step enable="True" id="103" name="Exit Script">
			<Calculation><![CDATA[Response_Finalize]]></Calculation>
		</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="89" name="# (comment)">
		<Text>── Evaluate ──────────────────────────────────────────────────────────────</Text>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$effectiveThreshold</Name>
		<Value><Calculation><![CDATA[If ( IsEmpty ( $threshold ) ; 0 ; $threshold )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$isValid</Name>
		<Value><Calculation><![CDATA[$total > $effectiveThreshold]]></Calculation></Value>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[not $isValid]]></Calculation>
	</Step>
		<Step enable="True" id="141" name="Set Variable">
			<Name>$void</Name>
			<Value><Calculation><![CDATA[Response_AddError ( "VALIDATION_FAILED" ; "Total " & $total & " does not meet threshold " & $effectiveThreshold ; "" ; JSONSetElement ( "{}" ; [ "total" ; $total ; JSONNumber ] ; [ "threshold" ; $effectiveThreshold ; JSONNumber ] ) ; "" )]]></Calculation></Value>
		</Step>
		<Step enable="True" id="68" name="If">
			<Calculation><![CDATA[$isRoot]]></Calculation>
		</Step>
			<Step enable="True" id="25" name="Perform Script">
				<Script id="780" name="UTIL__FlushLog"/>
				<Calculation><![CDATA[JSONSetElement ( "{}" ; "traceID" ; $traceID ; JSONString )]]></Calculation>
			</Step>
		<Step enable="True" id="70" name="End If"/>
		<Step enable="True" id="103" name="Exit Script">
			<Calculation><![CDATA[Response_Finalize]]></Calculation>
		</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="89" name="# (comment)">
		<Text>── Success ───────────────────────────────────────────────────────────────</Text>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Response_SetData ( JSONSetElement ( "{}" ;
	[ "isValid" ; $isValid ; JSONBoolean ] ;
	[ "total"   ; $total   ; JSONNumber  ]
) )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Log.add ( "info" ; "SCRIPT_DONE" ; "total=" & $total & " isValid=" & $isValid ; $params )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[$isRoot]]></Calculation>
	</Step>
		<Step enable="True" id="25" name="Perform Script">
			<Script id="780" name="UTIL__FlushLog"/>
			<Calculation><![CDATA[JSONSetElement ( "{}" ; "traceID" ; $traceID ; JSONString )]]></Calculation>
		</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="103" name="Exit Script">
		<Calculation><![CDATA[Response_Finalize]]></Calculation>
	</Step>

</fmxmlsnippet>

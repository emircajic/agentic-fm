    <Value>
      <Calculation><![CDATA[Settings_Get ( "invoices.currentType" ; "" )]]></Calculation>
    </Value>
    <Name>$currentType</Name>
  </Step>
  <Step enable="True" id="70" name="End If"/>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[getCompanyID ( Settings_Get ( "invoices.currentCompany" ; "" ) )]]></Calculation>
    </Value>
    <Name>$currentCompany</Name>
  </Step>
  <Step enable="True" id="22" name="Enter Find Mode">
    <Pause state="False"/>
  </Step>
  <Step enable="True" id="76" name="Set Field">
    <Field table="Invoices" id="21" name="StatusDokumenta"/>

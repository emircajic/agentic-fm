  </Step>
  <Step enable="True" id="28" name="Perform Find"/>
  <Step enable="True" id="39" name="Sort Records">
    <NoInteract state="True"/>
    <Restore state="True"/>
  </Step>
  <Step enable="True" id="16" name="Go to Record/Request/Page">
    <GoTo value="Last"/>
  </Step>
  <Step enable="True" id="68" name="If">
    <Restore state="False"/>
    <Calculation><![CDATA[not IsEmpty ( Get ( ScriptParameter ) )]]></Calculation>
  </Step>
  <Step enable="True" id="1" name="Perform Script">
    <Calculated>
      <Calculation><![CDATA["SETTINGS__SetValue"]]></Calculation>
    </Calculated>
    <Calculation><![CDATA[JSONSetElement (
    "{}" ;
    [ "key" ; "invoices.currentType" ; JSONString ] ;
    [ "value" ; Get ( ScriptParameter ) ; JSONString ] ;
    [ "valueType" ; JSONString ; JSONNumber ] ;
    [ "reload" ; True ; JSONBoolean ]
)]]></Calculation>
  </Step>
  <Step enable="True" id="70" name="End If"/>
</fmxmlsnippet>

<?xml version="1.0"?>
<fmxmlsnippet type="FMObjectList">
  <Step enable="True" id="89" name="# (comment)">
    <Text>PURPOSE: Merge razduzenje rows from virman and daily deposits.</Text>
  </Step>
  <Step enable="False" id="89" name="# (comment)">
    <Text>// Expects JSON: { "companyID": &lt;text&gt;, "datumOd": &lt;date&gt;, "datumDo": &lt;date&gt; }</Text>
  </Step>
  <Step enable="False" id="89" name="# (comment)">
    <Text>// Returns JSON: { "status": "success|fail", "rows": [], "errors": [] }</Text>
  </Step>
  <Step enable="True" id="89" name="# (comment)"/>
  <Step enable="True" id="85" name="Allow User Abort">
    <Set state="False"/>
  </Step>
  <Step enable="True" id="86" name="Set Error Capture">
    <Set state="True"/>
  </Step>
  <Step enable="True" id="89" name="# (comment)"/>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[Get ( ScriptParameter )]]></Calculation>
    </Value>
    <Name>$param</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[JSONGetElement ( $param ; "companyID" )]]></Calculation>
    </Value>
    <Name>$companyID</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[JSONGetElement ( $param ; "datumOd" )]]></Calculation>
    </Value>
    <Name>$datumOd</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[JSONGetElement ( $param ; "datumDo" )]]></Calculation>
    </Value>
    <Name>$datumDo</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA["[]"]]></Calculation>
    </Value>
    <Name>$errors</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA["[]"]]></Calculation>
    </Value>
    <Name>$rows</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[False]]></Calculation>
    </Value>
    <Name>$exit</Name>
  </Step>
  <Step enable="True" id="89" name="# (comment)"/>
  <Step enable="True" id="68" name="If">
    <Restore state="False"/>
    <Calculation><![CDATA[IsEmpty ( $companyID )]]></Calculation>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[JSONSetElement ( $errors ; "[+]" ; "Nedostaje companyID" ; JSONString )]]></Calculation>
    </Value>
    <Name>$errors</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[True]]></Calculation>
    </Value>
    <Name>$exit</Name>
  </Step>
  <Step enable="True" id="70" name="End If"/>
  <Step enable="True" id="68" name="If">
    <Restore state="False"/>
    <Calculation><![CDATA[IsEmpty ( $datumOd )]]></Calculation>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[JSONSetElement ( $errors ; "[+]" ; "Nedostaje datumOd" ; JSONString )]]></Calculation>
    </Value>
    <Name>$errors</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[True]]></Calculation>
    </Value>
    <Name>$exit</Name>
  </Step>
  <Step enable="True" id="70" name="End If"/>
  <Step enable="True" id="68" name="If">
    <Restore state="False"/>
    <Calculation><![CDATA[IsEmpty ( $datumDo )]]></Calculation>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[JSONSetElement ( $errors ; "[+]" ; "Nedostaje datumDo" ; JSONString )]]></Calculation>
    </Value>
    <Name>$errors</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[True]]></Calculation>
    </Value>
    <Name>$exit</Name>
  </Step>
  <Step enable="True" id="70" name="End If"/>
  <Step enable="True" id="68" name="If">
    <Restore state="False"/>
    <Calculation><![CDATA[$exit]]></Calculation>
  </Step>
  <Step enable="True" id="103" name="Exit Script">
    <Calculation><![CDATA[JSONSetElement ( "{}" ;
	[ "status" ; "fail" ; JSONString ] ;
	[ "rows" ; $rows ; JSONArray ] ;
	[ "errors" ; $errors ; JSONArray ]
)]]></Calculation>
  </Step>
  <Step enable="True" id="70" name="End If"/>
  <Step enable="True" id="89" name="# (comment)"/>
  <Step enable="True" id="1" name="Perform Script">
    <Calculated>
      <Calculation><![CDATA["TK__GetRazduzenjeVirman"]]></Calculation>
    </Calculated>
    <Calculation><![CDATA[JSONSetElement ( "{}" ;
	[ "companyID" ; $companyID ; JSONString ] ;
	[ "datumOd" ; $datumOd ; JSONString ] ;
	[ "datumDo" ; $datumDo ; JSONString ]
)]]></Calculation>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[Get ( ScriptResult )]]></Calculation>
    </Value>
    <Name>$virmanResult</Name>
  </Step>
  <Step enable="True" id="68" name="If">
    <Restore state="False"/>
    <Calculation><![CDATA[JSONGetElement ( $virmanResult ; "status" ) ≠ "success"]]></Calculation>
  </Step>
  <Step enable="True" id="103" name="Exit Script">
    <Calculation><![CDATA[JSONSetElement ( "{}" ;
	[ "status" ; "fail" ; JSONString ] ;
	[ "rows" ; $rows ; JSONArray ] ;
	[ "errors" ; JSONGetElement ( $virmanResult ; "errors" ) ; JSONArray ]
)]]></Calculation>
  </Step>
  <Step enable="True" id="70" name="End If"/>
  <Step enable="True" id="89" name="# (comment)"/>
  <Step enable="True" id="1" name="Perform Script">
    <Calculated>
      <Calculation><![CDATA["TK__GetRazduzenjePolozi"]]></Calculation>
    </Calculated>
    <Calculation><![CDATA[JSONSetElement ( "{}" ;
	[ "companyID" ; $companyID ; JSONString ] ;
	[ "datumOd" ; $datumOd ; JSONString ] ;
	[ "datumDo" ; $datumDo ; JSONString ]
)]]></Calculation>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[Get ( ScriptResult )]]></Calculation>
    </Value>
    <Name>$poloziResult</Name>
  </Step>
  <Step enable="True" id="68" name="If">
    <Restore state="False"/>
    <Calculation><![CDATA[JSONGetElement ( $poloziResult ; "status" ) ≠ "success"]]></Calculation>
  </Step>
  <Step enable="True" id="103" name="Exit Script">
    <Calculation><![CDATA[JSONSetElement ( "{}" ;
	[ "status" ; "fail" ; JSONString ] ;
	[ "rows" ; $rows ; JSONArray ] ;
	[ "errors" ; JSONGetElement ( $poloziResult ; "errors" ) ; JSONArray ]
)]]></Calculation>
  </Step>
  <Step enable="True" id="70" name="End If"/>
  <Step enable="True" id="89" name="# (comment)"/>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[JSONMergeArrays ( $errors ; JSONGetElement ( $virmanResult ; "errors" ) )]]></Calculation>
    </Value>
    <Name>$errors</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[JSONMergeArrays ( $errors ; JSONGetElement ( $poloziResult ; "errors" ) )]]></Calculation>
    </Value>
    <Name>$errors</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[JSONMergeArrays ( JSONGetElement ( $virmanResult ; "rows" ) ; JSONGetElement ( $poloziResult ; "rows" ) )]]></Calculation>
    </Value>
    <Name>$rows</Name>
  </Step>
  <Step enable="True" id="89" name="# (comment)"/>
  <Step enable="True" id="103" name="Exit Script">
    <Calculation><![CDATA[JSONSetElement ( "{}" ;
	[ "status" ; "success" ; JSONString ] ;
	[ "rows" ; $rows ; JSONArray ] ;
	[ "errors" ; $errors ; JSONArray ]
)]]></Calculation>
  </Step>
</fmxmlsnippet>

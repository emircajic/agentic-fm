<fmxmlsnippet type="FMObjectList">

	<Step enable="True" id="89" name="# (comment)">
		<Text>PURPOSE: Release all attached Primke from a UFD header, then delete the UFD record.</Text>
	</Step>

	<Step enable="False" id="61" name="Insert Text">
		<SelectAll state="False"/>
		<Text>PARAMS: ulaznaFakturaID (text, required)
RETURNS: data.releasedCount (number)</Text>
		<Field table="" id="0" name="$README"/>
	</Step>

	<Step enable="True" id="85" name="Allow User Abort">
		<Set state="False"/>
	</Step>

	<Step enable="True" id="86" name="Set Error Capture">
		<Set state="True"/>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Params.parse ( Get ( ScriptParameter ) ; "ulaznaFakturaID" )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Response_Init ( "{}" )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$releasedCount</Name>
		<Value><Calculation><![CDATA[0]]></Calculation></Value>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Log.add ( "info" ; "UFD_REMOVE_START" ; "Removing UFD: " & $ulaznaFakturaID ; $params )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="89" name="# (comment)">
		<Text>── Validate ──────────────────────────────────────────────────────────────</Text>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[IsEmpty ( $ulaznaFakturaID )]]></Calculation>
	</Step>
		<Step enable="True" id="141" name="Set Variable">
			<Name>$void</Name>
			<Value><Calculation><![CDATA[Response_AddError ( "MISSING_PARAM" ; "ulaznaFakturaID is required" ; "ulaznaFakturaID" ; "{}" ; "" )]]></Calculation></Value>
		</Step>
		<Step enable="True" id="68" name="If">
			<Calculation><![CDATA[$isRoot]]></Calculation>
		</Step>
			<Step enable="True" id="25" name="Perform Script">
				<Script id="780" name="UTIL__FlushLog"/>
				<Calculation><![CDATA[JSONSetElement ( "{}" ; "traceID" ; $traceID ; JSONString )]]></Calculation>
			</Step>
		<Step enable="True" id="70" name="End If"/>
		<Step enable="True" id="103" name="Exit Script">
			<Calculation><![CDATA[Response_Finalize]]></Calculation>
		</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="89" name="# (comment)">
		<Text>── Collect attached Primke PKs via SQL ───────────────────────────────────</Text>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$primkaRows</Name>
		<Value><Calculation><![CDATA[ExecuteSQL (
	"SELECT PrimaryKey FROM Primke WHERE ForeignKeyUlaznaFakturaID = ?" ;
	"" ; "¶" ;
	$ulaznaFakturaID
)]]></Calculation></Value>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$primkaCount</Name>
		<Value><Calculation><![CDATA[If ( IsEmpty ( $primkaRows ) or Left ( $primkaRows ; 1 ) = "?" ; 0 ; ValueCount ( $primkaRows ) )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="89" name="# (comment)">
		<Text>── Release Primke — single find with multiple requests, then iterate found set ──</Text>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[$primkaCount > 0]]></Calculation>
	</Step>

		<Step enable="True" id="6" name="Go to Layout">
			<LayoutDestination value="SelectedLayout"/>
			<Layout id="229" name="Dev Primke"/>
			<Animation value="None"/>
		</Step>

		<Step enable="True" id="22" name="Enter Find Mode">
			<Pause state="False"/>
		</Step>

		<Step enable="True" id="76" name="Set Field">
			<Calculation><![CDATA[GetValue ( $primkaRows ; 1 )]]></Calculation>
			<Field table="Primke" id="1" name="PrimaryKey"/>
		</Step>

		<Step enable="True" id="89" name="# (comment)">
			<Text>Add one find request per additional Primka</Text>
		</Step>

		<Step enable="True" id="141" name="Set Variable">
			<Name>$i</Name>
			<Value><Calculation><![CDATA[2]]></Calculation></Value>
		</Step>

		<Step enable="True" id="71" name="Loop">
			<FlushType value="Always"/>
		</Step>
			<Step enable="True" id="72" name="Exit Loop If">
				<Calculation><![CDATA[$i > $primkaCount]]></Calculation>
			</Step>
			<Step enable="True" id="7" name="New Record/Request"/>
			<Step enable="True" id="76" name="Set Field">
				<Calculation><![CDATA[GetValue ( $primkaRows ; $i )]]></Calculation>
				<Field table="Primke" id="1" name="PrimaryKey"/>
			</Step>
			<Step enable="True" id="141" name="Set Variable">
				<Name>$i</Name>
				<Value><Calculation><![CDATA[$i + 1]]></Calculation></Value>
			</Step>
		<Step enable="True" id="73" name="End Loop"/>

		<Step enable="True" id="31" name="Perform Find">
			<Restore state="False"/>
		</Step>

		<Step enable="True" id="141" name="Set Variable">
			<Name>$releasedCount</Name>
			<Value><Calculation><![CDATA[Get ( FoundCount )]]></Calculation></Value>
		</Step>

		<Step enable="True" id="89" name="# (comment)">
			<Text>Iterate found set — no layout navigation inside loop</Text>
		</Step>

		<Step enable="True" id="16" name="Go to Record/Request/Page">
			<RowPageLocation value="First"/>
			<Exit state="False"/>
		</Step>

		<Step enable="True" id="71" name="Loop">
			<FlushType value="Always"/>
		</Step>
			<Step enable="True" id="76" name="Set Field">
				<Calculation><![CDATA[""]]></Calculation>
				<Field table="Primke" id="18" name="ForeignKeyUlaznaFakturaID"/>
			</Step>
			<Step enable="True" id="76" name="Set Field">
				<Calculation><![CDATA["Otvorena"]]></Calculation>
				<Field table="Primke" id="14" name="Status"/>
			</Step>
			<Step enable="True" id="75" name="Commit Records/Requests">
				<NoInteract state="True"/>
				<Option state="False"/>
				<ESSForceCommit state="False"/>
			</Step>
			<Step enable="True" id="16" name="Go to Record/Request/Page">
				<RowPageLocation value="Next"/>
				<Exit state="True"/>
			</Step>
		<Step enable="True" id="73" name="End Loop"/>

	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="89" name="# (comment)">
		<Text>── Delete UFD record ─────────────────────────────────────────────────────</Text>
	</Step>

	<Step enable="True" id="6" name="Go to Layout">
		<LayoutDestination value="SelectedLayout"/>
		<Layout id="240" name="UFD__UlaznaFakturaDobavljaca"/>
		<Animation value="None"/>
	</Step>

	<Step enable="True" id="22" name="Enter Find Mode">
		<Pause state="False"/>
	</Step>

	<Step enable="True" id="76" name="Set Field">
		<Calculation><![CDATA[$ulaznaFakturaID]]></Calculation>
		<Field table="UFD__UlaznaFakturaDobavljaca" id="1" name="PrimaryKey"/>
	</Step>

	<Step enable="True" id="31" name="Perform Find">
		<Restore state="False"/>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[Get ( FoundCount ) = 0]]></Calculation>
	</Step>
		<Step enable="True" id="141" name="Set Variable">
			<Name>$void</Name>
			<Value><Calculation><![CDATA[Response_AddWarning ( "UFD_ALREADY_GONE" ; "UFD record not found for deletion: " & $ulaznaFakturaID ; "" ; "{}" ; "" )]]></Calculation></Value>
		</Step>
	<Step enable="True" id="69" name="Else">
	</Step>
		<Step enable="True" id="30" name="Delete Record/Request">
			<NoInteract state="True"/>
		</Step>
		<Step enable="True" id="68" name="If">
			<Calculation><![CDATA[Get ( LastError ) ≠ 0]]></Calculation>
		</Step>
			<Step enable="True" id="141" name="Set Variable">
				<Name>$void</Name>
				<Value><Calculation><![CDATA[Response_AddError ( "DELETE_FAILED" ; "Failed to delete UFD record (FM error " & Get ( LastError ) & ")" ; "" ; JSONSetElement ( "{}" ; "ulaznaFakturaID" ; $ulaznaFakturaID ; JSONString ) ; "" )]]></Calculation></Value>
			</Step>
			<Step enable="True" id="141" name="Set Variable">
				<Name>$void</Name>
				<Value><Calculation><![CDATA[Log.add ( "error" ; "UFD_DELETE_FAILED" ; "Delete failed: " & $ulaznaFakturaID & " FM error " & Get ( LastError ) ; $params )]]></Calculation></Value>
			</Step>
			<Step enable="True" id="68" name="If">
				<Calculation><![CDATA[$isRoot]]></Calculation>
			</Step>
				<Step enable="True" id="25" name="Perform Script">
					<Script id="780" name="UTIL__FlushLog"/>
					<Calculation><![CDATA[JSONSetElement ( "{}" ; "traceID" ; $traceID ; JSONString )]]></Calculation>
				</Step>
			<Step enable="True" id="70" name="End If"/>
			<Step enable="True" id="103" name="Exit Script">
				<Calculation><![CDATA[Response_Finalize]]></Calculation>
			</Step>
		<Step enable="True" id="70" name="End If"/>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="89" name="# (comment)">
		<Text>── Result ────────────────────────────────────────────────────────────────</Text>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Response_SetData ( JSONSetElement ( "{}" ; "releasedCount" ; $releasedCount ; JSONNumber ) )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Log.add ( "info" ; "UFD_REMOVE_OK" ; "UFD removed, released " & $releasedCount & " primke" ; $params )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[$isRoot]]></Calculation>
	</Step>
		<Step enable="True" id="25" name="Perform Script">
			<Script id="780" name="UTIL__FlushLog"/>
			<Calculation><![CDATA[JSONSetElement ( "{}" ; "traceID" ; $traceID ; JSONString )]]></Calculation>
		</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="103" name="Exit Script">
		<Calculation><![CDATA[Response_Finalize]]></Calculation>
	</Step>

</fmxmlsnippet>

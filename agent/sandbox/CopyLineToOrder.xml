<fmxmlsnippet type="FMObjectList">

	<Step enable="True" id="141" name="Set Variable">
		<Name>$action</Name>
		<Value><Calculation><![CDATA[Get ( ScriptParameter )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[$action = "prepare"]]></Calculation>
	</Step>

		<Step enable="False" id="89" name="# (comment)">
			<Text>MARK: Capture stavka context before any layout switch</Text>
		</Step>
		<Step enable="True" id="141" name="Set Variable">
			<Name>$stavkaPK</Name>
			<Value><Calculation><![CDATA[StavkePrimke::PrimaryKey]]></Calculation></Value>
		</Step>
		<Step enable="True" id="141" name="Set Variable">
			<Name>$fakturaPK</Name>
			<Value><Calculation><![CDATA[StavkePrimke::ForeignKeyPrimkaID]]></Calculation></Value>
		</Step>
		<Step enable="True" id="141" name="Set Variable">
			<Name>$artikalPK</Name>
			<Value><Calculation><![CDATA[StavkePrimke::ForeignKeyArtikalID]]></Calculation></Value>
		</Step>
		<Step enable="True" id="141" name="Set Variable">
			<Name>$nazivArtikla</Name>
			<Value><Calculation><![CDATA[Artikli::NazivArtikla]]></Calculation></Value>
		</Step>
		<Step enable="True" id="141" name="Set Variable">
			<Name>$kolicina</Name>
			<Value><Calculation><![CDATA[StavkePrimke::Kolicina]]></Calculation></Value>
		</Step>
		<Step enable="True" id="141" name="Set Variable">
			<Name>$jm</Name>
			<Value><Calculation><![CDATA[StavkePrimke::JM]]></Calculation></Value>
		</Step>
		<Step enable="True" id="141" name="Set Variable">
			<Name>$nabavnaCijena</Name>
			<Value><Calculation><![CDATA[StavkePrimke::NabavnaCijenaStavke]]></Calculation></Value>
		</Step>
		<Step enable="True" id="141" name="Set Variable">
			<Name>$prodajnaCijena</Name>
			<Value><Calculation><![CDATA[StavkePrimke::ProdajnaCijena]]></Calculation></Value>
		</Step>
		<Step enable="True" id="141" name="Set Variable">
			<Name>$qtyAvailable</Name>
			<Value><Calculation><![CDATA[StavkePrimke::QtyAvailable_Calculation]]></Calculation></Value>
		</Step>
		<Step enable="True" id="141" name="Set Variable">
			<Name>$transferStatus</Name>
			<Value><Calculation><![CDATA[StavkePrimke::TransferStatus_Display]]></Calculation></Value>
		</Step>
		<Step enable="True" id="141" name="Set Variable">
			<Name>$currentLayout</Name>
			<Value><Calculation><![CDATA[Get ( LayoutName )]]></Calculation></Value>
		</Step>
		<Step enable="True" id="141" name="Set Variable">
			<Name>$currentWindow</Name>
			<Value><Calculation><![CDATA[Get ( WindowName )]]></Calculation></Value>
		</Step>

		<Step enable="False" id="89" name="# (comment)">
			<Text>MARK: Store full context in shared global state</Text>
		</Step>
		<Step enable="True" id="76" name="Set Field">
			<Calculation><![CDATA[JSONSetElement ( "{}" ;
	["currentLayout"             ; $currentLayout   ; JSONString] ;
	["currentRecordID"           ; Primke::PrimaryKey ; JSONString] ;
	["currentWindow"             ; $currentWindow   ; JSONString] ;
	["selectedServiceOrder"      ; ""               ; JSONString] ;
	["selectedServiceOrderNumber"; ""               ; JSONString] ;
	["callbackScript"            ; "CopyLineToOrder"; JSONString] ;
	["pickerMode"                ; "Active"         ; JSONString] ;
	["stavkaPK"                  ; $stavkaPK        ; JSONString] ;
	["fakturaPK"                 ; $fakturaPK       ; JSONString] ;
	["artikalPK"                 ; $artikalPK       ; JSONString] ;
	["nazivArtikla"              ; $nazivArtikla    ; JSONString] ;
	["kolicina"                  ; $kolicina        ; JSONNumber] ;
	["nabavnaCijena"             ; $nabavnaCijena   ; JSONNumber] ;
	["prodajnaCijena"            ; $prodajnaCijena  ; JSONNumber] ;
	["qtyAvailable"              ; $qtyAvailable    ; JSONNumber] ;
	["transferStatus"            ; $transferStatus  ; JSONString] ;
	["transferredQuantity"       ; $qtyAvailable    ; JSONNumber] ;
	["jm"                        ; $jm              ; JSONString]
)]]></Calculation>
			<Field table="Globals" id="0" name="ServiceOrderSelector"/>
		</Step>

		<Step enable="True" id="86" name="Set Error Capture">
			<Set state="True"/>
		</Step>
		<Step enable="True" id="85" name="Allow User Abort">
			<Set state="False"/>
		</Step>

		<Step enable="False" id="89" name="# (comment)">
			<Text>MARK: Validate stavka has required data</Text>
		</Step>
		<Step enable="True" id="68" name="If">
			<Calculation><![CDATA[IsEmpty ( $stavkaPK ) or IsEmpty ( $artikalPK )]]></Calculation>
		</Step>
			<Step enable="True" id="52" name="Show Custom Dialog">
				<Title><Calculation><![CDATA["Greška"]]></Calculation></Title>
				<Message><Calculation><![CDATA["Ova stavka nema potrebne podatke. Provjerite da li je artikal odabran."]]></Calculation></Message>
				<Buttons>
					<Button name="OK" IsDefault="True"/>
				</Buttons>
			</Step>
			<Step enable="True" id="76" name="Set Field">
				<Calculation><![CDATA[""]]></Calculation>
				<Field table="Globals" id="0" name="ServiceOrderSelector"/>
			</Step>
			<Step enable="True" id="103" name="Exit Script">
				<Calculation><![CDATA["Missing data"]]></Calculation>
			</Step>
		<Step enable="True" id="70" name="End If"/>

		<Step enable="False" id="89" name="# (comment)">
			<Text>MARK: Validate available quantity</Text>
		</Step>
		<Step enable="True" id="68" name="If">
			<Calculation><![CDATA[$qtyAvailable <= 0]]></Calculation>
		</Step>
			<Step enable="True" id="52" name="Show Custom Dialog">
				<Title><Calculation><![CDATA["Nema dostupne količine"]]></Calculation></Title>
				<Message><Calculation><![CDATA["Ova stavka je već u potpunosti iskorištena ili vraćena.¶¶Status: " & $transferStatus & "¶Dostupna količina: " & $qtyAvailable]]></Calculation></Message>
				<Buttons>
					<Button name="OK" IsDefault="True"/>
				</Buttons>
			</Step>
			<Step enable="True" id="76" name="Set Field">
				<Calculation><![CDATA[""]]></Calculation>
				<Field table="Globals" id="0" name="ServiceOrderSelector"/>
			</Step>
			<Step enable="True" id="103" name="Exit Script">
				<Calculation><![CDATA["No quantity available"]]></Calculation>
			</Step>
		<Step enable="True" id="70" name="End If"/>

		<Step enable="False" id="89" name="# (comment)">
			<Text>MARK: Open SO picker — qty input is handled inline in the picker web viewer</Text>
		</Step>
		<Step enable="True" id="1" name="Perform Script">
			<Script id="0" name="SO__OpenSOPicker"/>
		</Step>

	<Step enable="True" id="67" name="Else"/>
		<Step enable="True" id="76" name="Set Field">
			<Calculation><![CDATA[""]]></Calculation>
			<Field table="Globals" id="0" name="ServiceOrderSelector"/>
		</Step>
	<Step enable="True" id="70" name="End If"/>

</fmxmlsnippet>

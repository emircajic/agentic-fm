<?xml version="1.0"?>
<fmxmlsnippet type="FMObjectList">
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[Substitute ( Get ( ScriptParameter ) ; "|" ; ¶ )]]></Calculation>
    </Value>
    <Name>$parametar</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[GetValue ( $parametar ; 1 )]]></Calculation>
    </Value>
    <Name>$verb</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[GetValue ( $parametar ; 2 )]]></Calculation>
    </Value>
    <Name>$verbData</Name>
  </Step>
  <Step enable="True" id="68" name="If">
    <Restore state="False"/>
    <Calculation><![CDATA[$verb = "init"]]></Calculation>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[Settings_GetScopeObject ( "layouts" ; "184" ; "{}" )]]></Calculation>
    </Value>
    <Name>$opcije</Name>
  </Step>
  <Step enable="True" id="1" name="Perform Script">
    <Calculated>
      <Calculation><![CDATA["SETTINGS__SetValue"]]></Calculation>
    </Calculated>
    <Calculation><![CDATA[JSONSetElement (
    "{}" ;
    [ "key" ; "layouts.184.currentDate" ; JSONString ] ;
    [ "value" ; date.format ( Get ( CurrentDate ) ; "yyyy-mm-dd" ) ; JSONString ] ;
    [ "valueType" ; JSONString ; JSONNumber ] ;
    [ "reload" ; True ; JSONBoolean ]
)]]></Calculation>
  </Step>
  <Step enable="True" id="103" name="Exit Script">
    <Calculation><![CDATA[""]]></Calculation>
  </Step>
  <Step enable="True" id="121" name="Else If">
    <Restore state="False"/>
    <Calculation><![CDATA[$verb = "exit"]]></Calculation>
  </Step>
  <Step enable="True" id="121" name="Else If">
    <Restore state="False"/>
    <Calculation><![CDATA[$verb = "navigate"]]></Calculation>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[Let (
[
    currentView = Settings_Get ( "layouts.184.currentView" ; "" )
] ;
    Case (
        currentView = "daily" ; 1 ;
        currentView = "weekly" ; 7 ;
        currentView = "three_day" ; 3
    )
)]]></Calculation>
    </Value>
    <Name>$change</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[JSDateToFMDate ( Settings_Get ( "layouts.184.currentDate" ; "" ) )]]></Calculation>
    </Value>
    <Name>$currentDate</Name>
  </Step>
  <Step enable="True" id="68" name="If">
    <Restore state="False"/>
    <Calculation><![CDATA[$verbData = "today"]]></Calculation>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[Get ( CurrentDate )]]></Calculation>
    </Value>
    <Name>$currentDate</Name>
  </Step>
  <Step enable="True" id="121" name="Else If">
    <Restore state="False"/>
    <Calculation><![CDATA[$verbData = "previous"]]></Calculation>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[$currentDate - $change]]></Calculation>
    </Value>
    <Name>$currentDate</Name>
  </Step>
  <Step enable="True" id="121" name="Else If">
    <Restore state="False"/>
    <Calculation><![CDATA[$verbData = "next"]]></Calculation>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[$currentDate + $change]]></Calculation>
    </Value>
    <Name>$currentDate</Name>
  </Step>
  <Step enable="True" id="70" name="End If"/>
  <Step enable="True" id="1" name="Perform Script">
    <Calculated>
      <Calculation><![CDATA["SETTINGS__SetValue"]]></Calculation>
    </Calculated>
    <Calculation><![CDATA[JSONSetElement (
    "{}" ;
    [ "key" ; "layouts.184.currentDate" ; JSONString ] ;
    [ "value" ; date.format ( $currentDate ; "yyyy-mm-dd" ) ; JSONString ] ;
    [ "valueType" ; JSONString ; JSONNumber ] ;
    [ "reload" ; True ; JSONBoolean ]
)]]></Calculation>
  </Step>
  <Step enable="True" id="121" name="Else If">
    <Restore state="False"/>
    <Calculation><![CDATA[$verb = "view"]]></Calculation>
  </Step>
  <Step enable="True" id="68" name="If">
    <Restore state="False"/>
    <Calculation><![CDATA[$verbData = "weekly"]]></Calculation>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[Let (
[
    currentDate = JSDateToFMDate ( Settings_Get ( "layouts.184.currentDate" ; "" ) )
] ;
    currentDate - DayOfWeek ( currentDate ) + 2
)]]></Calculation>
    </Value>
    <Name>$datum</Name>
  </Step>
  <Step enable="True" id="1" name="Perform Script">
    <Calculated>
      <Calculation><![CDATA["SETTINGS__SetValue"]]></Calculation>
    </Calculated>
    <Calculation><![CDATA[JSONSetElement (
    "{}" ;
    [ "key" ; "layouts.184.currentDate" ; JSONString ] ;
    [ "value" ; FMDateToJSDate ( $datum ) ; JSONString ] ;
    [ "valueType" ; JSONString ; JSONNumber ] ;
    [ "reload" ; True ; JSONBoolean ]
)]]></Calculation>
  </Step>
  <Step enable="True" id="70" name="End If"/>
  <Step enable="True" id="1" name="Perform Script">
    <Calculated>
      <Calculation><![CDATA["SETTINGS__SetValue"]]></Calculation>
    </Calculated>
    <Calculation><![CDATA[JSONSetElement (
    "{}" ;
    [ "key" ; "layouts.184.currentView" ; JSONString ] ;
    [ "value" ; $verbData ; JSONString ] ;
    [ "valueType" ; JSONString ; JSONNumber ] ;
    [ "reload" ; True ; JSONBoolean ]
)]]></Calculation>
  </Step>
  <Step enable="True" id="121" name="Else If">
    <Restore state="False"/>
    <Calculation><![CDATA[$verb = "display"]]></Calculation>
  </Step>
  <Step enable="True" id="1" name="Perform Script">
    <Calculated>
      <Calculation><![CDATA["SETTINGS__SetValue"]]></Calculation>
    </Calculated>
    <Calculation><![CDATA[JSONSetElement (
    "{}" ;
    [ "key" ; "layouts.184.displayType" ; JSONString ] ;
    [ "value" ; $verbData ; JSONString ] ;
    [ "valueType" ; JSONString ; JSONNumber ] ;
    [ "reload" ; True ; JSONBoolean ]
)]]></Calculation>
  </Step>
  <Step enable="True" id="70" name="End If"/>
  <Step enable="True" id="1" name="Perform Script">
    <Calculated>
      <Calculation><![CDATA["RefreshWebViewer"]]></Calculation>
    </Calculated>
    <Calculation><![CDATA[.1]]></Calculation>
  </Step>
</fmxmlsnippet>

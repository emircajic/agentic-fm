<fmxmlsnippet type="FMObjectList">

	<Step enable="True" id="89" name="# (comment)">
		<Text>PURPOSE: Generate StavkeKalkulacijeMP lines for a KalkulacijaMP by pulling all StavkePrimke attached to the same UFD.
One StavkaKalkulacijeMP is created per StavkaPrimke — nabavna from NabavnaCijenaStavke, prodajna from ProdajnaCijena.</Text>
	</Step>
	<Step enable="False" id="61" name="Insert Text">
		<SelectAll state="False"/>
		<Text>PARAMS: kalkulacijaID (text, required)
RETURNS: data.generatedCount (number)</Text>
		<Field>$README</Field>
	</Step>

	<Step enable="True" id="85" name="Allow User Abort">
		<Set state="False"/>
	</Step>
	<Step enable="True" id="86" name="Set Error Capture">
		<Set state="True"/>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Params.parse ( Get ( ScriptParameter ) ; "kalkulacijaID" )]]></Calculation></Value>
	</Step>
	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Response_Init ( "{}" )]]></Calculation></Value>
	</Step>
	<Step enable="True" id="141" name="Set Variable">
		<Name>$generatedCount</Name>
		<Value><Calculation><![CDATA[0]]></Calculation></Value>
	</Step>
	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Log.add ( "info" ; "KMP_GEN_START" ; "Generating stavke for kalkulacija " & $kalkulacijaID ; $params )]]></Calculation></Value>
	</Step>

	<Step enable="False" id="89" name="# (comment)">
		<Text>MARK: Validate</Text>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[IsEmpty ( $kalkulacijaID )]]></Calculation>
	</Step>
		<Step enable="True" id="141" name="Set Variable">
			<Name>$void</Name>
			<Value><Calculation><![CDATA[Response_AddError ( "MISSING_PARAM" ; "kalkulacijaID is required" ; "kalkulacijaID" ; "{}" ; "" )]]></Calculation></Value>
		</Step>
		<Step enable="True" id="68" name="If">
			<Calculation><![CDATA[$isRoot]]></Calculation>
		</Step>
			<Step enable="True" id="1" name="Perform Script">
				<Script id="0" name="UTIL__FlushLog"/>
				<Calculation><![CDATA[JSONSetElement ( "{}" ; "traceID" ; $traceID ; JSONString )]]></Calculation>
			</Step>
		<Step enable="True" id="70" name="End If"/>
		<Step enable="True" id="103" name="Exit Script">
			<Calculation><![CDATA[Response_Finalize]]></Calculation>
		</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="False" id="89" name="# (comment)">
		<Text>MARK: Load and validate KalkulacijaMP</Text>
	</Step>

	<Step enable="True" id="6" name="Go to Layout">
		<LayoutDestination value="SelectedLayout"/>
		<Layout id="241" name="KMP__KalkulacijaMP"/>
		<Animation value="None"/>
	</Step>
	<Step enable="True" id="22" name="Enter Find Mode">
		<UseCurrentRecord state="False"/>
		<PauseForUser state="False"/>
	</Step>
	<Step enable="True" id="76" name="Set Field">
		<Field table="KMP__KalkulacijaMP" id="1" name="PrimaryKey"/>
		<Calculation><![CDATA[$kalkulacijaID]]></Calculation>
	</Step>
	<Step enable="True" id="28" name="Perform Find"/>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[Get ( FoundCount ) = 0]]></Calculation>
	</Step>
		<Step enable="True" id="141" name="Set Variable">
			<Name>$void</Name>
			<Value><Calculation><![CDATA[Response_AddError ( "NOT_FOUND" ; "KalkulacijaMP not found: " & $kalkulacijaID ; "" ; "{}" ; "" )]]></Calculation></Value>
		</Step>
		<Step enable="True" id="68" name="If">
			<Calculation><![CDATA[$isRoot]]></Calculation>
		</Step>
			<Step enable="True" id="1" name="Perform Script">
				<Script id="0" name="UTIL__FlushLog"/>
				<Calculation><![CDATA[JSONSetElement ( "{}" ; "traceID" ; $traceID ; JSONString )]]></Calculation>
			</Step>
		<Step enable="True" id="70" name="End If"/>
		<Step enable="True" id="103" name="Exit Script">
			<Calculation><![CDATA[Response_Finalize]]></Calculation>
		</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[KMP__KalkulacijaMP::Status ≠ "Otvorena"]]></Calculation>
	</Step>
		<Step enable="True" id="141" name="Set Variable">
			<Name>$void</Name>
			<Value><Calculation><![CDATA[Response_AddError ( "INVALID_STATUS" ; "KalkulacijaMP is not Otvorena: " & KMP__KalkulacijaMP::Status ; "" ; "{}" ; "" )]]></Calculation></Value>
		</Step>
		<Step enable="True" id="68" name="If">
			<Calculation><![CDATA[$isRoot]]></Calculation>
		</Step>
			<Step enable="True" id="1" name="Perform Script">
				<Script id="0" name="UTIL__FlushLog"/>
				<Calculation><![CDATA[JSONSetElement ( "{}" ; "traceID" ; $traceID ; JSONString )]]></Calculation>
			</Step>
		<Step enable="True" id="70" name="End If"/>
		<Step enable="True" id="103" name="Exit Script">
			<Calculation><![CDATA[Response_Finalize]]></Calculation>
		</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[not IsEmpty ( KMP__Stavke::PrimaryKey )]]></Calculation>
	</Step>
		<Step enable="True" id="141" name="Set Variable">
			<Name>$void</Name>
			<Value><Calculation><![CDATA[Response_AddError ( "ALREADY_GENERATED" ; "Stavke already exist for kalkulacijaID: " & $kalkulacijaID ; "" ; "{}" ; "" )]]></Calculation></Value>
		</Step>
		<Step enable="True" id="68" name="If">
			<Calculation><![CDATA[$isRoot]]></Calculation>
		</Step>
			<Step enable="True" id="1" name="Perform Script">
				<Script id="0" name="UTIL__FlushLog"/>
				<Calculation><![CDATA[JSONSetElement ( "{}" ; "traceID" ; $traceID ; JSONString )]]></Calculation>
			</Step>
		<Step enable="True" id="70" name="End If"/>
		<Step enable="True" id="103" name="Exit Script">
			<Calculation><![CDATA[Response_Finalize]]></Calculation>
		</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$ulaznaFakturaID</Name>
		<Value><Calculation><![CDATA[KMP__KalkulacijaMP::ForeignKeyUlaznaFakturaID]]></Calculation></Value>
	</Step>

	<Step enable="False" id="89" name="# (comment)">
		<Text>MARK: Collect StavkePrimke for this UFD</Text>
	</Step>

	<Step enable="True" id="6" name="Go to Layout">
		<LayoutDestination value="SelectedLayout"/>
		<Layout id="227" name="Dev StavkePrimke"/>
		<Animation value="None"/>
	</Step>
	<Step enable="True" id="22" name="Enter Find Mode">
		<UseCurrentRecord state="False"/>
		<PauseForUser state="False"/>
	</Step>
	<Step enable="True" id="76" name="Set Field">
		<Field table="StavkePrimke" id="32" name="ForeignKeyUlaznaFakturaID"/>
		<Calculation><![CDATA[$ulaznaFakturaID]]></Calculation>
	</Step>
	<Step enable="True" id="28" name="Perform Find"/>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[Get ( FoundCount ) = 0]]></Calculation>
	</Step>
		<Step enable="True" id="141" name="Set Variable">
			<Name>$void</Name>
			<Value><Calculation><![CDATA[Response_AddError ( "NO_STAVKE" ; "No StavkePrimke attached to UFD: " & $ulaznaFakturaID ; "" ; "{}" ; "" )]]></Calculation></Value>
		</Step>
		<Step enable="True" id="68" name="If">
			<Calculation><![CDATA[$isRoot]]></Calculation>
		</Step>
			<Step enable="True" id="1" name="Perform Script">
				<Script id="0" name="UTIL__FlushLog"/>
				<Calculation><![CDATA[JSONSetElement ( "{}" ; "traceID" ; $traceID ; JSONString )]]></Calculation>
			</Step>
		<Step enable="True" id="70" name="End If"/>
		<Step enable="True" id="103" name="Exit Script">
			<Calculation><![CDATA[Response_Finalize]]></Calculation>
		</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$sourceCount</Name>
		<Value><Calculation><![CDATA[Get ( FoundCount )]]></Calculation></Value>
	</Step>
	<Step enable="True" id="141" name="Set Variable">
		<Name>$sourceRows</Name>
		<Value><Calculation><![CDATA["[]"]]></Calculation></Value>
	</Step>
	<Step enable="True" id="141" name="Set Variable">
		<Name>$i</Name>
		<Value><Calculation><![CDATA[0]]></Calculation></Value>
	</Step>
	<Step enable="True" id="16" name="Go to Record/Request/Page">
		<RowPageLocation value="First"/>
	</Step>

	<Step enable="True" id="71" name="Loop">
		<FlushType value="Always"/>
	</Step>

		<Step enable="True" id="141" name="Set Variable">
			<Name>$sourceRows</Name>
			<Value><Calculation><![CDATA[JSONSetElement ( $sourceRows ;
	[ "[+].stavkaPrimkeID" ; StavkePrimke::PrimaryKey           ; JSONString ] ;
	[ "[:].artikalID"      ; StavkePrimke::ForeignKeyArtikalID  ; JSONString ] ;
	[ "[:].kolicina"       ; StavkePrimke::Kolicina              ; JSONNumber ] ;
	[ "[:].nabavna"        ; If ( not IsEmpty ( StavkePrimke::NabavnaCijenaStavke ) ; StavkePrimke::NabavnaCijenaStavke ; StavkePrimke::ProdajnaCijena ) ; JSONNumber ] ;
	[ "[:].prodajna"       ; If ( not IsEmpty ( StavkePrimke::ProdajnaCijena )      ; StavkePrimke::ProdajnaCijena      ; StavkePrimke::NabavnaCijenaStavke ) ; JSONNumber ]
)]]></Calculation></Value>
		</Step>

		<Step enable="True" id="141" name="Set Variable">
			<Name>$i</Name>
			<Value><Calculation><![CDATA[$i + 1]]></Calculation></Value>
		</Step>
		<Step enable="True" id="72" name="Exit Loop If">
			<Calculation><![CDATA[$i >= $sourceCount]]></Calculation>
		</Step>
		<Step enable="True" id="16" name="Go to Record/Request/Page">
			<Exit state="False"/>
			<RowPageLocation value="Next"/>
		</Step>

	<Step enable="True" id="73" name="End Loop"/>

	<Step enable="False" id="89" name="# (comment)">
		<Text>MARK: Create StavkeKalkulacijeMP</Text>
	</Step>

	<Step enable="True" id="6" name="Go to Layout">
		<LayoutDestination value="SelectedLayout"/>
		<Layout id="242" name="KMP__Stavke"/>
		<Animation value="None"/>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$i</Name>
		<Value><Calculation><![CDATA[0]]></Calculation></Value>
	</Step>

	<Step enable="True" id="71" name="Loop">
		<FlushType value="Always"/>
	</Step>

		<Step enable="True" id="72" name="Exit Loop If">
			<Calculation><![CDATA[$i >= $sourceCount]]></Calculation>
		</Step>

		<Step enable="True" id="141" name="Set Variable">
			<Name>$stavkaPrimkeID</Name>
			<Value><Calculation><![CDATA[JSONGetElement ( $sourceRows ; "[" & $i & "].stavkaPrimkeID" )]]></Calculation></Value>
		</Step>
		<Step enable="True" id="141" name="Set Variable">
			<Name>$artikalID</Name>
			<Value><Calculation><![CDATA[JSONGetElement ( $sourceRows ; "[" & $i & "].artikalID" )]]></Calculation></Value>
		</Step>
		<Step enable="True" id="141" name="Set Variable">
			<Name>$kolicina</Name>
			<Value><Calculation><![CDATA[JSONGetElement ( $sourceRows ; "[" & $i & "].kolicina" )]]></Calculation></Value>
		</Step>
		<Step enable="True" id="141" name="Set Variable">
			<Name>$nabavna</Name>
			<Value><Calculation><![CDATA[JSONGetElement ( $sourceRows ; "[" & $i & "].nabavna" )]]></Calculation></Value>
		</Step>
		<Step enable="True" id="141" name="Set Variable">
			<Name>$prodajna</Name>
			<Value><Calculation><![CDATA[JSONGetElement ( $sourceRows ; "[" & $i & "].prodajna" )]]></Calculation></Value>
		</Step>

		<Step enable="True" id="24" name="New Record/Request"/>
		<Step enable="True" id="76" name="Set Field">
			<Field table="KMP__Stavke" id="6" name="ForeignKeyKalkulacijaID"/>
			<Calculation><![CDATA[$kalkulacijaID]]></Calculation>
		</Step>
		<Step enable="True" id="76" name="Set Field">
			<Field table="KMP__Stavke" id="7" name="ForeignKeyArtikalID"/>
			<Calculation><![CDATA[$artikalID]]></Calculation>
		</Step>
		<Step enable="True" id="76" name="Set Field">
			<Field table="KMP__Stavke" id="8" name="ForeignKeyStavkaPrimkeID"/>
			<Calculation><![CDATA[$stavkaPrimkeID]]></Calculation>
		</Step>
		<Step enable="True" id="76" name="Set Field">
			<Field table="KMP__Stavke" id="9" name="Kolicina"/>
			<Calculation><![CDATA[$kolicina]]></Calculation>
		</Step>
		<Step enable="True" id="76" name="Set Field">
			<Field table="KMP__Stavke" id="10" name="NabavnaCijena"/>
			<Calculation><![CDATA[$nabavna]]></Calculation>
		</Step>
		<Step enable="True" id="76" name="Set Field">
			<Field table="KMP__Stavke" id="11" name="MPCijena"/>
			<Calculation><![CDATA[$prodajna]]></Calculation>
		</Step>
		<Step enable="True" id="76" name="Set Field">
			<Field table="KMP__Stavke" id="12" name="IznosMP"/>
			<Calculation><![CDATA[$kolicina * $prodajna]]></Calculation>
		</Step>
		<Step enable="True" id="75" name="Commit Records/Requests">
			<NoInteract state="True"/>
			<Option state="False"/>
			<ESSForceCommit state="False"/>
		</Step>
		<Step enable="True" id="68" name="If">
			<Calculation><![CDATA[Get ( LastError ) = 0]]></Calculation>
		</Step>
			<Step enable="True" id="141" name="Set Variable">
				<Name>$generatedCount</Name>
				<Value><Calculation><![CDATA[$generatedCount + 1]]></Calculation></Value>
			</Step>
		<Step enable="True" id="69" name="Else"/>
			<Step enable="True" id="141" name="Set Variable">
				<Name>$void</Name>
				<Value><Calculation><![CDATA[Response_AddWarning ( "COMMIT_FAILED" ; "Failed to create stavka for stavkaPrimkeID " & $stavkaPrimkeID & " (FM error " & Get ( LastError ) & ")" ; "" ; JSONSetElement ( "{}" ; "stavkaPrimkeID" ; $stavkaPrimkeID ; JSONString ) ; "" )]]></Calculation></Value>
			</Step>
		<Step enable="True" id="70" name="End If"/>

		<Step enable="True" id="141" name="Set Variable">
			<Name>$i</Name>
			<Value><Calculation><![CDATA[$i + 1]]></Calculation></Value>
		</Step>

	<Step enable="True" id="73" name="End Loop"/>

	<Step enable="False" id="89" name="# (comment)">
		<Text>MARK: Result</Text>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[$generatedCount = 0]]></Calculation>
	</Step>
		<Step enable="True" id="141" name="Set Variable">
			<Name>$void</Name>
			<Value><Calculation><![CDATA[Response_AddError ( "NONE_GENERATED" ; "No StavkeKalkulacijeMP were created" ; "" ; $params ; "" )]]></Calculation></Value>
		</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Response_SetData ( JSONSetElement ( "{}" ; "generatedCount" ; $generatedCount ; JSONNumber ) )]]></Calculation></Value>
	</Step>
	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Log.add ( "info" ; "KMP_GEN_DONE" ; "Generated " & $generatedCount & " of " & $sourceCount & " stavke for kalkulacija " & $kalkulacijaID ; $params )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[$isRoot]]></Calculation>
	</Step>
		<Step enable="True" id="1" name="Perform Script">
			<Script id="0" name="UTIL__FlushLog"/>
			<Calculation><![CDATA[JSONSetElement ( "{}" ; "traceID" ; $traceID ; JSONString )]]></Calculation>
		</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="103" name="Exit Script">
		<Calculation><![CDATA[Response_Finalize]]></Calculation>
	</Step>

</fmxmlsnippet>

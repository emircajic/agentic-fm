<fmxmlsnippet type="FMObjectList">

	<Step enable="True" id="89" name="# (comment)">
		<Text>PURPOSE: Root orchestrator — validate prices, create KMP, generate stavke, post KMP, lock Primke, mark UFD as Knjižena.</Text>
	</Step>

	<Step enable="False" id="61" name="Insert Text">
		<SelectAll state="False"/>
		<Text>PARAMS: ulaznaFakturaID (text, required)
RETURNS: data.kalkulacijaID (text) | data.lockedCount (number)</Text>
		<Field table="" id="0" name="$README"/>
	</Step>

	<Step enable="True" id="85" name="Allow User Abort">
		<Set state="False"/>
	</Step>

	<Step enable="True" id="86" name="Set Error Capture">
		<Set state="True"/>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Params.parse ( Get ( ScriptParameter ) ; "ulaznaFakturaID" )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Response_Init ( "{}" )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$kalkulacijaID</Name>
		<Value><Calculation><![CDATA[""]]></Calculation></Value>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Log.add ( "info" ; "UFD_PROCESS_START" ; "Processing UFD " & $ulaznaFakturaID ; $params )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="89" name="# (comment)">
		<Text>── Validate ──────────────────────────────────────────────────────────────</Text>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[IsEmpty ( $ulaznaFakturaID )]]></Calculation>
	</Step>
	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Response_AddError ( "MISSING_PARAM" ; "ulaznaFakturaID is required" ; "ulaznaFakturaID" ; "{}" ; "" )]]></Calculation></Value>
	</Step>
	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[$isRoot]]></Calculation>
	</Step>
	<Step enable="True" id="25" name="Perform Script">
		<Script id="780" name="UTIL__FlushLog"/>
		<Calculation><![CDATA[JSONSetElement ( "{}" ; "traceID" ; $traceID ; JSONString )]]></Calculation>
	</Step>
	<Step enable="True" id="70" name="End If"/>
	<Step enable="True" id="103" name="Exit Script">
		<Calculation><![CDATA[Response_Finalize]]></Calculation>
	</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="89" name="# (comment)">
		<Text>── Step 1: Validate prices ───────────────────────────────────────────────</Text>
	</Step>

	<Step enable="True" id="25" name="Perform Script">
		<Script id="0" name="UFD__ValidatePrices"/>
		<Calculation><![CDATA[JSONSetElement ( "{}" ;
	[ "ulaznaFakturaID" ; $ulaznaFakturaID ; JSONString ] ;
	[ "traceID"         ; $traceID         ; JSONString ]
)]]></Calculation>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$r</Name>
		<Value><Calculation><![CDATA[Get ( ScriptResult )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[Response_HasErrors ( $r )]]></Calculation>
	</Step>
	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Response_Absorb ( $r )]]></Calculation></Value>
	</Step>
	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Log.add ( "error" ; "UFD_VALIDATE_FAIL" ; "Price validation failed" ; $params )]]></Calculation></Value>
	</Step>
	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[$isRoot]]></Calculation>
	</Step>
	<Step enable="True" id="25" name="Perform Script">
		<Script id="780" name="UTIL__FlushLog"/>
		<Calculation><![CDATA[JSONSetElement ( "{}" ; "traceID" ; $traceID ; JSONString )]]></Calculation>
	</Step>
	<Step enable="True" id="70" name="End If"/>
	<Step enable="True" id="103" name="Exit Script">
		<Calculation><![CDATA[Response_Finalize]]></Calculation>
	</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="89" name="# (comment)">
		<Text>── Step 2: Create KalkulacijaMP ──────────────────────────────────────────</Text>
	</Step>

	<Step enable="True" id="25" name="Perform Script">
		<Script id="679" name="KMP__CreateFromUlaznaFaktura"/>
		<Calculation><![CDATA[JSONSetElement ( "{}" ; "ulaznaFakturaID" ; $ulaznaFakturaID ; JSONString )]]></Calculation>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$r</Name>
		<Value><Calculation><![CDATA[Get ( ScriptResult )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$kalkulacijaID</Name>
		<Value><Calculation><![CDATA[JSONGetElement ( $r ; "kalkulacijaID" )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[JSONGetElement ( $r ; "status" ) = "fail" or IsEmpty ( $kalkulacijaID )]]></Calculation>
	</Step>
	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Response_AddError ( "KMP_CREATE_FAILED" ; "KMP__CreateFromUlaznaFaktura failed: " & JSONGetElement ( $r ; "errors[0]" ) ; "" ; JSONSetElement ( "{}" ; "kmpResult" ; $r ; JSONObject ) ; "" )]]></Calculation></Value>
	</Step>
	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Log.add ( "error" ; "KMP_CREATE_FAILED" ; "KMP create failed for UFD " & $ulaznaFakturaID ; $params )]]></Calculation></Value>
	</Step>
	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[$isRoot]]></Calculation>
	</Step>
	<Step enable="True" id="25" name="Perform Script">
		<Script id="780" name="UTIL__FlushLog"/>
		<Calculation><![CDATA[JSONSetElement ( "{}" ; "traceID" ; $traceID ; JSONString )]]></Calculation>
	</Step>
	<Step enable="True" id="70" name="End If"/>
	<Step enable="True" id="103" name="Exit Script">
		<Calculation><![CDATA[Response_Finalize]]></Calculation>
	</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="89" name="# (comment)">
		<Text>── Step 3: Generate KMP stavke ───────────────────────────────────────────</Text>
	</Step>

	<Step enable="True" id="25" name="Perform Script">
		<Script id="683" name="KMP__GenerateStavke"/>
		<Calculation><![CDATA[JSONSetElement ( "{}" ; "kalkulacijaID" ; $kalkulacijaID ; JSONString )]]></Calculation>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$r</Name>
		<Value><Calculation><![CDATA[Get ( ScriptResult )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[JSONGetElement ( $r ; "status" ) = "fail"]]></Calculation>
	</Step>
	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Response_AddError ( "KMP_GENERATE_FAILED" ; "KMP__GenerateStavke failed: " & JSONGetElement ( $r ; "errors[0]" ) ; "" ; JSONSetElement ( "{}" ; "kalkulacijaID" ; $kalkulacijaID ; JSONString ) ; "" )]]></Calculation></Value>
	</Step>
	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Log.add ( "error" ; "KMP_GENERATE_FAILED" ; "KMP generate failed for kalkulacijaID " & $kalkulacijaID ; $params )]]></Calculation></Value>
	</Step>
	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[$isRoot]]></Calculation>
	</Step>
	<Step enable="True" id="25" name="Perform Script">
		<Script id="780" name="UTIL__FlushLog"/>
		<Calculation><![CDATA[JSONSetElement ( "{}" ; "traceID" ; $traceID ; JSONString )]]></Calculation>
	</Step>
	<Step enable="True" id="70" name="End If"/>
	<Step enable="True" id="103" name="Exit Script">
		<Calculation><![CDATA[Response_Finalize]]></Calculation>
	</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="89" name="# (comment)">
		<Text>── Step 4: Post KMP ──────────────────────────────────────────────────────</Text>
	</Step>

	<Step enable="True" id="25" name="Perform Script">
		<Script id="684" name="KMP__Post"/>
		<Calculation><![CDATA[JSONSetElement ( "{}" ; "kalkulacijaID" ; $kalkulacijaID ; JSONString )]]></Calculation>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$r</Name>
		<Value><Calculation><![CDATA[Get ( ScriptResult )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[JSONGetElement ( $r ; "status" ) = "fail"]]></Calculation>
	</Step>
	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Response_AddError ( "KMP_POST_FAILED" ; "KMP__Post failed: " & JSONGetElement ( $r ; "errors[0]" ) ; "" ; JSONSetElement ( "{}" ; "kalkulacijaID" ; $kalkulacijaID ; JSONString ) ; "" )]]></Calculation></Value>
	</Step>
	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Log.add ( "error" ; "KMP_POST_FAILED" ; "KMP post failed for kalkulacijaID " & $kalkulacijaID ; $params )]]></Calculation></Value>
	</Step>
	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[$isRoot]]></Calculation>
	</Step>
	<Step enable="True" id="25" name="Perform Script">
		<Script id="780" name="UTIL__FlushLog"/>
		<Calculation><![CDATA[JSONSetElement ( "{}" ; "traceID" ; $traceID ; JSONString )]]></Calculation>
	</Step>
	<Step enable="True" id="70" name="End If"/>
	<Step enable="True" id="103" name="Exit Script">
		<Calculation><![CDATA[Response_Finalize]]></Calculation>
	</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="89" name="# (comment)">
		<Text>── Step 5: Lock Primke ───────────────────────────────────────────────────</Text>
	</Step>

	<Step enable="True" id="25" name="Perform Script">
		<Script id="0" name="UFD__LockPrimke"/>
		<Calculation><![CDATA[JSONSetElement ( "{}" ;
	[ "ulaznaFakturaID" ; $ulaznaFakturaID ; JSONString ] ;
	[ "traceID"         ; $traceID         ; JSONString ]
)]]></Calculation>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$r</Name>
		<Value><Calculation><![CDATA[Get ( ScriptResult )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$lockedCount</Name>
		<Value><Calculation><![CDATA[JSONGetElement ( $r ; "data.lockedCount" )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[Response_HasErrors ( $r )]]></Calculation>
	</Step>
	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Response_Absorb ( $r )]]></Calculation></Value>
	</Step>
	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Log.add ( "error" ; "UFD_LOCK_FAIL" ; "LockPrimke failed after KMP post — KMP is posted but Primke not locked" ; $params )]]></Calculation></Value>
	</Step>
	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[$isRoot]]></Calculation>
	</Step>
	<Step enable="True" id="25" name="Perform Script">
		<Script id="780" name="UTIL__FlushLog"/>
		<Calculation><![CDATA[JSONSetElement ( "{}" ; "traceID" ; $traceID ; JSONString )]]></Calculation>
	</Step>
	<Step enable="True" id="70" name="End If"/>
	<Step enable="True" id="103" name="Exit Script">
		<Calculation><![CDATA[Response_Finalize]]></Calculation>
	</Step>
	<Step enable="True" id="69" name="Else">
	</Step>
	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Response_Absorb ( $r )]]></Calculation></Value>
	</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="89" name="# (comment)">
		<Text>── Step 6: Mark UFD as Knjižena ──────────────────────────────────────────</Text>
	</Step>

	<Step enable="True" id="6" name="Go to Layout">
		<LayoutDestination value="SelectedLayout"/>
		<Layout id="240" name="UFD__UlaznaFakturaDobavljaca"/>
		<Animation value="None"/>
	</Step>

	<Step enable="True" id="22" name="Enter Find Mode">
		<Pause state="False"/>
	</Step>

	<Step enable="True" id="76" name="Set Field">
		<Calculation><![CDATA[$ulaznaFakturaID]]></Calculation>
		<Field table="UFD__UlaznaFakturaDobavljaca" id="1" name="PrimaryKey"/>
	</Step>

	<Step enable="True" id="31" name="Perform Find">
		<Restore state="False"/>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[Get ( FoundCount ) > 0]]></Calculation>
	</Step>

	<Step enable="True" id="76" name="Set Field">
		<Calculation><![CDATA["Knjižena"]]></Calculation>
		<Field table="UFD__UlaznaFakturaDobavljaca" id="11" name="Status"/>
	</Step>

	<Step enable="True" id="75" name="Commit Records/Requests">
		<NoInteract state="True"/>
		<Option state="False"/>
		<ESSForceCommit state="False"/>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[Get ( LastError ) ≠ 0]]></Calculation>
	</Step>
	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Response_AddWarning ( "UFD_STATUS_COMMIT_FAILED" ; "KMP posted and Primke locked but UFD Status could not be updated (FM error " & Get ( LastError ) & ")" ; "" ; "{}" ; "" )]]></Calculation></Value>
	</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="89" name="# (comment)">
		<Text>── Success ───────────────────────────────────────────────────────────────</Text>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Response_SetData ( JSONSetElement ( "{}" ;
	[ "kalkulacijaID" ; $kalkulacijaID ; JSONString ] ;
	[ "lockedCount"   ; $lockedCount   ; JSONNumber ]
) )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Log.add ( "info" ; "UFD_PROCESS_DONE" ; "UFD processed — kalkulacijaID: " & $kalkulacijaID & " lockedCount: " & $lockedCount ; $params )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[$isRoot]]></Calculation>
	</Step>
	<Step enable="True" id="25" name="Perform Script">
		<Script id="780" name="UTIL__FlushLog"/>
		<Calculation><![CDATA[JSONSetElement ( "{}" ; "traceID" ; $traceID ; JSONString )]]></Calculation>
	</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="103" name="Exit Script">
		<Calculation><![CDATA[Response_Finalize]]></Calculation>
	</Step>

</fmxmlsnippet>

<fmxmlsnippet type="FMObjectList">

	<Step enable="True" id="89" name="# (comment)">
		<Text>PURPOSE: Create a new UlaznaFakturaDobavljaca header record for a supplier.</Text>
	</Step>

	<Step enable="False" id="61" name="Insert Text">
		<SelectAll state="False"/>
		<Text>PARAMS: dobavljacID (text, required) | datumFakture (date, optional) | napomena (text, optional) | brojUlazneFakture (text, optional) | companyID (text, optional)
RETURNS: data.ulaznaFakturaID (text)</Text>
		<Field table="" id="0" name="$README"/>
	</Step>

	<Step enable="True" id="85" name="Allow User Abort">
		<Set state="False"/>
	</Step>

	<Step enable="True" id="86" name="Set Error Capture">
		<Set state="True"/>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Params.parse ( Get ( ScriptParameter ) ; "dobavljacID|datumFakture|napomena|brojUlazneFakture|companyID" )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Response_Init ( "{}" )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Log.add ( "info" ; "UFD_CREATE_START" ; "Creating UFD for dobavljacID: " & $dobavljacID ; $params )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="89" name="# (comment)">
		<Text>── Validate ──────────────────────────────────────────────────────────────</Text>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[IsEmpty ( $dobavljacID )]]></Calculation>
	</Step>
		<Step enable="True" id="141" name="Set Variable">
			<Name>$void</Name>
			<Value><Calculation><![CDATA[Response_AddError ( "MISSING_PARAM" ; "dobavljacID is required" ; "dobavljacID" ; "{}" ; "" )]]></Calculation></Value>
		</Step>
		<Step enable="True" id="141" name="Set Variable">
			<Name>$void</Name>
			<Value><Calculation><![CDATA[Log.add ( "error" ; "MISSING_PARAM" ; "dobavljacID is required" ; "{}" )]]></Calculation></Value>
		</Step>
		<Step enable="True" id="68" name="If">
			<Calculation><![CDATA[$isRoot]]></Calculation>
		</Step>
			<Step enable="True" id="25" name="Perform Script">
				<Script id="780" name="UTIL__FlushLog"/>
				<Calculation><![CDATA[JSONSetElement ( "{}" ; "traceID" ; $traceID ; JSONString )]]></Calculation>
			</Step>
		<Step enable="True" id="70" name="End If"/>
		<Step enable="True" id="103" name="Exit Script">
			<Calculation><![CDATA[Response_Finalize]]></Calculation>
		</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="89" name="# (comment)">
		<Text>── Create UFD record ─────────────────────────────────────────────────────</Text>
	</Step>

	<Step enable="True" id="6" name="Go to Layout">
		<LayoutDestination value="SelectedLayout"/>
		<Layout id="240" name="UFD__UlaznaFakturaDobavljaca"/>
		<Animation value="None"/>
	</Step>

	<Step enable="True" id="7" name="New Record/Request"/>

	<Step enable="True" id="147" name="Set Field By Name">
		<TargetName><Calculation><![CDATA["UFD__UlaznaFakturaDobavljaca::ForeignKeyDobavljacID"]]></Calculation></TargetName>
		<Result><Calculation><![CDATA[$dobavljacID]]></Calculation></Result>
	</Step>

	<Step enable="True" id="76" name="Set Field">
		<Calculation><![CDATA["Otvorena"]]></Calculation>
		<Field table="UFD__UlaznaFakturaDobavljaca" id="11" name="Status"/>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[not IsEmpty ( $datumFakture )]]></Calculation>
	</Step>
		<Step enable="True" id="76" name="Set Field">
			<Calculation><![CDATA[GetAsDate ( $datumFakture )]]></Calculation>
			<Field table="UFD__UlaznaFakturaDobavljaca" id="7" name="DatumFakture"/>
		</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[not IsEmpty ( $napomena )]]></Calculation>
	</Step>
		<Step enable="True" id="76" name="Set Field">
			<Calculation><![CDATA[$napomena]]></Calculation>
			<Field table="UFD__UlaznaFakturaDobavljaca" id="12" name="Napomena"/>
		</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[not IsEmpty ( $brojUlazneFakture )]]></Calculation>
	</Step>
		<Step enable="True" id="76" name="Set Field">
			<Calculation><![CDATA[$brojUlazneFakture]]></Calculation>
			<Field table="UFD__UlaznaFakturaDobavljaca" id="6" name="BrojUlazneFakture"/>
		</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[not IsEmpty ( $companyID )]]></Calculation>
	</Step>
		<Step enable="True" id="76" name="Set Field">
			<Calculation><![CDATA[$companyID]]></Calculation>
			<Field table="UFD__UlaznaFakturaDobavljaca" id="13" name="ForeignKeyCompanyID"/>
		</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="75" name="Commit Records/Requests">
		<NoInteract state="True"/>
		<Option state="False"/>
		<ESSForceCommit state="False"/>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$fmError</Name>
		<Value><Calculation><![CDATA[Get ( LastError )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[$fmError ≠ 0]]></Calculation>
	</Step>
		<Step enable="True" id="141" name="Set Variable">
			<Name>$void</Name>
			<Value><Calculation><![CDATA[Response_AddError ( "COMMIT_FAILED" ; "Failed to create UFD record (FM error " & $fmError & ")" ; "" ; JSONSetElement ( "{}" ; "dobavljacID" ; $dobavljacID ; JSONString ) ; "" )]]></Calculation></Value>
		</Step>
		<Step enable="True" id="141" name="Set Variable">
			<Name>$void</Name>
			<Value><Calculation><![CDATA[Log.add ( "error" ; "COMMIT_FAILED" ; "UFD commit failed: " & $fmError ; $params )]]></Calculation></Value>
		</Step>
		<Step enable="True" id="68" name="If">
			<Calculation><![CDATA[$isRoot]]></Calculation>
		</Step>
			<Step enable="True" id="25" name="Perform Script">
				<Script id="780" name="UTIL__FlushLog"/>
				<Calculation><![CDATA[JSONSetElement ( "{}" ; "traceID" ; $traceID ; JSONString )]]></Calculation>
			</Step>
		<Step enable="True" id="70" name="End If"/>
		<Step enable="True" id="103" name="Exit Script">
			<Calculation><![CDATA[Response_Finalize]]></Calculation>
		</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="89" name="# (comment)">
		<Text>── Verify ForeignKeyDobavljacID persisted (self-heal if cleared by trigger/auto-enter) ──</Text>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[IsEmpty ( UFD__UlaznaFakturaDobavljaca::ForeignKeyDobavljacID )]]></Calculation>
	</Step>
		<Step enable="True" id="141" name="Set Variable">
			<Name>$void</Name>
			<Value><Calculation><![CDATA[Log.add ( "warn" ; "UFD_FK_HEAL" ; "ForeignKeyDobavljacID was empty after commit — re-applying: " & $dobavljacID ; $params )]]></Calculation></Value>
		</Step>
		<Step enable="True" id="147" name="Set Field By Name">
			<TargetName><Calculation><![CDATA["UFD__UlaznaFakturaDobavljaca::ForeignKeyDobavljacID"]]></Calculation></TargetName>
			<Result><Calculation><![CDATA[$dobavljacID]]></Calculation></Result>
		</Step>
		<Step enable="True" id="75" name="Commit Records/Requests">
			<NoInteract state="True"/>
			<Option state="False"/>
			<ESSForceCommit state="False"/>
		</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="89" name="# (comment)">
		<Text>── Success ───────────────────────────────────────────────────────────────</Text>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$ulaznaFakturaID</Name>
		<Value><Calculation><![CDATA[UFD__UlaznaFakturaDobavljaca::PrimaryKey]]></Calculation></Value>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Response_SetData ( JSONSetElement ( "{}" ; "ulaznaFakturaID" ; $ulaznaFakturaID ; JSONString ) )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Log.add ( "info" ; "UFD_CREATE_OK" ; "UFD created: " & $ulaznaFakturaID ; $params )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[$isRoot]]></Calculation>
	</Step>
		<Step enable="True" id="25" name="Perform Script">
			<Script id="780" name="UTIL__FlushLog"/>
			<Calculation><![CDATA[JSONSetElement ( "{}" ; "traceID" ; $traceID ; JSONString )]]></Calculation>
		</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="103" name="Exit Script">
		<Calculation><![CDATA[Response_Finalize]]></Calculation>
	</Step>

</fmxmlsnippet>

<fmxmlsnippet type="FMObjectList">

  <Step enable="True" id="89" name="# (comment)">
    <Text>PURPOSE: One-time migration — converts old-style refund markers to proper Reklamacija records.
Finds all Invoices where BrojReklamiranogRačuna is populated, creates a Reklamacija invoice + lines for each,
then clears BrojReklamiranogRačuna on the original.

Field mapping on new Reklamacija:
  BrojFiskalnogRačuna    ← original's BrojReklamiranogRačuna (the refund receipt number issued at the time)
  BrojReklamiranogRačuna ← original's BrojFiskalnogRačuna (the original receipt number)
  Datum                  ← original's Datum (actual refund date unknown, correct manually if needed)</Text>
  </Step>

  <Step enable="True" id="89" name="# (comment)"/>

  <Step enable="True" id="86" name="Set Error Capture">
    <Set state="True"/>
  </Step>

  <Step enable="True" id="85" name="Allow User Abort">
    <Set state="False"/>
  </Step>

  <Step enable="True" id="141" name="Set Variable">
    <Name>$returnLayout</Name>
    <Value><Calculation><![CDATA[Get ( LayoutName )]]></Calculation></Value>
  </Step>

  <Step enable="True" id="141" name="Set Variable">
    <Name>$processed</Name>
    <Value><Calculation><![CDATA[0]]></Calculation></Value>
  </Step>

  <Step enable="True" id="141" name="Set Variable">
    <Name>$skipped</Name>
    <Value><Calculation><![CDATA[0]]></Calculation></Value>
  </Step>

  <Step enable="True" id="141" name="Set Variable">
    <Name>$failed</Name>
    <Value><Calculation><![CDATA[0]]></Calculation></Value>
  </Step>

  <Step enable="True" id="89" name="# (comment)"/>

  <Step enable="False" id="89" name="# (comment)">
    <Text>MARK: Collect IDs</Text>
  </Step>

  <Step enable="True" id="141" name="Set Variable">
    <Name>$ids</Name>
    <Value><Calculation><![CDATA[ExecuteSQL (
	"SELECT PrimaryKey, BrojFiskalnogRacuna, BrojReklamiranogRacuna
	 FROM Invoices
	 WHERE BrojReklamiranogRacuna > 0" ;
	"|" ; "¶"
)]]></Calculation></Value>
  </Step>

  <Step enable="True" id="68" name="If">
    <Calculation><![CDATA[IsEmpty ( $ids ) or $ids = "?"]]></Calculation>
  </Step>

    <Step enable="True" id="14" name="Show Custom Dialog">
      <Title><Calculation><![CDATA["Backfill Reklamacija"]]></Calculation></Title>
      <Message><Calculation><![CDATA["Nema računa za migraciju — BrojReklamiranogRačuna je prazan na svim računima."]]></Calculation></Message>
      <Button1><Calculation><![CDATA["OK"]]></Calculation></Button1>
    </Step>

    <Step enable="True" id="103" name="Exit Script">
      <Calculation><![CDATA[""]]></Calculation>
    </Step>

  <Step enable="True" id="70" name="End If"/>

  <Step enable="True" id="141" name="Set Variable">
    <Name>$rowCount</Name>
    <Value><Calculation><![CDATA[ValueCount ( $ids )]]></Calculation></Value>
  </Step>

  <Step enable="True" id="141" name="Set Variable">
    <Name>$i</Name>
    <Value><Calculation><![CDATA[1]]></Calculation></Value>
  </Step>

  <Step enable="True" id="79" name="Freeze Window"/>

  <Step enable="True" id="89" name="# (comment)"/>

  <Step enable="False" id="89" name="# (comment)">
    <Text>MARK: Main loop</Text>
  </Step>

  <Step enable="True" id="71" name="Loop">
    <FlushType value="Always"/>
  </Step>

    <Step enable="True" id="72" name="Exit Loop If">
      <Calculation><![CDATA[$i > $rowCount]]></Calculation>
    </Step>

    <Step enable="True" id="141" name="Set Variable">
      <Name>$row</Name>
      <Value><Calculation><![CDATA[Substitute ( GetValue ( $ids ; $i ) ; "|" ; Char ( 13 ) )]]></Calculation></Value>
    </Step>

    <Step enable="True" id="141" name="Set Variable">
      <Name>$originalID</Name>
      <Value><Calculation><![CDATA[GetValue ( $row ; 1 )]]></Calculation></Value>
    </Step>

    <Step enable="True" id="141" name="Set Variable">
      <Name>$originalBrojFiskalnog</Name>
      <Value><Calculation><![CDATA[GetAsNumber ( GetValue ( $row ; 2 ) )]]></Calculation></Value>
    </Step>

    <Step enable="True" id="141" name="Set Variable">
      <Name>$oldBrojReklamiranog</Name>
      <Value><Calculation><![CDATA[GetAsNumber ( GetValue ( $row ; 3 ) )]]></Calculation></Value>
    </Step>

    <Step enable="True" id="89" name="# (comment)"/>

    <Step enable="False" id="89" name="# (comment)">
      <Text>MARK: Guard — skip if Reklamacija already exists for this invoice</Text>
    </Step>

    <Step enable="True" id="141" name="Set Variable">
      <Name>$existingCount</Name>
      <Value><Calculation><![CDATA[GetAsNumber ( ExecuteSQL (
	"SELECT COUNT(*) FROM Invoices
	 WHERE ForeignKeyOriginalInvoiceID = ?
	   AND StatusDokumenta = 'Reklamacija'" ;
	"" ; "" ;
	$originalID
) )]]></Calculation></Value>
    </Step>

    <Step enable="True" id="68" name="If">
      <Calculation><![CDATA[$existingCount > 0]]></Calculation>
    </Step>

      <Step enable="True" id="141" name="Set Variable">
        <Name>$skipped</Name>
        <Value><Calculation><![CDATA[$skipped + 1]]></Calculation></Value>
      </Step>

      <Step enable="True" id="141" name="Set Variable">
        <Name>$i</Name>
        <Value><Calculation><![CDATA[$i + 1]]></Calculation></Value>
      </Step>

    <Step enable="True" id="70" name="End If"/>

    <Step enable="True" id="68" name="If">
      <Calculation><![CDATA[$existingCount = 0]]></Calculation>
    </Step>

      <Step enable="False" id="89" name="# (comment)">
        <Text>MARK: Find and read original invoice</Text>
      </Step>

      <Step enable="True" id="6" name="Go to Layout">
        <LayoutDestination value="SelectedLayout">
          <Layout id="179" name="Dev Invoices"/>
        </LayoutDestination>
        <Animation value="None"/>
      </Step>

      <Step enable="True" id="17" name="Enter Find Mode">
        <Pause state="False"/>
      </Step>

      <Step enable="True" id="76" name="Set Field">
        <Calculation><![CDATA[$originalID]]></Calculation>
        <Field table="Invoices" id="1" name="PrimaryKey"/>
      </Step>

      <Step enable="True" id="22" name="Perform Find">
        <Restore state="False"/>
      </Step>

      <Step enable="True" id="68" name="If">
        <Calculation><![CDATA[Get ( LastError ) ≠ 0 or Get ( FoundCount ) = 0]]></Calculation>
      </Step>

        <Step enable="True" id="141" name="Set Variable">
          <Name>$failed</Name>
          <Value><Calculation><![CDATA[$failed + 1]]></Calculation></Value>
        </Step>

        <Step enable="True" id="141" name="Set Variable">
          <Name>$i</Name>
          <Value><Calculation><![CDATA[$i + 1]]></Calculation></Value>
        </Step>

      <Step enable="True" id="69" name="Else"/>

        <Step enable="True" id="141" name="Set Variable">
          <Name>$clientID</Name>
          <Value><Calculation><![CDATA[Invoices::ForeignKeyClientID]]></Calculation></Value>
        </Step>

        <Step enable="True" id="141" name="Set Variable">
          <Name>$companyID</Name>
          <Value><Calculation><![CDATA[Invoices::ForeignKeyCompanyID]]></Calculation></Value>
        </Step>

        <Step enable="True" id="141" name="Set Variable">
          <Name>$paymentType</Name>
          <Value><Calculation><![CDATA[Invoices::NacinPlacanja]]></Calculation></Value>
        </Step>

        <Step enable="True" id="141" name="Set Variable">
          <Name>$datum</Name>
          <Value><Calculation><![CDATA[Invoices::Datum]]></Calculation></Value>
        </Step>

        <Step enable="True" id="89" name="# (comment)"/>

        <Step enable="False" id="89" name="# (comment)">
          <Text>MARK: Collect lines from original</Text>
        </Step>

        <Step enable="True" id="141" name="Set Variable">
          <Name>$lines</Name>
          <Value><Calculation><![CDATA["[]"]]></Calculation></Value>
        </Step>

        <Step enable="True" id="74" name="Go to Related Record">
          <Option state="True"/>
          <Table id="0" name="InvoiceLines"/>
          <LayoutDestination value="SelectedLayout">
            <Layout id="225" name="Dev InvoiceLines"/>
          </LayoutDestination>
          <Animation value="None"/>
        </Step>

        <Step enable="True" id="68" name="If">
          <Calculation><![CDATA[Get ( LastError ) = 0 and Get ( FoundCount ) > 0]]></Calculation>
        </Step>

          <Step enable="True" id="16" name="Go to Record/Request/Page">
            <RowPageLocation value="First"/>
          </Step>

          <Step enable="True" id="71" name="Loop">
            <FlushType value="Always"/>
          </Step>

            <Step enable="True" id="141" name="Set Variable">
              <Name>$lines</Name>
              <Value><Calculation><![CDATA[JSONSetElement ( $lines ; "[+]" ;
	JSONSetElement ( "{}" ;
		[ "sifra"       ; InvoiceLines::Šifra                        ; JSONString ] ;
		[ "naziv"       ; InvoiceLines::Description                   ; JSONString ] ;
		[ "jm"          ; InvoiceLines::JM                            ; JSONString ] ;
		[ "cijena"      ; InvoiceLines::Rate                          ; JSONNumber ] ;
		[ "kolicina"    ; InvoiceLines::Qty                           ; JSONNumber ] ;
		[ "rabat"       ; InvoiceLines::Discount                      ; JSONNumber ] ;
		[ "vrstaStavke" ; InvoiceLines::VrstaStavke                   ; JSONString ] ;
		[ "artikalID"   ; InvoiceLines::ForeignKeyArtikal             ; JSONString ] ;
		[ "batchID"     ; InvoiceLines::ForeignKeyStavkaUlazneFakture ; JSONString ]
	) ;
	JSONObject
)]]></Calculation></Value>
            </Step>

            <Step enable="True" id="16" name="Go to Record/Request/Page">
              <RowPageLocation value="Next"/>
              <Exit state="True"/>
            </Step>

          <Step enable="True" id="73" name="End Loop"/>

        <Step enable="True" id="70" name="End If"/>

        <Step enable="True" id="89" name="# (comment)"/>

        <Step enable="False" id="89" name="# (comment)">
          <Text>MARK: Create Reklamacija header</Text>
        </Step>

        <Step enable="True" id="6" name="Go to Layout">
          <LayoutDestination value="SelectedLayout">
            <Layout id="179" name="Dev Invoices"/>
          </LayoutDestination>
          <Animation value="None"/>
        </Step>

        <Step enable="True" id="28" name="New Record/Request"/>

        <Step enable="True" id="76" name="Set Field">
          <Calculation><![CDATA["Reklamacija"]]></Calculation>
          <Field table="Invoices" id="21" name="StatusDokumenta"/>
        </Step>

        <Step enable="True" id="76" name="Set Field">
          <Calculation><![CDATA[$originalID]]></Calculation>
          <Field table="Invoices" id="37" name="ForeignKeyOriginalInvoiceID"/>
        </Step>

        <Step enable="True" id="76" name="Set Field">
          <Calculation><![CDATA[$clientID]]></Calculation>
          <Field table="Invoices" id="19" name="ForeignKeyClientID"/>
        </Step>

        <Step enable="True" id="76" name="Set Field">
          <Calculation><![CDATA[$companyID]]></Calculation>
          <Field table="Invoices" id="26" name="ForeignKeyCompanyID"/>
        </Step>

        <Step enable="True" id="76" name="Set Field">
          <Calculation><![CDATA[$paymentType]]></Calculation>
          <Field table="Invoices" id="9" name="NacinPlacanja"/>
        </Step>

        <Step enable="True" id="76" name="Set Field">
          <Calculation><![CDATA[GetAsDate ( $datum )]]></Calculation>
          <Field table="Invoices" id="10" name="Datum"/>
        </Step>

        <Step enable="True" id="76" name="Set Field">
          <Calculation><![CDATA[$oldBrojReklamiranog]]></Calculation>
          <Field table="Invoices" id="7" name="BrojFiskalnogRačuna"/>
        </Step>

        <Step enable="True" id="76" name="Set Field">
          <Calculation><![CDATA[$originalBrojFiskalnog]]></Calculation>
          <Field table="Invoices" id="16" name="BrojReklamiranogRačuna"/>
        </Step>

        <Step enable="True" id="75" name="Commit Records/Requests">
          <NoInteract state="True"/>
        </Step>

        <Step enable="True" id="68" name="If">
          <Calculation><![CDATA[Get ( LastError ) ≠ 0]]></Calculation>
        </Step>

          <Step enable="True" id="141" name="Set Variable">
            <Name>$failed</Name>
            <Value><Calculation><![CDATA[$failed + 1]]></Calculation></Value>
          </Step>

          <Step enable="True" id="141" name="Set Variable">
            <Name>$i</Name>
            <Value><Calculation><![CDATA[$i + 1]]></Calculation></Value>
          </Step>

        <Step enable="True" id="69" name="Else"/>

          <Step enable="True" id="141" name="Set Variable">
            <Name>$refundID</Name>
            <Value><Calculation><![CDATA[Invoices::PrimaryKey]]></Calculation></Value>
          </Step>

          <Step enable="False" id="89" name="# (comment)">
            <Text>MARK: Create refund lines</Text>
          </Step>

          <Step enable="True" id="141" name="Set Variable">
            <Name>$lineTotal</Name>
            <Value><Calculation><![CDATA[ValueCount ( JSONListKeys ( $lines ; "" ) )]]></Calculation></Value>
          </Step>

          <Step enable="True" id="141" name="Set Variable">
            <Name>$j</Name>
            <Value><Calculation><![CDATA[0]]></Calculation></Value>
          </Step>

          <Step enable="True" id="6" name="Go to Layout">
            <LayoutDestination value="SelectedLayout">
              <Layout id="225" name="Dev InvoiceLines"/>
            </LayoutDestination>
            <Animation value="None"/>
          </Step>

          <Step enable="True" id="71" name="Loop">
            <FlushType value="Always"/>
          </Step>

            <Step enable="True" id="72" name="Exit Loop If">
              <Calculation><![CDATA[$j >= $lineTotal]]></Calculation>
            </Step>

            <Step enable="True" id="141" name="Set Variable">
              <Name>$line</Name>
              <Value><Calculation><![CDATA[JSONGetElement ( $lines ; "[" & $j & "]" )]]></Calculation></Value>
            </Step>

            <Step enable="True" id="28" name="New Record/Request"/>

            <Step enable="True" id="76" name="Set Field">
              <Calculation><![CDATA[$refundID]]></Calculation>
              <Field table="InvoiceLines" id="6" name="ForeignKeyInvoiceID"/>
            </Step>

            <Step enable="True" id="76" name="Set Field">
              <Calculation><![CDATA[JSONGetElement ( $line ; "sifra" )]]></Calculation>
              <Field table="InvoiceLines" id="13" name="Šifra"/>
            </Step>

            <Step enable="True" id="76" name="Set Field">
              <Calculation><![CDATA[JSONGetElement ( $line ; "naziv" )]]></Calculation>
              <Field table="InvoiceLines" id="7" name="Description"/>
            </Step>

            <Step enable="True" id="76" name="Set Field">
              <Calculation><![CDATA[JSONGetElement ( $line ; "jm" )]]></Calculation>
              <Field table="InvoiceLines" id="17" name="JM"/>
            </Step>

            <Step enable="True" id="76" name="Set Field">
              <Calculation><![CDATA[JSONGetElement ( $line ; "cijena" )]]></Calculation>
              <Field table="InvoiceLines" id="9" name="Rate"/>
            </Step>

            <Step enable="True" id="76" name="Set Field">
              <Calculation><![CDATA[JSONGetElement ( $line ; "kolicina" )]]></Calculation>
              <Field table="InvoiceLines" id="8" name="Qty"/>
            </Step>

            <Step enable="True" id="76" name="Set Field">
              <Calculation><![CDATA[JSONGetElement ( $line ; "rabat" )]]></Calculation>
              <Field table="InvoiceLines" id="11" name="Discount"/>
            </Step>

            <Step enable="True" id="76" name="Set Field">
              <Calculation><![CDATA[JSONGetElement ( $line ; "vrstaStavke" )]]></Calculation>
              <Field table="InvoiceLines" id="22" name="VrstaStavke"/>
            </Step>

            <Step enable="True" id="76" name="Set Field">
              <Calculation><![CDATA[JSONGetElement ( $line ; "artikalID" )]]></Calculation>
              <Field table="InvoiceLines" id="16" name="ForeignKeyArtikal"/>
            </Step>

            <Step enable="True" id="76" name="Set Field">
              <Calculation><![CDATA[JSONGetElement ( $line ; "batchID" )]]></Calculation>
              <Field table="InvoiceLines" id="20" name="ForeignKeyStavkaUlazneFakture"/>
            </Step>

            <Step enable="True" id="75" name="Commit Records/Requests">
              <NoInteract state="True"/>
            </Step>

            <Step enable="True" id="141" name="Set Variable">
              <Name>$j</Name>
              <Value><Calculation><![CDATA[$j + 1]]></Calculation></Value>
            </Step>

          <Step enable="True" id="73" name="End Loop"/>

          <Step enable="False" id="89" name="# (comment)">
            <Text>MARK: Clear BrojReklamiranogRačuna on original</Text>
          </Step>

          <Step enable="True" id="6" name="Go to Layout">
            <LayoutDestination value="SelectedLayout">
              <Layout id="179" name="Dev Invoices"/>
            </LayoutDestination>
            <Animation value="None"/>
          </Step>

          <Step enable="True" id="17" name="Enter Find Mode">
            <Pause state="False"/>
          </Step>

          <Step enable="True" id="76" name="Set Field">
            <Calculation><![CDATA[$originalID]]></Calculation>
            <Field table="Invoices" id="1" name="PrimaryKey"/>
          </Step>

          <Step enable="True" id="22" name="Perform Find">
            <Restore state="False"/>
          </Step>

          <Step enable="True" id="76" name="Set Field">
            <Calculation><![CDATA[""]]></Calculation>
            <Field table="Invoices" id="16" name="BrojReklamiranogRačuna"/>
          </Step>

          <Step enable="True" id="75" name="Commit Records/Requests">
            <NoInteract state="True"/>
          </Step>

          <Step enable="True" id="141" name="Set Variable">
            <Name>$processed</Name>
            <Value><Calculation><![CDATA[$processed + 1]]></Calculation></Value>
          </Step>

          <Step enable="True" id="141" name="Set Variable">
            <Name>$i</Name>
            <Value><Calculation><![CDATA[$i + 1]]></Calculation></Value>
          </Step>

        <Step enable="True" id="70" name="End If"/>

      <Step enable="True" id="70" name="End If"/>

    <Step enable="True" id="70" name="End If"/>

  <Step enable="True" id="73" name="End Loop"/>

  <Step enable="True" id="89" name="# (comment)"/>

  <Step enable="True" id="6" name="Go to Layout">
    <LayoutDestination value="LayoutNameByCalculation">
      <Layout id="0" name=""/>
      <Calculation><![CDATA[$returnLayout]]></Calculation>
    </LayoutDestination>
    <Animation value="None"/>
  </Step>

  <Step enable="True" id="14" name="Show Custom Dialog">
    <Title><Calculation><![CDATA["Backfill Reklamacija — završeno"]]></Calculation></Title>
    <Message><Calculation><![CDATA["Obrađeno:  " & $processed & "¶" &
"Preskočeno (već postoji): " & $skipped & "¶" &
"Greška:    " & $failed]]></Calculation></Message>
    <Button1><Calculation><![CDATA["OK"]]></Calculation></Button1>
  </Step>

  <Step enable="True" id="103" name="Exit Script">
    <Calculation><![CDATA[JSONSetElement ( "{}" ;
	[ "processed" ; $processed ; JSONNumber ] ;
	[ "skipped"   ; $skipped   ; JSONNumber ] ;
	[ "failed"    ; $failed    ; JSONNumber ]
)]]></Calculation>
  </Step>

</fmxmlsnippet>

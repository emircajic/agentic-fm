<?xml version="1.0"?>
<fmxmlsnippet type="FMObjectList">
  <Script includeInMenu="False" SiriShortcutVisible="False" runFullAccess="False" id="178001" name="AGENT__QueueXMLExport">
    <Step enable="True" id="89" name="# (comment)">
      <Text>PURPOSE: Queue one AgentExports record for later server-side XML assembly.</Text>
    </Step>
    <Step enable="True" id="86" name="Set Error Capture">
      <Set state="True"/>
    </Step>
    <Step enable="True" id="85" name="Allow User Abort">
      <Set state="False"/>
    </Step>
    <Step enable="True" id="141" name="Set Variable">
      <Value>
        <Calculation><![CDATA[Response_Init ( "{}" )]]></Calculation>
      </Value>
      <Name>$response</Name>
    </Step>
    <Step enable="True" id="141" name="Set Variable">
      <Value>
        <Calculation><![CDATA[Get ( ScriptParameter )]]></Calculation>
      </Value>
      <Name>$param</Name>
    </Step>
    <Step enable="True" id="141" name="Set Variable">
      <Value>
        <Calculation><![CDATA[Let ( [ v = JSONGetElement ( $param ; "solution" ) ] ; Case ( not IsEmpty ( v ) and Left ( v ; 1 ) ≠ "?" ; v ; Get ( FileName ) ) )]]></Calculation>
      </Value>
      <Name>$solution</Name>
    </Step>
    <Step enable="True" id="141" name="Set Variable">
      <Value>
        <Calculation><![CDATA[Let ( [ v = JSONGetElement ( $param ; "type" ) ] ; Case ( not IsEmpty ( v ) and Left ( v ; 1 ) ≠ "?" ; v ; "xml_export" ) )]]></Calculation>
      </Value>
      <Name>$type</Name>
    </Step>
    <Step enable="True" id="141" name="Set Variable">
      <Value>
        <Calculation><![CDATA[Let ( [ v = JSONGetElement ( $param ; "filename" ) ] ; Case ( not IsEmpty ( v ) and Left ( v ; 1 ) ≠ "?" ; v ; $solution & ".xml" ) )]]></Calculation>
      </Value>
      <Name>$filename</Name>
    </Step>
    <Step enable="True" id="141" name="Set Variable">
      <Value>
        <Calculation><![CDATA[Let ( [ v = JSONGetElement ( $param ; "requestedBy" ) ] ; Case ( not IsEmpty ( v ) and Left ( v ; 1 ) ≠ "?" ; v ; Get ( AccountName ) ) )]]></Calculation>
      </Value>
      <Name>$requestedBy</Name>
    </Step>
    <Step enable="True" id="141" name="Set Variable">
      <Value>
        <Calculation><![CDATA[Let (
[
    v = JSONGetElement ( $param ; "autoBuild" ) ;
    t = JSONGetElementType ( $param ; "autoBuild" )
] ;
    Case ( t = JSONBoolean and v ; 1 ; 0 )
)]]></Calculation>
      </Value>
      <Name>$autoBuild</Name>
    </Step>
    <Step enable="True" id="6" name="Go to Layout">
      <LayoutDestination value="SelectedLayout"/>
      <Layout id="250" name="AgentExports"/>
      <Animation value=""/>
    </Step>
    <Step enable="True" id="31" name="New Record/Request"/>
    <Step enable="True" id="68" name="If">
      <Restore state="False"/>
      <Calculation><![CDATA[Get ( LastError ) ≠ 0]]></Calculation>
    </Step>
    <Step enable="True" id="141" name="Set Variable">
      <Value>
        <Calculation><![CDATA[Response_AddError (
    "AGENT_QUEUE_CREATE_FAILED" ;
    "Unable to create AgentExports queue record." ;
    "AgentExports" ;
    JSONSetElement ( "{}" ; [ "error" ; Get ( LastError ) ; JSONNumber ] ) ;
    Get ( ScriptName )
)]]></Calculation>
      </Value>
      <Name>$response</Name>
    </Step>
    <Step enable="True" id="69" name="Else">
      <Restore state="False"/>
    </Step>
    <Step enable="True" id="76" name="Set Field">
      <Calculation><![CDATA[$type]]></Calculation>
      <Field table="AgentExports" id="13" name="Type"/>
    </Step>
    <Step enable="True" id="76" name="Set Field">
      <Calculation><![CDATA[$solution]]></Calculation>
      <Field table="AgentExports" id="14" name="Solution"/>
    </Step>
    <Step enable="True" id="76" name="Set Field">
      <Calculation><![CDATA["pending"]]></Calculation>
      <Field table="AgentExports" id="15" name="Status"/>
    </Step>
    <Step enable="True" id="76" name="Set Field">
      <Calculation><![CDATA[$filename]]></Calculation>
      <Field table="AgentExports" id="16" name="Filename"/>
    </Step>
    <Step enable="True" id="76" name="Set Field">
      <Calculation><![CDATA[$requestedBy]]></Calculation>
      <Field table="AgentExports" id="20" name="requestedBy"/>
    </Step>
    <Step enable="True" id="76" name="Set Field">
      <Calculation><![CDATA[Get ( CurrentTimestamp )]]></Calculation>
      <Field table="AgentExports" id="21" name="requestedOn"/>
    </Step>
    <Step enable="True" id="75" name="Commit Records/Requests">
      <NoInteract state="True"/>
      <Option state="False"/>
      <ESSForceCommit state="False"/>
    </Step>
    <Step enable="True" id="141" name="Set Variable">
      <Value>
        <Calculation><![CDATA[Get ( LastError )]]></Calculation>
      </Value>
      <Name>$commitError</Name>
    </Step>
    <Step enable="True" id="68" name="If">
      <Restore state="False"/>
      <Calculation><![CDATA[$commitError ≠ 0]]></Calculation>
    </Step>
    <Step enable="True" id="141" name="Set Variable">
      <Value>
        <Calculation><![CDATA[Response_AddError (
    "AGENT_QUEUE_COMMIT_FAILED" ;
    "Unable to save AgentExports queue record." ;
    "AgentExports::Status" ;
    JSONSetElement ( "{}" ; [ "error" ; $commitError ; JSONNumber ] ) ;
    Get ( ScriptName )
)]]></Calculation>
      </Value>
      <Name>$response</Name>
    </Step>
    <Step enable="True" id="69" name="Else">
      <Restore state="False"/>
    </Step>
    <Step enable="True" id="141" name="Set Variable">
      <Value>
        <Calculation><![CDATA[Response_SetData (
    JSONSetElement ( "{}" ;
        [ "id" ; AgentExports::id ; JSONString ] ;
        [ "status" ; AgentExports::Status ; JSONString ] ;
        [ "solution" ; AgentExports::Solution ; JSONString ] ;
        [ "type" ; AgentExports::Type ; JSONString ] ;
        [ "filename" ; AgentExports::Filename ; JSONString ]
    )
)]]></Calculation>
      </Value>
      <Name>$response</Name>
    </Step>
    <Step enable="True" id="68" name="If">
      <Restore state="False"/>
      <Calculation><![CDATA[$autoBuild]]></Calculation>
    </Step>
    <Step enable="True" id="1" name="Perform Script">
      <Calculated>
        <Calculation><![CDATA["AGENT__BuildXMLExport"]]></Calculation>
      </Calculated>
      <Calculation><![CDATA[JSONSetElement ( "{}" ; [ "id" ; AgentExports::id ; JSONString ] )]]></Calculation>
    </Step>
    <Step enable="True" id="70" name="End If"/>
    <Step enable="True" id="70" name="End If"/>
    <Step enable="True" id="70" name="End If"/>
    <Step enable="True" id="6" name="Go to Layout">
      <LayoutDestination value="OriginalLayout"/>
      <Animation value=""/>
    </Step>
    <Step enable="True" id="141" name="Set Variable">
      <Value>
        <Calculation><![CDATA[Response_Finalize]]></Calculation>
      </Value>
      <Name>$response</Name>
    </Step>
    <Step enable="True" id="103" name="Exit Script">
      <Calculation><![CDATA[$response]]></Calculation>
    </Step>
  </Script>
</fmxmlsnippet>

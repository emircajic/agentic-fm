<fmxmlsnippet type="FMObjectList">
  <Step enable="True" id="68" name="Set Error Capture">
    <State state="True"/>
  </Step>
  <Step enable="True" id="85" name="Allow User Abort">
    <State state="False"/>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Name>$response</Name>
    <Value><Calculation><![CDATA[Response_Init ( "{}" )]]></Calculation></Value>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Name>$param</Name>
    <Value><Calculation><![CDATA[Get ( ScriptParameter )]]></Calculation></Value>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Name>$id</Name>
    <Value><Calculation><![CDATA[JSONGetElement ( $param ; "id" )]]></Calculation></Value>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Name>$companionURL</Name>
    <Value><Calculation><![CDATA[JSONGetElement ( $param ; "companion_url" )]]></Calculation></Value>
  </Step>
  <Step enable="True" id="68" name="If">
    <Calculation><![CDATA[IsEmpty ( $id )]]></Calculation>
  </Step>
    <Step enable="True" id="141" name="Set Variable">
      <Name>$response</Name>
      <Value><Calculation><![CDATA[Response_AddError (
    "AGENT_BUILD_ID_MISSING" ;
    "AgentExports id is required." ;
    "Get ( ScriptParameter )" ;
    "{}" ;
    Get ( ScriptName )
)]]></Calculation></Value>
    </Step>
  <Step enable="True" id="70" name="Else"/>
    <Step enable="True" id="5" name="Go to Layout">
      <Layout name="AgentExports" id="0"/>
    </Step>
    <Step enable="True" id="28" name="Enter Find Mode">
      <Pause state="False"/>
    </Step>
    <Step enable="True" id="76" name="Set Field">
      <Field table="AgentExports" id="0" name="id"/>
      <Calculation><![CDATA["=" & $id]]></Calculation>
    </Step>
    <Step enable="True" id="31" name="Perform Find"/>
    <Step enable="True" id="68" name="If">
      <Calculation><![CDATA[Get ( FoundCount ) ≠ 1]]></Calculation>
    </Step>
      <Step enable="True" id="141" name="Set Variable">
        <Name>$response</Name>
        <Value><Calculation><![CDATA[Response_AddError (
    "AGENT_BUILD_NOT_FOUND" ;
    "Expected exactly one AgentExports row for the supplied id." ;
    "AgentExports::id" ;
    JSONSetElement ( "{}" ; [ "id" ; $id ; JSONString ] ) ;
    Get ( ScriptName )
)]]></Calculation></Value>
      </Step>
    <Step enable="True" id="70" name="Else"/>
      <Step enable="True" id="76" name="Set Field">
        <Field table="AgentExports" id="0" name="Status"/>
        <Calculation><![CDATA["assembling"]]></Calculation>
      </Step>
      <Step enable="True" id="76" name="Set Field">
        <Field table="AgentExports" id="0" name="startedOn"/>
        <Calculation><![CDATA[Get ( CurrentTimestamp )]]></Calculation>
      </Step>
      <Step enable="True" id="76" name="Set Field">
        <Field table="AgentExports" id="0" name="Error"/>
        <Calculation><![CDATA[""]]></Calculation>
      </Step>
      <Step enable="True" id="75" name="Commit Records/Requests">
        <DialogOption state="False"/>
      </Step>
      <Step enable="True" id="141" name="Set Variable">
        <Name>$serverFolderFm</Name>
        <Value><Calculation><![CDATA["filewin:/C:/Program Files/FileMaker/FileMaker Server/Data/Documents/AgentExports/"]]></Calculation></Value>
      </Step>
      <Step enable="True" id="141" name="Set Variable">
        <Name>$serverFolderNative</Name>
        <Value><Calculation><![CDATA["C:\Program Files\FileMaker\FileMaker Server\Data\Documents\AgentExports\"]]></Calculation></Value>
      </Step>
      <Step enable="True" id="141" name="Set Variable">
        <Name>$xmlFilename</Name>
        <Value><Calculation><![CDATA[Case ( IsEmpty ( AgentExports::Filename ) ; AgentExports::Solution & ".xml" ; AgentExports::Filename )]]></Calculation></Value>
      </Step>
      <Step enable="True" id="141" name="Set Variable">
        <Name>$xmlBaseName</Name>
        <Value><Calculation><![CDATA[AgentExports::id & "__" & $xmlFilename]]></Calculation></Value>
      </Step>
      <Step enable="True" id="141" name="Set Variable">
        <Name>$xmlFmPath</Name>
        <Value><Calculation><![CDATA[$serverFolderFm & $xmlBaseName]]></Calculation></Value>
      </Step>
      <Step enable="True" id="141" name="Set Variable">
        <Name>$xmlNativePath</Name>
        <Value><Calculation><![CDATA[$serverFolderNative & $xmlBaseName]]></Calculation></Value>
      </Step>
      <Step enable="True" id="177" name="Save a Copy as XML">
        <Calculation><![CDATA[$xmlFmPath]]></Calculation>
      </Step>
      <Step enable="True" id="141" name="Set Variable">
        <Name>$saveError</Name>
        <Value><Calculation><![CDATA[Get ( LastError )]]></Calculation></Value>
      </Step>
      <Step enable="True" id="68" name="If">
        <Calculation><![CDATA[$saveError ≠ 0]]></Calculation>
      </Step>
        <Step enable="True" id="76" name="Set Field">
          <Field table="AgentExports" id="0" name="Status"/>
          <Calculation><![CDATA["failed"]]></Calculation>
        </Step>
        <Step enable="True" id="76" name="Set Field">
          <Field table="AgentExports" id="0" name="finishedOn"/>
          <Calculation><![CDATA[Get ( CurrentTimestamp )]]></Calculation>
        </Step>
        <Step enable="True" id="76" name="Set Field">
          <Field table="AgentExports" id="0" name="Error"/>
          <Calculation><![CDATA["Save as XML failed (error " & $saveError & ")."]]></Calculation>
        </Step>
        <Step enable="True" id="76" name="Set Field">
          <Field table="AgentExports" id="0" name="Notes"/>
          <Calculation><![CDATA[$xmlFmPath]]></Calculation>
        </Step>
        <Step enable="True" id="75" name="Commit Records/Requests">
          <DialogOption state="False"/>
        </Step>
        <Step enable="True" id="141" name="Set Variable">
          <Name>$response</Name>
          <Value><Calculation><![CDATA[Response_AddError (
    "AGENT_BUILD_SAVE_XML_FAILED" ;
    "Save a Copy as XML failed." ;
    "Save a Copy as XML" ;
    JSONSetElement (
        "{}" ;
        [ "id" ; AgentExports::id ; JSONString ] ;
        [ "error" ; $saveError ; JSONNumber ] ;
        [ "path" ; $xmlFmPath ; JSONString ]
    ) ;
    Get ( ScriptName )
)]]></Calculation></Value>
        </Step>
      <Step enable="True" id="70" name="Else"/>
        <Step enable="True" id="141" name="Set Variable">
          <Name>$~</Name>
          <Value><Calculation><![CDATA[BE_HTTP_SetCustomHeader ( "X-Export-Id" ; AgentExports::id )]]></Calculation></Value>
        </Step>
        <Step enable="True" id="141" name="Set Variable">
          <Name>$~</Name>
          <Value><Calculation><![CDATA[BE_HTTP_SetCustomHeader ( "X-Filename" ; $xmlBaseName )]]></Calculation></Value>
        </Step>
        <Step enable="True" id="141" name="Set Variable">
          <Name>$~</Name>
          <Value><Calculation><![CDATA[BE_HTTP_SetCustomHeader ( "X-Solution-Name" ; AgentExports::Solution )]]></Calculation></Value>
        </Step>
        <Step enable="True" id="141" name="Set Variable">
          <Name>$xmlContent</Name>
          <Value><Calculation><![CDATA[BE_FileReadText ( $xmlNativePath )]]></Calculation></Value>
        </Step>
        <Step enable="True" id="141" name="Set Variable">
          <Name>$httpResult</Name>
          <Value><Calculation><![CDATA[BE_HTTP_POST ( $companionURL & "/agentexports/receive" ; $xmlContent )]]></Calculation></Value>
        </Step>
        <Step enable="True" id="141" name="Set Variable">
          <Name>$httpCode</Name>
          <Value><Calculation><![CDATA[BE_HTTP_ResponseCode]]></Calculation></Value>
        </Step>
        <Step enable="True" id="141" name="Set Variable">
          <Name>$~</Name>
          <Value><Calculation><![CDATA[BE_FileDelete ( $xmlNativePath )]]></Calculation></Value>
        </Step>
        <Step enable="True" id="68" name="If">
          <Calculation><![CDATA[$httpCode ≠ 200]]></Calculation>
        </Step>
          <Step enable="True" id="76" name="Set Field">
            <Field table="AgentExports" id="0" name="Status"/>
            <Calculation><![CDATA["failed"]]></Calculation>
          </Step>
          <Step enable="True" id="76" name="Set Field">
            <Field table="AgentExports" id="0" name="finishedOn"/>
            <Calculation><![CDATA[Get ( CurrentTimestamp )]]></Calculation>
          </Step>
          <Step enable="True" id="76" name="Set Field">
            <Field table="AgentExports" id="0" name="Error"/>
            <Calculation><![CDATA["HTTP POST to companion failed (code " & $httpCode & ")."]]></Calculation>
          </Step>
          <Step enable="True" id="75" name="Commit Records/Requests">
            <DialogOption state="False"/>
          </Step>
          <Step enable="True" id="141" name="Set Variable">
            <Name>$response</Name>
            <Value><Calculation><![CDATA[Response_AddError (
    "AGENT_BUILD_POST_FAILED" ;
    "HTTP POST to companion server failed." ;
    "BE_HTTP_POST" ;
    JSONSetElement (
        "{}" ;
        [ "id" ; AgentExports::id ; JSONString ] ;
        [ "http_code" ; $httpCode ; JSONNumber ] ;
        [ "result" ; $httpResult ; JSONString ]
    ) ;
    Get ( ScriptName )
)]]></Calculation></Value>
          </Step>
        <Step enable="True" id="70" name="Else"/>
          <Step enable="True" id="76" name="Set Field">
            <Field table="AgentExports" id="0" name="Status"/>
            <Calculation><![CDATA["processing"]]></Calculation>
          </Step>
          <Step enable="True" id="76" name="Set Field">
            <Field table="AgentExports" id="0" name="finishedOn"/>
            <Calculation><![CDATA[Get ( CurrentTimestamp )]]></Calculation>
          </Step>
          <Step enable="True" id="76" name="Set Field">
            <Field table="AgentExports" id="0" name="Error"/>
            <Calculation><![CDATA[""]]></Calculation>
          </Step>
          <Step enable="True" id="75" name="Commit Records/Requests">
            <DialogOption state="False"/>
          </Step>
          <Step enable="True" id="141" name="Set Variable">
            <Name>$response</Name>
            <Value><Calculation><![CDATA[Response_SetData (
    JSONSetElement (
        "{}" ;
        [ "id" ; AgentExports::id ; JSONString ] ;
        [ "status" ; AgentExports::Status ; JSONString ] ;
        [ "filename" ; AgentExports::Filename ; JSONString ] ;
        [ "http_code" ; $httpCode ; JSONNumber ]
    )
)]]></Calculation></Value>
          </Step>
        <Step enable="True" id="72" name="End If"/>
      <Step enable="True" id="72" name="End If"/>
    <Step enable="True" id="72" name="End If"/>
  <Step enable="True" id="72" name="End If"/>
  <Step enable="True" id="5" name="Go to Layout">
    <OriginalLayout/>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Name>$response</Name>
    <Value><Calculation><![CDATA[Response_Finalize]]></Calculation></Value>
  </Step>
  <Step enable="True" id="6" name="Exit Script">
    <Calculation><![CDATA[$response]]></Calculation>
  </Step>
</fmxmlsnippet>

<fmxmlsnippet type="FMObjectList">

	<Step enable="True" id="89" name="# (comment)">
		<Text>PURPOSE: Attach one or more StavkePrimke to a UFD header by setting ForeignKeyUlaznaFakturaID.</Text>
	</Step>
	<Step enable="False" id="61" name="Insert Text">
		<SelectAll state="False"/>
		<Text>PARAMS: ulaznaFakturaID (text, required) | stavkePKs (JSONArray of StavkePrimke PKs, required)
RETURNS: data.attachedCount (number)</Text>
		<Field>$README</Field>
	</Step>

	<Step enable="True" id="85" name="Allow User Abort">
		<Set state="False"/>
	</Step>
	<Step enable="True" id="86" name="Set Error Capture">
		<Set state="True"/>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Params.parse ( Get ( ScriptParameter ) ; "ulaznaFakturaID|stavkePKs" )]]></Calculation></Value>
	</Step>
	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Response_Init ( "{}" )]]></Calculation></Value>
	</Step>
	<Step enable="True" id="141" name="Set Variable">
		<Name>$attachedCount</Name>
		<Value><Calculation><![CDATA[0]]></Calculation></Value>
	</Step>
	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Log.add ( "info" ; "UFD_ATTACH_START" ; "Attaching stavke to UFD: " & $ulaznaFakturaID ; $params )]]></Calculation></Value>
	</Step>

	<Step enable="False" id="89" name="# (comment)">
		<Text>MARK: Validate</Text>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[IsEmpty ( $ulaznaFakturaID )]]></Calculation>
	</Step>
		<Step enable="True" id="141" name="Set Variable">
			<Name>$void</Name>
			<Value><Calculation><![CDATA[Response_AddError ( "MISSING_PARAM" ; "ulaznaFakturaID is required" ; "ulaznaFakturaID" ; "{}" ; "" )]]></Calculation></Value>
		</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[IsEmpty ( $stavkePKs ) or ValueCount ( JSONListKeys ( $stavkePKs ; "" ) ) = 0]]></Calculation>
	</Step>
		<Step enable="True" id="141" name="Set Variable">
			<Name>$void</Name>
			<Value><Calculation><![CDATA[Response_AddError ( "MISSING_PARAM" ; "stavkePKs is required and must not be empty" ; "stavkePKs" ; "{}" ; "" )]]></Calculation></Value>
		</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[Response_HasErrors ( $response )]]></Calculation>
	</Step>
		<Step enable="True" id="68" name="If">
			<Calculation><![CDATA[$isRoot]]></Calculation>
		</Step>
			<Step enable="True" id="1" name="Perform Script">
				<Script id="0" name="UTIL__FlushLog"/>
				<Calculation><![CDATA[JSONSetElement ( "{}" ; "traceID" ; $traceID ; JSONString )]]></Calculation>
			</Step>
		<Step enable="True" id="70" name="End If"/>
		<Step enable="True" id="103" name="Exit Script">
			<Calculation><![CDATA[Response_Finalize]]></Calculation>
		</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="False" id="89" name="# (comment)">
		<Text>MARK: Verify UFD exists</Text>
	</Step>

	<Step enable="True" id="6" name="Go to Layout">
		<LayoutDestination value="SelectedLayout"/>
		<Layout id="240" name="UFD__UlaznaFakturaDobavljaca"/>
		<Animation value="None"/>
	</Step>
	<Step enable="True" id="22" name="Enter Find Mode">
		<UseCurrentRecord state="False"/>
		<PauseForUser state="False"/>
	</Step>
	<Step enable="True" id="76" name="Set Field">
		<Field table="UFD__UlaznaFakturaDobavljaca" id="0" name="PrimaryKey"/>
		<Calculation><![CDATA[$ulaznaFakturaID]]></Calculation>
	</Step>
	<Step enable="True" id="28" name="Perform Find"/>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[Get ( FoundCount ) = 0]]></Calculation>
	</Step>
		<Step enable="True" id="141" name="Set Variable">
			<Name>$void</Name>
			<Value><Calculation><![CDATA[Response_AddError ( "NOT_FOUND_UFD" ; "UFD not found: " & $ulaznaFakturaID ; "" ; "{}" ; "" )]]></Calculation></Value>
		</Step>
		<Step enable="True" id="68" name="If">
			<Calculation><![CDATA[$isRoot]]></Calculation>
		</Step>
			<Step enable="True" id="1" name="Perform Script">
				<Script id="0" name="UTIL__FlushLog"/>
				<Calculation><![CDATA[JSONSetElement ( "{}" ; "traceID" ; $traceID ; JSONString )]]></Calculation>
			</Step>
		<Step enable="True" id="70" name="End If"/>
		<Step enable="True" id="103" name="Exit Script">
			<Calculation><![CDATA[Response_Finalize]]></Calculation>
		</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="False" id="89" name="# (comment)">
		<Text>MARK: Loop stavkePKs</Text>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$count</Name>
		<Value><Calculation><![CDATA[ValueCount ( JSONListKeys ( $stavkePKs ; "" ) )]]></Calculation></Value>
	</Step>
	<Step enable="True" id="141" name="Set Variable">
		<Name>$i</Name>
		<Value><Calculation><![CDATA[0]]></Calculation></Value>
	</Step>

	<Step enable="True" id="71" name="Loop">
		<FlushType value="Always"/>
	</Step>

		<Step enable="True" id="72" name="Exit Loop If">
			<Calculation><![CDATA[$i >= $count]]></Calculation>
		</Step>

		<Step enable="True" id="141" name="Set Variable">
			<Name>$stavkaPK</Name>
			<Value><Calculation><![CDATA[JSONGetElement ( $stavkePKs ; "[" & $i & "]" )]]></Calculation></Value>
		</Step>

		<Step enable="True" id="6" name="Go to Layout">
			<LayoutDestination value="SelectedLayout"/>
			<Layout id="227" name="Dev StavkePrimke"/>
			<Animation value="None"/>
		</Step>
		<Step enable="True" id="22" name="Enter Find Mode">
			<UseCurrentRecord state="False"/>
			<PauseForUser state="False"/>
		</Step>
		<Step enable="True" id="76" name="Set Field">
			<Field table="StavkePrimke" id="0" name="PrimaryKey"/>
			<Calculation><![CDATA[$stavkaPK]]></Calculation>
		</Step>
		<Step enable="True" id="28" name="Perform Find"/>

		<Step enable="True" id="68" name="If">
			<Calculation><![CDATA[Get ( FoundCount ) = 0]]></Calculation>
		</Step>
			<Step enable="True" id="141" name="Set Variable">
				<Name>$void</Name>
				<Value><Calculation><![CDATA[Response_AddWarning ( "NOT_FOUND_STAVKA" ; "StavkaPrimke not found: " & $stavkaPK ; "" ; JSONSetElement ( "{}" ; "stavkaPK" ; $stavkaPK ; JSONString ) ; "" )]]></Calculation></Value>
			</Step>

		<Step enable="True" id="125" name="Else If">
			<Calculation><![CDATA[not IsEmpty ( StavkePrimke::ForeignKeyUlaznaFakturaID ) and StavkePrimke::ForeignKeyUlaznaFakturaID ≠ $ulaznaFakturaID]]></Calculation>
		</Step>
			<Step enable="True" id="141" name="Set Variable">
				<Name>$void</Name>
				<Value><Calculation><![CDATA[Response_AddWarning ( "CONFLICT_ALREADY_LINKED" ; "StavkaPrimke already linked to another UFD" ; "" ; JSONSetElement ( "{}" ; "stavkaPK" ; $stavkaPK ; JSONString ) ; "" )]]></Calculation></Value>
			</Step>

		<Step enable="True" id="69" name="Else"/>

			<Step enable="True" id="76" name="Set Field">
				<Field table="StavkePrimke" id="0" name="ForeignKeyUlaznaFakturaID"/>
				<Calculation><![CDATA[$ulaznaFakturaID]]></Calculation>
			</Step>
			<Step enable="True" id="75" name="Commit Records/Requests">
				<NoInteract state="True"/>
				<Option state="False"/>
				<ESSForceCommit state="False"/>
			</Step>
			<Step enable="True" id="68" name="If">
				<Calculation><![CDATA[Get ( LastError ) = 0]]></Calculation>
			</Step>
				<Step enable="True" id="141" name="Set Variable">
					<Name>$attachedCount</Name>
					<Value><Calculation><![CDATA[$attachedCount + 1]]></Calculation></Value>
				</Step>
			<Step enable="True" id="69" name="Else"/>
				<Step enable="True" id="141" name="Set Variable">
					<Name>$void</Name>
					<Value><Calculation><![CDATA[Response_AddWarning ( "COMMIT_FAILED" ; "Failed to attach stavka: " & $stavkaPK & " (FM error " & Get ( LastError ) & ")" ; "" ; JSONSetElement ( "{}" ; "stavkaPK" ; $stavkaPK ; JSONString ) ; "" )]]></Calculation></Value>
				</Step>
			<Step enable="True" id="70" name="End If"/>

		<Step enable="True" id="70" name="End If"/>

		<Step enable="True" id="141" name="Set Variable">
			<Name>$i</Name>
			<Value><Calculation><![CDATA[$i + 1]]></Calculation></Value>
		</Step>

	<Step enable="True" id="73" name="End Loop"/>

	<Step enable="False" id="89" name="# (comment)">
		<Text>MARK: Result</Text>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[$attachedCount = 0]]></Calculation>
	</Step>
		<Step enable="True" id="141" name="Set Variable">
			<Name>$void</Name>
			<Value><Calculation><![CDATA[Response_AddError ( "NO_STAVKE_ATTACHED" ; "No stavke were successfully attached" ; "" ; $params ; "" )]]></Calculation></Value>
		</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Response_SetData ( JSONSetElement ( "{}" ; "attachedCount" ; $attachedCount ; JSONNumber ) )]]></Calculation></Value>
	</Step>
	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Log.add ( "info" ; "UFD_ATTACH_DONE" ; "Attached " & $attachedCount & " of " & $count & " stavke" ; $params )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[$isRoot]]></Calculation>
	</Step>
		<Step enable="True" id="1" name="Perform Script">
			<Script id="0" name="UTIL__FlushLog"/>
			<Calculation><![CDATA[JSONSetElement ( "{}" ; "traceID" ; $traceID ; JSONString )]]></Calculation>
		</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="103" name="Exit Script">
		<Calculation><![CDATA[Response_Finalize]]></Calculation>
	</Step>

</fmxmlsnippet>

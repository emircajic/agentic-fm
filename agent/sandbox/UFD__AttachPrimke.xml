<fmxmlsnippet type="FMObjectList">

	<Step enable="True" id="89" name="# (comment)">
		<Text>PURPOSE: Attach one or more Primke to a UFD header and set their Status to "Priložena".</Text>
	</Step>

	<Step enable="False" id="61" name="Insert Text">
		<SelectAll state="False"/>
		<Text>PARAMS: ulaznaFakturaID (text, required) | primkaIDs (JSONArray of PrimaryKey strings, required)
RETURNS: data.attachedCount (number)</Text>
		<Field table="" id="0" name="$README"/>
	</Step>

	<Step enable="True" id="85" name="Allow User Abort">
		<Set state="False"/>
	</Step>

	<Step enable="True" id="86" name="Set Error Capture">
		<Set state="True"/>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Params.parse ( Get ( ScriptParameter ) ; "ulaznaFakturaID|primkaIDs" )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Response_Init ( "{}" )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$attachedCount</Name>
		<Value><Calculation><![CDATA[0]]></Calculation></Value>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Log.add ( "info" ; "UFD_ATTACH_START" ; "Attaching primke to UFD: " & $ulaznaFakturaID ; $params )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="89" name="# (comment)">
		<Text>── Validate ──────────────────────────────────────────────────────────────</Text>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[IsEmpty ( $ulaznaFakturaID )]]></Calculation>
	</Step>
	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Response_AddError ( "MISSING_PARAM" ; "ulaznaFakturaID is required" ; "ulaznaFakturaID" ; "{}" ; "" )]]></Calculation></Value>
	</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[IsEmpty ( $primkaIDs ) or ValueCount ( JSONListKeys ( $primkaIDs ; "" ) ) = 0]]></Calculation>
	</Step>
	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Response_AddError ( "MISSING_PARAM" ; "primkaIDs is required and must not be empty" ; "primkaIDs" ; "{}" ; "" )]]></Calculation></Value>
	</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[Response_HasErrors ( $response )]]></Calculation>
	</Step>
	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[$isRoot]]></Calculation>
	</Step>
	<Step enable="True" id="25" name="Perform Script">
		<Script id="780" name="UTIL__FlushLog"/>
		<Calculation><![CDATA[JSONSetElement ( "{}" ; "traceID" ; $traceID ; JSONString )]]></Calculation>
	</Step>
	<Step enable="True" id="70" name="End If"/>
	<Step enable="True" id="103" name="Exit Script">
		<Calculation><![CDATA[Response_Finalize]]></Calculation>
	</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="89" name="# (comment)">
		<Text>── Load UFD header ───────────────────────────────────────────────────────</Text>
	</Step>

	<Step enable="True" id="6" name="Go to Layout">
		<LayoutDestination value="SelectedLayout"/>
		<Layout id="240" name="UFD__UlaznaFakturaDobavljaca"/>
		<Animation value="None"/>
	</Step>

	<Step enable="True" id="22" name="Enter Find Mode">
		<Pause state="False"/>
	</Step>

	<Step enable="True" id="76" name="Set Field">
		<Calculation><![CDATA[$ulaznaFakturaID]]></Calculation>
		<Field table="UFD__UlaznaFakturaDobavljaca" id="1" name="PrimaryKey"/>
	</Step>

	<Step enable="True" id="31" name="Perform Find">
		<Restore state="False"/>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[Get ( FoundCount ) = 0]]></Calculation>
	</Step>
	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Response_AddError ( "NOT_FOUND_UFD" ; "UFD not found: " & $ulaznaFakturaID ; "" ; "{}" ; "" )]]></Calculation></Value>
	</Step>
	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[$isRoot]]></Calculation>
	</Step>
	<Step enable="True" id="25" name="Perform Script">
		<Script id="780" name="UTIL__FlushLog"/>
		<Calculation><![CDATA[JSONSetElement ( "{}" ; "traceID" ; $traceID ; JSONString )]]></Calculation>
	</Step>
	<Step enable="True" id="70" name="End If"/>
	<Step enable="True" id="103" name="Exit Script">
		<Calculation><![CDATA[Response_Finalize]]></Calculation>
	</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$dobavljacID</Name>
		<Value><Calculation><![CDATA[UFD__UlaznaFakturaDobavljaca::ForeignKeyDobavljacID]]></Calculation></Value>
	</Step>

	<Step enable="True" id="89" name="# (comment)">
		<Text>── Loop Primke ───────────────────────────────────────────────────────────</Text>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$count</Name>
		<Value><Calculation><![CDATA[ValueCount ( JSONListKeys ( $primkaIDs ; "" ) )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$i</Name>
		<Value><Calculation><![CDATA[0]]></Calculation></Value>
	</Step>

	<Step enable="True" id="71" name="Loop">
		<FlushType value="Always"/>
	</Step>

	<Step enable="True" id="72" name="Exit Loop If">
		<Calculation><![CDATA[$i >= $count]]></Calculation>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$primkaID</Name>
		<Value><Calculation><![CDATA[JSONGetElement ( $primkaIDs ; "[" & $i & "]" )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="6" name="Go to Layout">
		<LayoutDestination value="SelectedLayout"/>
		<Layout id="229" name="Dev Primke"/>
		<Animation value="None"/>
	</Step>

	<Step enable="True" id="22" name="Enter Find Mode">
		<Pause state="False"/>
	</Step>

	<Step enable="True" id="76" name="Set Field">
		<Calculation><![CDATA[$primkaID]]></Calculation>
		<Field table="Primke" id="1" name="PrimaryKey"/>
	</Step>

	<Step enable="True" id="31" name="Perform Find">
		<Restore state="False"/>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[Get ( FoundCount ) = 0]]></Calculation>
	</Step>
	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Response_AddWarning ( "NOT_FOUND_PRIMKA" ; "Primka not found: " & $primkaID ; "" ; JSONSetElement ( "{}" ; "primkaID" ; $primkaID ; JSONString ) ; "" )]]></Calculation></Value>
	</Step>
	<Step enable="True" id="69" name="Else If">
		<Calculation><![CDATA[Primke::ForeignKeyDobavljacID ≠ $dobavljacID]]></Calculation>
	</Step>
	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Response_AddWarning ( "CONFLICT_SUPPLIER" ; "Primka belongs to different supplier: " & Primke::BrojFaktureDobavljaca ; "" ; JSONSetElement ( "{}" ; "primkaID" ; $primkaID ; JSONString ) ; "" )]]></Calculation></Value>
	</Step>
	<Step enable="True" id="69" name="Else If">
		<Calculation><![CDATA[not IsEmpty ( Primke::ForeignKeyUlaznaFakturaID ) and Primke::ForeignKeyUlaznaFakturaID ≠ $ulaznaFakturaID]]></Calculation>
	</Step>
	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Response_AddWarning ( "CONFLICT_ALREADY_LINKED" ; "Primka already linked to another UFD: " & Primke::BrojFaktureDobavljaca ; "" ; JSONSetElement ( "{}" ; "primkaID" ; $primkaID ; JSONString ) ; "" )]]></Calculation></Value>
	</Step>
	<Step enable="True" id="69" name="Else">
	</Step>

	<Step enable="True" id="76" name="Set Field">
		<Calculation><![CDATA[$ulaznaFakturaID]]></Calculation>
		<Field table="Primke" id="18" name="ForeignKeyUlaznaFakturaID"/>
	</Step>

	<Step enable="True" id="76" name="Set Field">
		<Calculation><![CDATA["Priložena"]]></Calculation>
		<Field table="Primke" id="14" name="Status"/>
	</Step>

	<Step enable="True" id="75" name="Commit Records/Requests">
		<NoInteract state="True"/>
		<Option state="False"/>
		<ESSForceCommit state="False"/>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[Get ( LastError ) = 0]]></Calculation>
	</Step>
	<Step enable="True" id="141" name="Set Variable">
		<Name>$attachedCount</Name>
		<Value><Calculation><![CDATA[$attachedCount + 1]]></Calculation></Value>
	</Step>
	<Step enable="True" id="69" name="Else">
	</Step>
	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Response_AddWarning ( "COMMIT_FAILED" ; "Failed to attach primka: " & $primkaID & " (FM error " & Get ( LastError ) & ")" ; "" ; JSONSetElement ( "{}" ; "primkaID" ; $primkaID ; JSONString ) ; "" )]]></Calculation></Value>
	</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$i</Name>
		<Value><Calculation><![CDATA[$i + 1]]></Calculation></Value>
	</Step>

	<Step enable="True" id="73" name="End Loop"/>

	<Step enable="True" id="89" name="# (comment)">
		<Text>── Evaluate result ───────────────────────────────────────────────────────</Text>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[$attachedCount = 0]]></Calculation>
	</Step>
	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Response_AddError ( "NO_PRIMKE_ATTACHED" ; "No primke were successfully attached" ; "" ; $params ; "" )]]></Calculation></Value>
	</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Response_SetData ( JSONSetElement ( "{}" ; "attachedCount" ; $attachedCount ; JSONNumber ) )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Log.add ( "info" ; "UFD_ATTACH_DONE" ; "Attached " & $attachedCount & " of " & $count & " primke" ; $params )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[$isRoot]]></Calculation>
	</Step>
	<Step enable="True" id="25" name="Perform Script">
		<Script id="780" name="UTIL__FlushLog"/>
		<Calculation><![CDATA[JSONSetElement ( "{}" ; "traceID" ; $traceID ; JSONString )]]></Calculation>
	</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="103" name="Exit Script">
		<Calculation><![CDATA[Response_Finalize]]></Calculation>
	</Step>

</fmxmlsnippet>

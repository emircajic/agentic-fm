<fmxmlsnippet type="FMObjectList">

	<Step enable="True" id="89" name="# (comment)">
		<Text>PURPOSE: ONE-SHOT CLEANUP — Delete all KretanjeRobe records sourced from Primke (DokumentTip = "StavkeUlazneFakture").
Keeps all ServiceOrderLines and InvoiceLines entries (fiscal data).
Run once. Disable or delete this script after execution.</Text>
	</Step>

	<Step enable="True" id="85" name="Allow User Abort">
		<Set state="False"/>
	</Step>

	<Step enable="True" id="86" name="Set Error Capture">
		<Set state="True"/>
	</Step>

	<Step enable="True" id="89" name="# (comment)">
		<Text>── Navigate and find Primke-sourced entries ──────────────────────────────</Text>
	</Step>

	<Step enable="True" id="6" name="Go to Layout">
		<LayoutDestination value="SelectedLayout"/>
		<Layout id="228" name="Dev KR__KretanjeRobe"/>
		<Animation value="None"/>
	</Step>

	<Step enable="True" id="22" name="Enter Find Mode">
		<Pause state="False"/>
	</Step>

	<Step enable="True" id="76" name="Set Field">
		<Calculation><![CDATA["StavkeUlazneFakture"]]></Calculation>
		<Field table="KR__KretanjeRobe" id="19" name="DokumentTip"/>
	</Step>

	<Step enable="True" id="31" name="Perform Find">
		<Restore state="False"/>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$foundCount</Name>
		<Value><Calculation><![CDATA[Get ( FoundCount )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[$foundCount = 0]]></Calculation>
	</Step>
	<Step enable="True" id="103" name="Exit Script">
		<Calculation><![CDATA[JSONSetElement ( "{}" ;
	[ "status"     ; "success" ; JSONString ] ;
	[ "note"       ; "Nothing to delete — no StavkeUlazneFakture entries found" ; JSONString ] ;
	[ "deleted"    ; 0 ; JSONNumber ]
)]]></Calculation>
	</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="89" name="# (comment)">
		<Text>── Delete found set ──────────────────────────────────────────────────────</Text>
	</Step>

	<Step enable="True" id="10" name="Delete All Records">
		<NoInteract state="True"/>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$fmError</Name>
		<Value><Calculation><![CDATA[Get ( LastError )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[$fmError ≠ 0]]></Calculation>
	</Step>
	<Step enable="True" id="103" name="Exit Script">
		<Calculation><![CDATA[JSONSetElement ( "{}" ;
	[ "status"  ; "fail" ; JSONString ] ;
	[ "fmError" ; $fmError ; JSONNumber ] ;
	[ "note"    ; "Delete All Records failed — check record locks or privileges" ; JSONString ]
)]]></Calculation>
	</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="103" name="Exit Script">
		<Calculation><![CDATA[JSONSetElement ( "{}" ;
	[ "status"  ; "success" ; JSONString ] ;
	[ "deleted" ; $foundCount ; JSONNumber ]
)]]></Calculation>
	</Step>

</fmxmlsnippet>

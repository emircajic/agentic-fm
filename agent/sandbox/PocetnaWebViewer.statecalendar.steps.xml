<?xml version="1.0"?>
<fmxmlsnippet type="FMObjectList">
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[Substitute ( Get ( ScriptParameter ) ; "|" ; ¶ )]]></Calculation>
    </Value>
    <Name>$parametar</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[GetValue ( $parametar ; 1 )]]></Calculation>
    </Value>
    <Name>$verb</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[GetValue ( $parametar ; 2 )]]></Calculation>
    </Value>
    <Name>$verbData</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[Case ( JSONGetElementType ( Globals::StateCalendar ; "" ) = JSONObject ; Globals::StateCalendar ; "{}" )]]></Calculation>
    </Value>
    <Name>$state</Name>
  </Step>
  <Step enable="True" id="68" name="If">
    <Restore state="False"/>
    <Calculation><![CDATA[IsEmpty ( JSONGetElement ( $state ; "currentDate" ) ) or Left ( JSONGetElement ( $state ; "currentDate" ) ; 1 ) = "?"]]></Calculation>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[JSONSetElement ( $state ; "currentDate" ; date.format ( Get ( CurrentDate ) ; "yyyy-mm-dd" ) ; JSONString )]]></Calculation>
    </Value>
    <Name>$state</Name>
  </Step>
  <Step enable="True" id="70" name="End If"/>
  <Step enable="True" id="68" name="If">
    <Restore state="False"/>
    <Calculation><![CDATA[IsEmpty ( JSONGetElement ( $state ; "currentView" ) ) or Left ( JSONGetElement ( $state ; "currentView" ) ; 1 ) = "?"]]></Calculation>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[JSONSetElement ( $state ; "currentView" ; "weekly" ; JSONString )]]></Calculation>
    </Value>
    <Name>$state</Name>
  </Step>
  <Step enable="True" id="70" name="End If"/>
  <Step enable="True" id="68" name="If">
    <Restore state="False"/>
    <Calculation><![CDATA[IsEmpty ( JSONGetElement ( $state ; "displayType" ) ) or Left ( JSONGetElement ( $state ; "displayType" ) ; 1 ) = "?"]]></Calculation>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[JSONSetElement ( $state ; "displayType" ; "timeline" ; JSONString )]]></Calculation>
    </Value>
    <Name>$state</Name>
  </Step>
  <Step enable="True" id="70" name="End If"/>
  <Step enable="True" id="68" name="If">
    <Restore state="False"/>
    <Calculation><![CDATA[$verb = "init"]]></Calculation>
  </Step>
  <Step enable="True" id="76" name="Set Field">
    <Field table="Globals" id="38" name="StateCalendar"/>
    <Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
    <Calculation><![CDATA[$state]]></Calculation>
  </Step>
  <Step enable="True" id="1" name="Perform Script">
    <Calculated>
      <Calculation><![CDATA["RefreshWebViewer"]]></Calculation>
    </Calculated>
    <Calculation><![CDATA[.1]]></Calculation>
  </Step>
  <Step enable="True" id="103" name="Exit Script">
    <Calculation><![CDATA[""]]></Calculation>
  </Step>
  <Step enable="True" id="121" name="Else If">
    <Restore state="False"/>
    <Calculation><![CDATA[$verb = "exit"]]></Calculation>
  </Step>
  <Step enable="True" id="76" name="Set Field">
    <Field table="Globals" id="38" name="StateCalendar"/>
    <Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
    <Calculation><![CDATA[""]]></Calculation>
  </Step>
  <Step enable="True" id="103" name="Exit Script">
    <Calculation><![CDATA[""]]></Calculation>
  </Step>
  <Step enable="True" id="121" name="Else If">
    <Restore state="False"/>
    <Calculation><![CDATA[$verb = "navigate"]]></Calculation>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[JSONGetElement ( $state ; "currentView" )]]></Calculation>
    </Value>
    <Name>$currentView</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[JSDateToFMDate ( JSONGetElement ( $state ; "currentDate" ) )]]></Calculation>
    </Value>
    <Name>$currentDate</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[Case (
    $currentView = "daily" ; 1 ;
    $currentView = "weekly" ; 7 ;
    $currentView = "three_day" ; 3 ;
    1
)]]></Calculation>
    </Value>
    <Name>$change</Name>
  </Step>
  <Step enable="True" id="68" name="If">
    <Restore state="False"/>
    <Calculation><![CDATA[$verbData = "today"]]></Calculation>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[Get ( CurrentDate )]]></Calculation>
    </Value>
    <Name>$currentDate</Name>
  </Step>
  <Step enable="True" id="121" name="Else If">
    <Restore state="False"/>
    <Calculation><![CDATA[$verbData = "previous"]]></Calculation>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[$currentDate - $change]]></Calculation>
    </Value>
    <Name>$currentDate</Name>
  </Step>
  <Step enable="True" id="121" name="Else If">
    <Restore state="False"/>
    <Calculation><![CDATA[$verbData = "next"]]></Calculation>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[$currentDate + $change]]></Calculation>
    </Value>
    <Name>$currentDate</Name>
  </Step>
  <Step enable="True" id="70" name="End If"/>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[JSONSetElement ( $state ; "currentDate" ; date.format ( $currentDate ; "yyyy-mm-dd" ) ; JSONString )]]></Calculation>
    </Value>
    <Name>$state</Name>
  </Step>
  <Step enable="True" id="76" name="Set Field">
    <Field table="Globals" id="38" name="StateCalendar"/>
    <Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
    <Calculation><![CDATA[$state]]></Calculation>
  </Step>
  <Step enable="True" id="121" name="Else If">
    <Restore state="False"/>
    <Calculation><![CDATA[$verb = "view"]]></Calculation>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[JSONSetElement ( $state ; "currentView" ; $verbData ; JSONString )]]></Calculation>
    </Value>
    <Name>$state</Name>
  </Step>
  <Step enable="True" id="68" name="If">
    <Restore state="False"/>
    <Calculation><![CDATA[$verbData = "weekly"]]></Calculation>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[Let (
[
    currentDate = JSDateToFMDate ( JSONGetElement ( $state ; "currentDate" ) )
] ;
    currentDate - DayOfWeek ( currentDate ) + 2
)]]></Calculation>
    </Value>
    <Name>$datum</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[JSONSetElement ( $state ; "currentDate" ; FMDateToJSDate ( $datum ) ; JSONString )]]></Calculation>
    </Value>
    <Name>$state</Name>
  </Step>
  <Step enable="True" id="70" name="End If"/>
  <Step enable="True" id="76" name="Set Field">
    <Field table="Globals" id="38" name="StateCalendar"/>
    <Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
    <Calculation><![CDATA[$state]]></Calculation>
  </Step>
  <Step enable="True" id="121" name="Else If">
    <Restore state="False"/>
    <Calculation><![CDATA[$verb = "display"]]></Calculation>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[JSONSetElement ( $state ; "displayType" ; $verbData ; JSONString )]]></Calculation>
    </Value>
    <Name>$state</Name>
  </Step>
  <Step enable="True" id="76" name="Set Field">
    <Field table="Globals" id="38" name="StateCalendar"/>
    <Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
    <Calculation><![CDATA[$state]]></Calculation>
  </Step>
  <Step enable="True" id="70" name="End If"/>
  <Step enable="True" id="1" name="Perform Script">
    <Calculated>
      <Calculation><![CDATA["RefreshWebViewer"]]></Calculation>
    </Calculated>
    <Calculation><![CDATA[.1]]></Calculation>
  </Step>
</fmxmlsnippet>

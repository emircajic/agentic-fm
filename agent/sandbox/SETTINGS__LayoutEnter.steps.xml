<?xml version="1.0"?>
<fmxmlsnippet type="FMObjectList">
  <Step enable="True" id="89" name="# (comment)">
    <Text>PURPOSE: Initialize a shared per-layout settings draft on layout enter.</Text>
  </Step>
  <Step enable="True" id="86" name="Set Error Capture">
    <Set state="True"/>
  </Step>
  <Step enable="True" id="85" name="Allow User Abort">
    <Set state="False"/>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[Response_Init ( "{}" )]]></Calculation>
    </Value>
    <Name>$response</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[Get ( LayoutNumber )]]></Calculation>
    </Value>
    <Name>$layoutNumber</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA["layouts." & $layoutNumber]]></Calculation>
    </Value>
    <Name>$scopePrefix</Name>
  </Step>
  <Step enable="True" id="68" name="If">
    <Restore state="False"/>
    <Calculation><![CDATA[JSONGetElement ( $response ; "status" ) ≠ "fail"]]></Calculation>
  </Step>
  <Step enable="True" id="1" name="Perform Script">
    <Calculated>
      <Calculation><![CDATA["SETTINGS__EnsureLoaded"]]></Calculation>
    </Calculated>
    <Calculation><![CDATA[""]]></Calculation>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[Get ( ScriptResult )]]></Calculation>
    </Value>
    <Name>$ensureResult</Name>
  </Step>
  <Step enable="True" id="68" name="If">
    <Restore state="False"/>
    <Calculation><![CDATA[JSONGetElement ( $ensureResult ; "status" ) = "fail"]]></Calculation>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[Response_AddError (
    "SETTINGS_LAYOUT_ENTER_ENSURE_FAILED" ;
    "Unable to ensure settings cache before creating layout draft." ;
    "SETTINGS__EnsureLoaded" ;
    $ensureResult ;
    Get ( ScriptName )
)]]></Calculation>
    </Value>
    <Name>$response</Name>
  </Step>
  <Step enable="True" id="70" name="End If"/>
  <Step enable="True" id="70" name="End If"/>
  <Step enable="True" id="68" name="If">
    <Restore state="False"/>
    <Calculation><![CDATA[JSONGetElement ( $response ; "status" ) ≠ "fail"]]></Calculation>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[Case ( JSONGetElementType ( $$LAYOUT_SETTINGS ; "" ) = JSONObject ; $$LAYOUT_SETTINGS ; "{}" )]]></Calculation>
    </Value>
    <Name>$$LAYOUT_SETTINGS</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[JSONGetElement ( $$LAYOUT_SETTINGS ; $layoutNumber )]]></Calculation>
    </Value>
    <Name>$existingDraft</Name>
  </Step>
  <Step enable="True" id="68" name="If">
    <Restore state="False"/>
    <Calculation><![CDATA[JSONGetElementType ( $existingDraft ; "" ) = JSONObject]]></Calculation>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[$existingDraft]]></Calculation>
    </Value>
    <Name>$draft</Name>
  </Step>
  <Step enable="True" id="69" name="Else">
    <Restore state="False"/>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[Settings_GetObject ( $scopePrefix ; "{}" )]]></Calculation>
    </Value>
    <Name>$draft</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[JSONSetElement ( $$LAYOUT_SETTINGS ; $layoutNumber ; $draft ; JSONObject )]]></Calculation>
    </Value>
    <Name>$$LAYOUT_SETTINGS</Name>
  </Step>
  <Step enable="True" id="70" name="End If"/>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[Response_SetData (
    JSONSetElement (
        "{}" ;
        [ "layoutNumber" ; $layoutNumber ; JSONNumber ] ;
        [ "scope" ; $scopePrefix ; JSONString ] ;
        [ "draft" ; $draft ; JSONObject ]
    )
)]]></Calculation>
    </Value>
    <Name>$response</Name>
  </Step>
  <Step enable="True" id="70" name="End If"/>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[Response_Finalize]]></Calculation>
    </Value>
    <Name>$response</Name>
  </Step>
  <Step enable="True" id="103" name="Exit Script">
    <Calculation><![CDATA[$response]]></Calculation>
  </Step>
</fmxmlsnippet>

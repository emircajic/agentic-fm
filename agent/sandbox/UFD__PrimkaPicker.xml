<fmxmlsnippet type="FMObjectList">

	<Step enable="True" id="89" name="# (comment)">
		<Text>PURPOSE: Find unattached StavkePrimke for a supplier, group by Primka, and push the result as JSON to the Primka picker web viewer.</Text>
	</Step>
	<Step enable="False" id="61" name="Insert Text">
		<SelectAll state="False"/>
		<Text>PARAMS: ulaznaFakturaID (text, required) | dobavljacID (text, required) | callbackScript (text, required) | callbackContext (object, optional) | dateFrom (date, optional)
RETURNS: data.groupCount (number) | data.stavkeCount (number)</Text>
		<Field>$README</Field>
	</Step>

	<Step enable="True" id="85" name="Allow User Abort">
		<Set state="False"/>
	</Step>
	<Step enable="True" id="86" name="Set Error Capture">
		<Set state="True"/>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Params.parse ( Get ( ScriptParameter ) ; "ulaznaFakturaID|dobavljacID|callbackScript|callbackContext|dateFrom" )]]></Calculation></Value>
	</Step>
	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Response_Init ( "{}" )]]></Calculation></Value>
	</Step>
	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Log.add ( "info" ; "UFD_PRIMKA_PICKER_START" ; "Building picker for dobavljacID " & $dobavljacID & " ufdID " & $ulaznaFakturaID ; $params )]]></Calculation></Value>
	</Step>

	<Step enable="False" id="89" name="# (comment)">
		<Text>MARK: Validate</Text>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[IsEmpty ( $ulaznaFakturaID )]]></Calculation>
	</Step>
		<Step enable="True" id="141" name="Set Variable">
			<Name>$void</Name>
			<Value><Calculation><![CDATA[Response_AddError ( "MISSING_PARAM" ; "ulaznaFakturaID is required" ; "ulaznaFakturaID" ; "{}" ; "" )]]></Calculation></Value>
		</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[IsEmpty ( $dobavljacID )]]></Calculation>
	</Step>
		<Step enable="True" id="141" name="Set Variable">
			<Name>$void</Name>
			<Value><Calculation><![CDATA[Response_AddError ( "MISSING_PARAM" ; "dobavljacID is required" ; "dobavljacID" ; "{}" ; "" )]]></Calculation></Value>
		</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[Response_HasErrors ( $response )]]></Calculation>
	</Step>
		<Step enable="True" id="68" name="If">
			<Calculation><![CDATA[$isRoot]]></Calculation>
		</Step>
			<Step enable="True" id="1" name="Perform Script">
				<Script id="0" name="UTIL__FlushLog"/>
				<Calculation><![CDATA[JSONSetElement ( "{}" ; "traceID" ; $traceID ; JSONString )]]></Calculation>
			</Step>
		<Step enable="True" id="70" name="End If"/>
		<Step enable="True" id="103" name="Exit Script">
			<Calculation><![CDATA[Response_Finalize]]></Calculation>
		</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="False" id="89" name="# (comment)">
		<Text>MARK: Find unattached StavkePrimke for this supplier</Text>
	</Step>

	<Step enable="True" id="6" name="Go to Layout">
		<LayoutDestination value="SelectedLayout"/>
		<Layout id="227" name="Dev StavkePrimke"/>
		<Animation value="None"/>
	</Step>

	<Step enable="True" id="22" name="Enter Find Mode">
		<Pause state="False"/>
	</Step>
	<Step enable="True" id="76" name="Set Field">
		<Calculation><![CDATA["="]]></Calculation>
		<Field table="StavkePrimke" id="32" name="ForeignKeyUlaznaFakturaID"/>
	</Step>
	<Step enable="True" id="76" name="Set Field">
		<Calculation><![CDATA[$dobavljacID]]></Calculation>
		<Field table="Primke" id="6" name="ForeignKeyDobavljacID"/>
	</Step>
	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[not IsEmpty ( $dateFrom )]]></Calculation>
	</Step>
		<Step enable="True" id="76" name="Set Field">
			<Calculation><![CDATA[">=" & $dateFrom]]></Calculation>
			<Field table="Primke" id="8" name="DatumPrimitka"/>
		</Step>
	<Step enable="True" id="70" name="End If"/>
	<Step enable="True" id="28" name="Perform Find"/>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$foundCount</Name>
		<Value><Calculation><![CDATA[Get ( FoundCount )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[$foundCount = 0]]></Calculation>
	</Step>
		<Step enable="True" id="141" name="Set Variable">
			<Name>$void</Name>
			<Value><Calculation><![CDATA[Response_AddError ( "NO_STAVKE" ; "No available StavkePrimke found for dobavljacID: " & $dobavljacID ; "" ; "{}" ; "" )]]></Calculation></Value>
		</Step>
		<Step enable="True" id="68" name="If">
			<Calculation><![CDATA[$isRoot]]></Calculation>
		</Step>
			<Step enable="True" id="1" name="Perform Script">
				<Script id="0" name="UTIL__FlushLog"/>
				<Calculation><![CDATA[JSONSetElement ( "{}" ; "traceID" ; $traceID ; JSONString )]]></Calculation>
			</Step>
		<Step enable="True" id="70" name="End If"/>
		<Step enable="True" id="103" name="Exit Script">
			<Calculation><![CDATA[Response_Finalize]]></Calculation>
		</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="False" id="89" name="# (comment)">
		<Text>MARK: Sort — DatumPrimitka DESC, BrojFaktureDobavljaca ASC, NazivArtikla ASC</Text>
	</Step>

	<Step enable="True" id="39" name="Sort Records">
		<NoInteract state="True"/>
		<Restore state="True"/>
		<SortList Maintain="False" value="True">
			<Sort type="Descending">
				<PrimaryField>
					<Field table="Primke" id="8" name="DatumPrimitka"/>
				</PrimaryField>
			</Sort>
			<Sort type="Ascending">
				<PrimaryField>
					<Field table="Primke" id="7" name="BrojFaktureDobavljaca"/>
				</PrimaryField>
			</Sort>
			<Sort type="Ascending">
				<PrimaryField>
					<Field table="Artikli" id="7" name="NazivArtikla"/>
				</PrimaryField>
			</Sort>
		</SortList>
	</Step>

	<Step enable="False" id="89" name="# (comment)">
		<Text>MARK: Build grouped JSON — group StavkePrimke by Primka</Text>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$groups</Name>
		<Value><Calculation><![CDATA["[]"]]></Calculation></Value>
	</Step>
	<Step enable="True" id="141" name="Set Variable">
		<Name>$currentStavke</Name>
		<Value><Calculation><![CDATA["[]"]]></Calculation></Value>
	</Step>
	<Step enable="True" id="141" name="Set Variable">
		<Name>$currentGroup</Name>
		<Value><Calculation><![CDATA["{}"]]></Calculation></Value>
	</Step>
	<Step enable="True" id="141" name="Set Variable">
		<Name>$lastPrimkaPK</Name>
		<Value><Calculation><![CDATA[""]]></Calculation></Value>
	</Step>
	<Step enable="True" id="141" name="Set Variable">
		<Name>$groupCount</Name>
		<Value><Calculation><![CDATA[0]]></Calculation></Value>
	</Step>
	<Step enable="True" id="141" name="Set Variable">
		<Name>$totalStavke</Name>
		<Value><Calculation><![CDATA[0]]></Calculation></Value>
	</Step>

	<Step enable="True" id="16" name="Go to Record/Request/Page">
		<RowPageLocation value="First"/>
	</Step>

	<Step enable="True" id="71" name="Loop">
		<FlushType value="Always"/>
	</Step>

		<Step enable="True" id="141" name="Set Variable">
			<Name>$primkaPK</Name>
			<Value><Calculation><![CDATA[StavkePrimke::ForeignKeyPrimkaID]]></Calculation></Value>
		</Step>

		<Step enable="True" id="68" name="If">
			<Calculation><![CDATA[$primkaPK ≠ $lastPrimkaPK]]></Calculation>
		</Step>
			<Step enable="True" id="68" name="If">
				<Calculation><![CDATA[not IsEmpty ( $lastPrimkaPK )]]></Calculation>
			</Step>
				<Step enable="True" id="141" name="Set Variable">
					<Name>$currentGroup</Name>
					<Value><Calculation><![CDATA[JSONSetElement ( $currentGroup ; "stavke" ; $currentStavke ; JSONArray )]]></Calculation></Value>
				</Step>
				<Step enable="True" id="141" name="Set Variable">
					<Name>$groups</Name>
					<Value><Calculation><![CDATA[JSONSetElement ( $groups ; "[+]" ; $currentGroup ; JSONObject )]]></Calculation></Value>
				</Step>
				<Step enable="True" id="141" name="Set Variable">
					<Name>$groupCount</Name>
					<Value><Calculation><![CDATA[$groupCount + 1]]></Calculation></Value>
				</Step>
			<Step enable="True" id="70" name="End If"/>

			<Step enable="True" id="141" name="Set Variable">
				<Name>$currentGroup</Name>
				<Value><Calculation><![CDATA[JSONSetElement ( "{}" ;
	[ "primkaPK"    ; $primkaPK                           ; JSONString ] ;
	[ "brojFakture" ; Primke::BrojFaktureDobavljaca       ; JSONString ] ;
	[ "datum"       ; GetAsText ( Primke::DatumPrimitka ) ; JSONString ]
)]]></Calculation></Value>
			</Step>
			<Step enable="True" id="141" name="Set Variable">
				<Name>$currentStavke</Name>
				<Value><Calculation><![CDATA["[]"]]></Calculation></Value>
			</Step>
			<Step enable="True" id="141" name="Set Variable">
				<Name>$lastPrimkaPK</Name>
				<Value><Calculation><![CDATA[$primkaPK]]></Calculation></Value>
			</Step>
		<Step enable="True" id="70" name="End If"/>

		<Step enable="True" id="141" name="Set Variable">
			<Name>$stavkaObj</Name>
			<Value><Calculation><![CDATA[JSONSetElement ( "{}" ;
	[ "stavkaPK"       ; StavkePrimke::PrimaryKey                 ; JSONString ] ;
	[ "sifra"          ; Artikli::SifraArtikla                    ; JSONString ] ;
	[ "naziv"          ; Artikli::NazivArtikla                    ; JSONString ] ;
	[ "kolicina"       ; StavkePrimke::Kolicina                   ; JSONNumber ] ;
	[ "nabavna"        ; StavkePrimke::NabavnaCijenaStavke        ; JSONNumber ] ;
	[ "prodajna"       ; StavkePrimke::ProdajnaCijena             ; JSONNumber ] ;
	[ "qtyAvailable"   ; StavkePrimke::QtyAvailable_Calculation   ; JSONNumber ] ;
	[ "transferStatus" ; StavkePrimke::TransferStatus_Display     ; JSONString ]
)]]></Calculation></Value>
		</Step>
		<Step enable="True" id="141" name="Set Variable">
			<Name>$currentStavke</Name>
			<Value><Calculation><![CDATA[JSONSetElement ( $currentStavke ; "[+]" ; $stavkaObj ; JSONObject )]]></Calculation></Value>
		</Step>
		<Step enable="True" id="141" name="Set Variable">
			<Name>$totalStavke</Name>
			<Value><Calculation><![CDATA[$totalStavke + 1]]></Calculation></Value>
		</Step>

		<Step enable="True" id="16" name="Go to Record/Request/Page">
			<RowPageLocation value="Next"/>
			<Exit state="True"/>
		</Step>

	<Step enable="True" id="73" name="End Loop"/>

	<Step enable="False" id="89" name="# (comment)">
		<Text>Flush the last group</Text>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[not IsEmpty ( $lastPrimkaPK )]]></Calculation>
	</Step>
		<Step enable="True" id="141" name="Set Variable">
			<Name>$currentGroup</Name>
			<Value><Calculation><![CDATA[JSONSetElement ( $currentGroup ; "stavke" ; $currentStavke ; JSONArray )]]></Calculation></Value>
		</Step>
		<Step enable="True" id="141" name="Set Variable">
			<Name>$groups</Name>
			<Value><Calculation><![CDATA[JSONSetElement ( $groups ; "[+]" ; $currentGroup ; JSONObject )]]></Calculation></Value>
		</Step>
		<Step enable="True" id="141" name="Set Variable">
			<Name>$groupCount</Name>
			<Value><Calculation><![CDATA[$groupCount + 1]]></Calculation></Value>
		</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="False" id="89" name="# (comment)">
		<Text>MARK: Build payload and open picker card</Text>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$payload</Name>
		<Value><Calculation><![CDATA[JSONSetElement ( "{}" ;
	[ "ufdID"           ; $ulaznaFakturaID                               ; JSONString ] ;
	[ "groups"          ; $groups                                        ; JSONArray  ] ;
	[ "groupCount"      ; $groupCount                                    ; JSONNumber ] ;
	[ "stavkeCount"     ; $totalStavke                                   ; JSONNumber ] ;
	[ "callbackScript"  ; $callbackScript                                ; JSONString ] ;
	[ "callbackContext" ; If ( IsEmpty ( $callbackContext ) ; JSONSetElement ( "{}" ; "ulaznaFakturaID" ; $ulaznaFakturaID ; JSONString ) ; $callbackContext ) ; JSONObject ]
)]]></Calculation></Value>
	</Step>

	<Step enable="True" id="1" name="Perform Script">
		<Script id="0" name="PICKER__Open"/>
		<Calculation><![CDATA[$payload]]></Calculation>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Response_SetData ( JSONSetElement ( "{}" ;
	[ "groupCount"  ; $groupCount  ; JSONNumber ] ;
	[ "stavkeCount" ; $totalStavke ; JSONNumber ]
) )]]></Calculation></Value>
	</Step>
	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Log.add ( "info" ; "UFD_PRIMKA_PICKER_DONE" ; "Opened picker with " & $groupCount & " primke, " & $totalStavke & " stavke for dobavljacID " & $dobavljacID ; $params )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[$isRoot]]></Calculation>
	</Step>
		<Step enable="True" id="1" name="Perform Script">
			<Script id="0" name="UTIL__FlushLog"/>
			<Calculation><![CDATA[JSONSetElement ( "{}" ; "traceID" ; $traceID ; JSONString )]]></Calculation>
		</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="103" name="Exit Script">
		<Calculation><![CDATA[Response_Finalize]]></Calculation>
	</Step>

</fmxmlsnippet>

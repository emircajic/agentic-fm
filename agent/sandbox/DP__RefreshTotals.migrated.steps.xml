<?xml version="1.0"?>
<fmxmlsnippet type="FMObjectList">
  <Step enable="True" id="85" name="Allow User Abort">
    <Set state="False"/>
  </Step>
  <Step enable="True" id="86" name="Set Error Capture">
    <Set state="True"/>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Name>$pologID</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[jsonToVars(Get(ScriptParameter);"local")]]></Calculation>
    </Value>
    <Name>$void</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA["[]"]]></Calculation>
    </Value>
    <Name>$errors</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[False]]></Calculation>
    </Value>
    <Name>$exit</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[0]]></Calculation>
    </Value>
    <Name>$ukupnoGotovina</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[0]]></Calculation>
    </Value>
    <Name>$ukupnoKartice</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[0]]></Calculation>
    </Value>
    <Name>$ukupnoPolog</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[Settings_Get ( "polozi.pologUkljucujeKartice" ; "" )]]></Calculation>
    </Value>
    <Name>$ukljuciKartice</Name>
  </Step>
  <Step enable="True" id="68" name="If">
    <Restore state="False"/>
    <Calculation><![CDATA[IsEmpty ( $pologID )]]></Calculation>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[ JSONSetElement ( $errors ; "[+]" ; "Nedostaje pologID" ; JSONString )]]></Calculation>
    </Value>
    <Name>$errors</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[True]]></Calculation>
    </Value>
    <Name>$exit</Name>
  </Step>
  <Step enable="True" id="70" name="End If"/>
  <Step enable="True" id="68" name="If">
    <Restore state="False"/>
    <Calculation><![CDATA[$exit]]></Calculation>
  </Step>
  <Step enable="True" id="103" name="Exit Script">
    <Calculation><![CDATA[JSONSetElement ( "{}" ;
                            [ "status" ; "fail" ; JSONString ] ;
                            [ "ukupnoGotovina" ; 0 ; JSONNumber ] ;
                            [ "ukupnoKartice" ; 0 ; JSONNumber ] ;
                            [ "ukupnoPolog" ; 0 ; JSONNumber ] ;
                            [ "errors" ; $errors ; JSONArray ]
                        )]]></Calculation>
  </Step>
  <Step enable="True" id="70" name="End If"/>
  <Step enable="True" id="6" name="Go to Layout">
    <LayoutDestination value="SelectedLayout"/>
    <Layout id="243" name="DP__DnevniPolog"/>
    <Animation value=""/>
  </Step>
  <Step enable="True" id="22" name="Enter Find Mode">
    <Pause state="False"/>
  </Step>
  <Step enable="True" id="76" name="Set Field">
    <Field table="DP__DnevniPolog" id="1" name="PrimaryKey"/>
    <Calculation><![CDATA[$pologID]]></Calculation>
  </Step>
  <Step enable="True" id="28" name="Perform Find"/>
  <Step enable="True" id="68" name="If">
    <Restore state="False"/>
    <Calculation><![CDATA[Get(FoundCount) = 0]]></Calculation>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[JSONSetElement ( $errors ; "[+]" ; "Polog nije pronađen" ; JSONString )]]></Calculation>
    </Value>
    <Name>$errors</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[True]]></Calculation>
    </Value>
    <Name>$exit</Name>
  </Step>
  <Step enable="True" id="70" name="End If"/>
  <Step enable="True" id="68" name="If">
    <Restore state="False"/>
    <Calculation><![CDATA[not $exit and DP__DnevniPolog::Status ≠ "Otvoren"]]></Calculation>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[JSONSetElement ( $errors ; "[+]" ; "Polog nije otvoren." ; JSONString )]]></Calculation>
    </Value>
    <Name>$errors</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[True]]></Calculation>
    </Value>
    <Name>$exit</Name>
  </Step>
  <Step enable="True" id="70" name="End If"/>
  <Step enable="True" id="68" name="If">
    <Restore state="False"/>
    <Calculation><![CDATA[$exit]]></Calculation>
  </Step>
  <Step enable="True" id="103" name="Exit Script">
    <Calculation><![CDATA[JSONSetElement ( "{}" ;
                            [ "status" ; "fail" ; JSONString ] ;
                            [ "ukupnoGotovina" ; 0 ; JSONNumber ] ;
                            [ "ukupnoKartice" ; 0 ; JSONNumber ] ;
                            [ "ukupnoPolog" ; 0 ; JSONNumber ] ;
                            [ "errors" ; $errors ; JSONArray ]
                        )]]></Calculation>
  </Step>
  <Step enable="True" id="70" name="End If"/>
  <Step enable="True" id="76" name="Set Field">
    <Field table="DP__DnevniPolog" id="11" name="UkupnoGotovinaRoba"/>
    <Calculation><![CDATA[ExecuteSQL (
                    "SELECT SUM(UkupnoMP_Roba*SignMultiplier)
                     FROM I__INVOICES
                     WHERE ForeignKeyPologID = ?
                       AND NacinPlacanja = 'Gotovina'" ;
                    "" ; "" ;
                    $pologID
                )]]></Calculation>
  </Step>
  <Step enable="True" id="76" name="Set Field">
    <Field table="DP__DnevniPolog" id="12" name="UkupnoKarticeRoba"/>
    <Calculation><![CDATA[ExecuteSQL (
                    "SELECT SUM(UkupnoMP_Roba*SignMultiplier)
                     FROM I__INVOICES
                     WHERE ForeignKeyPologID = ?
                       AND NacinPlacanja = 'Kartica'" ;
                    "" ; "" ;
                    $pologID
                )]]></Calculation>
  </Step>
  <Step enable="True" id="76" name="Set Field">
    <Field table="DP__DnevniPolog" id="13" name="UkupnoPologRoba"/>
    <Calculation><![CDATA[If($ukljuciKartice; DP__DnevniPolog::UkupnoGotovinaRoba+DP__DnevniPolog::UkupnoKarticeRoba;DP__DnevniPolog::UkupnoGotovinaRoba)]]></Calculation>
  </Step>
  <Step enable="True" id="76" name="Set Field">
    <Field table="DP__DnevniPolog" id="8" name="UkupnoGotovina"/>
    <Calculation><![CDATA[ExecuteSQL (
                    "SELECT SUM(IznosFakture*SignMultiplier)
                     FROM I__INVOICES
                     WHERE ForeignKeyPologID = ?
                       AND NacinPlacanja = 'Gotovina'" ;
                    "" ; "" ;
                    $pologID
                )]]></Calculation>
  </Step>
  <Step enable="True" id="76" name="Set Field">
    <Field table="DP__DnevniPolog" id="9" name="UkupnoKartice"/>
    <Calculation><![CDATA[ExecuteSQL (
                    "SELECT SUM(IznosFakture*SignMultiplier)
                     FROM I__INVOICES
                     WHERE ForeignKeyPologID = ?
                       AND NacinPlacanja = 'Kartica'" ;
                    "" ; "" ;
                    $pologID
                )]]></Calculation>
  </Step>
  <Step enable="True" id="76" name="Set Field">
    <Field table="DP__DnevniPolog" id="14" name="UkupnoGotovinaUsluga"/>
    <Calculation><![CDATA[DP__DnevniPolog::UkupnoGotovina - DP__DnevniPolog::UkupnoGotovinaRoba]]></Calculation>
  </Step>
  <Step enable="True" id="76" name="Set Field">
    <Field table="DP__DnevniPolog" id="15" name="UkupnoKarticeUsluga"/>
    <Calculation><![CDATA[DP__DnevniPolog::UkupnoKartice - DP__DnevniPolog::UkupnoKarticeRoba]]></Calculation>
  </Step>
  <Step enable="True" id="75" name="Commit Records/Requests">
    <WithDialog state="False"/>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[Get(LastError)]]></Calculation>
    </Value>
    <Name>$lastError</Name>
  </Step>
  <Step enable="True" id="68" name="If">
    <Restore state="False"/>
    <Calculation><![CDATA[$lastError ≠ 0]]></Calculation>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[JSONSetElement ( $errors ; "[+]" ; "Greška pri ažuriranju pologa" ; JSONString )]]></Calculation>
    </Value>
    <Name>$errors</Name>
  </Step>
  <Step enable="True" id="103" name="Exit Script">
    <Calculation><![CDATA[JSONSetElement ( "{}" ;
                            [ "status" ; "fail" ; JSONString ] ;
                            [ "ukupnoGotovina" ; 0 ; JSONNumber ] ;
                            [ "ukupnoKartice" ; 0 ; JSONNumber ] ;
                            [ "ukupnoPolog" ; 0 ; JSONNumber ] ;
                            [ "errors" ; $errors ; JSONArray ]
                        )]]></Calculation>
  </Step>
  <Step enable="True" id="70" name="End If"/>
  <Step enable="True" id="103" name="Exit Script">
    <Calculation><![CDATA[JSONSetElement ( "{}" ;
                    [ "status" ; "success" ; JSONString ] ;
                    [ "ukupnoGotovina" ; $ukupnoGotovina ; JSONNumber ] ;
                    [ "ukupnoKartice" ; $ukupnoKartice ; JSONNumber ] ;
                    [ "ukupnoPolog" ; $ukupnoPolog ; JSONNumber ] ;
                    [ "errors" ; $errors ; JSONArray ]
                )]]></Calculation>
  </Step>
</fmxmlsnippet>

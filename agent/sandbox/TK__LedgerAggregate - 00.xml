<?xml version="1.0"?>
<fmxmlsnippet type="FMObjectList">
  <Step enable="True" id="89" name="# (comment)">
    <Text>PURPOSE: Aggregate donos, zaduzenja, and razduzenja rows into one ledger result.</Text>
  </Step>
  <Step enable="False" id="89" name="# (comment)">
    <Text>// Expects JSON: { "companyID": &lt;text&gt;, "datumOd": &lt;date&gt;, "datumDo": &lt;date&gt; }</Text>
  </Step>
  <Step enable="False" id="89" name="# (comment)">
    <Text>// Returns JSON: { "status": "success|fail", "rows": [], "errors": [] }</Text>
  </Step>
  <Step enable="True" id="89" name="# (comment)"/>
  <Step enable="True" id="85" name="Allow User Abort">
    <Set state="False"/>
  </Step>
  <Step enable="True" id="86" name="Set Error Capture">
    <Set state="True"/>
  </Step>
  <Step enable="True" id="89" name="# (comment)"/>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[Get ( ScriptParameter )]]></Calculation>
    </Value>
    <Name>$param</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[JSONGetElement ( $param ; "companyID" )]]></Calculation>
    </Value>
    <Name>$companyID</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[JSONGetElement ( $param ; "datumOd" )]]></Calculation>
    </Value>
    <Name>$datumOd</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[JSONGetElement ( $param ; "datumDo" )]]></Calculation>
    </Value>
    <Name>$datumDo</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA["[]"]]></Calculation>
    </Value>
    <Name>$errors</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA["[]"]]></Calculation>
    </Value>
    <Name>$rows</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[False]]></Calculation>
    </Value>
    <Name>$exit</Name>
  </Step>
  <Step enable="True" id="89" name="# (comment)"/>
  <Step enable="False" id="89" name="# (comment)">
    <Text>// Validate input</Text>
  </Step>
  <Step enable="True" id="68" name="If">
    <Restore state="False"/>
    <Calculation><![CDATA[IsEmpty ( $companyID )]]></Calculation>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[JSONSetElement ( $errors ; "[+]" ; "Nedostaje companyID" ; JSONString )]]></Calculation>
    </Value>
    <Name>$errors</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[True]]></Calculation>
    </Value>
    <Name>$exit</Name>
  </Step>
  <Step enable="True" id="70" name="End If"/>
  <Step enable="True" id="68" name="If">
    <Restore state="False"/>
    <Calculation><![CDATA[IsEmpty ( $datumOd )]]></Calculation>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[JSONSetElement ( $errors ; "[+]" ; "Nedostaje datumOd" ; JSONString )]]></Calculation>
    </Value>
    <Name>$errors</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[True]]></Calculation>
    </Value>
    <Name>$exit</Name>
  </Step>
  <Step enable="True" id="70" name="End If"/>
  <Step enable="True" id="68" name="If">
    <Restore state="False"/>
    <Calculation><![CDATA[IsEmpty ( $datumDo )]]></Calculation>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[JSONSetElement ( $errors ; "[+]" ; "Nedostaje datumDo" ; JSONString )]]></Calculation>
    </Value>
    <Name>$errors</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[True]]></Calculation>
    </Value>
    <Name>$exit</Name>
  </Step>
  <Step enable="True" id="70" name="End If"/>
  <Step enable="True" id="68" name="If">
    <Restore state="False"/>
    <Calculation><![CDATA[not $exit and GetAsDate ( $datumOd ) > GetAsDate ( $datumDo )]]></Calculation>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[JSONSetElement ( $errors ; "[+]" ; "datumOd ne može biti veći od datumDo" ; JSONString )]]></Calculation>
    </Value>
    <Name>$errors</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[True]]></Calculation>
    </Value>
    <Name>$exit</Name>
  </Step>
  <Step enable="True" id="70" name="End If"/>
  <Step enable="True" id="68" name="If">
    <Restore state="False"/>
    <Calculation><![CDATA[$exit]]></Calculation>
  </Step>
  <Step enable="True" id="103" name="Exit Script">
    <Calculation><![CDATA[JSONSetElement ( "{}" ;
	[ "status" ; "fail" ; JSONString ] ;
	[ "rows" ; $rows ; JSONArray ] ;
	[ "errors" ; $errors ; JSONArray ]
)]]></Calculation>
  </Step>
  <Step enable="True" id="70" name="End If"/>
  <Step enable="True" id="89" name="# (comment)"/>
  <Step enable="False" id="89" name="# (comment)">
    <Text>// 1. DONOS</Text>
  </Step>
  <Step enable="True" id="1" name="Perform Script">
    <Calculation><![CDATA[JSONSetElement ( "{}" ;
	[ "companyID" ; $companyID ; JSONString ] ;
	[ "datumOd" ; $datumOd ; JSONString ]
)]]></Calculation>
    <Script id="707" name="TK__GetDonos"/>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[Get ( ScriptResult )]]></Calculation>
    </Value>
    <Name>$donosResult</Name>
  </Step>
  <Step enable="True" id="68" name="If">
    <Restore state="False"/>
    <Calculation><![CDATA[JSONGetElement ( $donosResult ; "status" ) ≠ "success"]]></Calculation>
  </Step>
  <Step enable="True" id="103" name="Exit Script">
    <Calculation><![CDATA[JSONSetElement ( "{}" ;
	[ "status" ; "fail" ; JSONString ] ;
	[ "rows" ; $rows ; JSONArray ] ;
	[ "errors" ; JSONGetElement ( $donosResult ; "errors" ) ; JSONArray ]
)]]></Calculation>
  </Step>
  <Step enable="True" id="70" name="End If"/>
  <Step enable="True" id="89" name="# (comment)"/>
  <Step enable="False" id="89" name="# (comment)">
    <Text>// 2. ZADUŽENJA</Text>
  </Step>
  <Step enable="True" id="1" name="Perform Script">
    <Calculation><![CDATA[JSONSetElement ( "{}" ;
	[ "companyID" ; $companyID ; JSONString ] ;
	[ "datumOd" ; $datumOd ; JSONString ] ;
	[ "datumDo" ; $datumDo ; JSONString ]
)]]></Calculation>
    <Script id="708" name="TK__GetZaduzenja"/>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[Get ( ScriptResult )]]></Calculation>
    </Value>
    <Name>$zaduzenjaResult</Name>
  </Step>
  <Step enable="True" id="68" name="If">
    <Restore state="False"/>
    <Calculation><![CDATA[JSONGetElement ( $zaduzenjaResult ; "status" ) ≠ "success"]]></Calculation>
  </Step>
  <Step enable="True" id="103" name="Exit Script">
    <Calculation><![CDATA[JSONSetElement ( "{}" ;
	[ "status" ; "fail" ; JSONString ] ;
	[ "rows" ; $rows ; JSONArray ] ;
	[ "errors" ; JSONGetElement ( $zaduzenjaResult ; "errors" ) ; JSONArray ]
)]]></Calculation>
  </Step>
  <Step enable="True" id="70" name="End If"/>
  <Step enable="True" id="89" name="# (comment)"/>
  <Step enable="False" id="89" name="# (comment)">
    <Text>// 3. RAZDUŽENJA</Text>
  </Step>
  <Step enable="True" id="1" name="Perform Script">
    <Calculation><![CDATA[JSONSetElement ( "{}" ;
	[ "companyID" ; $companyID ; JSONString ] ;
	[ "datumOd" ; $datumOd ; JSONString ] ;
	[ "datumDo" ; $datumDo ; JSONString ]
)]]></Calculation>
    <Script id="709" name="TK__GetRazduzenja"/>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[Get ( ScriptResult )]]></Calculation>
    </Value>
    <Name>$razduzenjaResult</Name>
  </Step>
  <Step enable="True" id="68" name="If">
    <Restore state="False"/>
    <Calculation><![CDATA[JSONGetElement ( $razduzenjaResult ; "status" ) ≠ "success"]]></Calculation>
  </Step>
  <Step enable="True" id="103" name="Exit Script">
    <Calculation><![CDATA[JSONSetElement ( "{}" ;
	[ "status" ; "fail" ; JSONString ] ;
	[ "rows" ; $rows ; JSONArray ] ;
	[ "errors" ; JSONGetElement ( $razduzenjaResult ; "errors" ) ; JSONArray ]
)]]></Calculation>
  </Step>
  <Step enable="True" id="70" name="End If"/>
  <Step enable="True" id="89" name="# (comment)"/>
  <Step enable="False" id="89" name="# (comment)">
    <Text>// 4. MERGE</Text>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[JSONMergeArrays (
	JSONGetElement ( $zaduzenjaResult ; "rows" ) ;
	JSONGetElement ( $razduzenjaResult ; "rows" )
)]]></Calculation>
    </Value>
    <Name>$rows</Name>
  </Step>
  <Step enable="True" id="89" name="# (comment)"/>
  <Step enable="False" id="89" name="# (comment)">
    <Text>// 5. SORT</Text>
  </Step>
  <Step enable="True" id="1" name="Perform Script">
    <Calculated>
      <Calculation><![CDATA["TK__SortRows"]]></Calculation>
    </Calculated>
    <Calculation><![CDATA[JSONSetElement ( "{}" ;
	[ "rows" ; $rows ; JSONArray ]
)]]></Calculation>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[Get ( ScriptResult )]]></Calculation>
    </Value>
    <Name>$sortResult</Name>
  </Step>
  <Step enable="True" id="68" name="If">
    <Restore state="False"/>
    <Calculation><![CDATA[JSONGetElement ( $sortResult ; "status" ) ≠ "success"]]></Calculation>
  </Step>
  <Step enable="True" id="103" name="Exit Script">
    <Calculation><![CDATA[JSONSetElement ( "{}" ;
	[ "status" ; "fail" ; JSONString ] ;
	[ "rows" ; $rows ; JSONArray ] ;
	[ "errors" ; JSONGetElement ( $sortResult ; "errors" ) ; JSONArray ]
)]]></Calculation>
  </Step>
  <Step enable="True" id="70" name="End If"/>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[JSONGetElement ( $sortResult ; "rows" )]]></Calculation>
    </Value>
    <Name>$rows</Name>
  </Step>
  <Step enable="True" id="89" name="# (comment)"/>
  <Step enable="False" id="89" name="# (comment)">
    <Text>// 6. PREPEND DONOS</Text>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[JSONSetElement ( "{}" ;
	[ "datum" ; $datumOd ; JSONString ] ;
	[ "opis" ; "DONOS" ; JSONString ] ;
	[ "zaduzenje" ; 0 ; JSONNumber ] ;
	[ "razduzenje" ; 0 ; JSONNumber ] ;
	[ "donos" ; GetAsNumber ( JSONGetElement ( $donosResult ; "donos" ) ) ; JSONNumber ] ;
	[ "tip" ; "Donos" ; JSONString ] ;
	[ "sortDatum" ; $datumOd ; JSONString ] ;
	[ "sortOrder" ; 0 ; JSONNumber ] ;
	[ "documentID" ; "" ; JSONString ]
)]]></Calculation>
    </Value>
    <Name>$donosRow</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[JSONSetElement ( "[]" ; "[0]" ; $donosRow ; JSONObject )]]></Calculation>
    </Value>
    <Name>$allRows</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[JSONMergeArrays ( $allRows ; $rows )]]></Calculation>
    </Value>
    <Name>$allRows</Name>
  </Step>
  <Step enable="True" id="89" name="# (comment)"/>
  <Step enable="False" id="89" name="# (comment)">
    <Text>// 7. NUMBER ROWS</Text>
  </Step>
  <Step enable="True" id="1" name="Perform Script">
    <Calculated>
      <Calculation><![CDATA["TK__NumberRows"]]></Calculation>
    </Calculated>
    <Calculation><![CDATA[JSONSetElement ( "{}" ;
	[ "rows" ; $allRows ; JSONArray ]
)]]></Calculation>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[Get ( ScriptResult )]]></Calculation>
    </Value>
    <Name>$numberResult</Name>
  </Step>
  <Step enable="True" id="68" name="If">
    <Restore state="False"/>
    <Calculation><![CDATA[JSONGetElement ( $numberResult ; "status" ) ≠ "success"]]></Calculation>
  </Step>
  <Step enable="True" id="103" name="Exit Script">
    <Calculation><![CDATA[JSONSetElement ( "{}" ;
	[ "status" ; "fail" ; JSONString ] ;
	[ "rows" ; $allRows ; JSONArray ] ;
	[ "errors" ; JSONGetElement ( $numberResult ; "errors" ) ; JSONArray ]
)]]></Calculation>
  </Step>
  <Step enable="True" id="70" name="End If"/>
  <Step enable="True" id="141" name="Set Variable">
    <Value>
      <Calculation><![CDATA[JSONGetElement ( $numberResult ; "rows" )]]></Calculation>
    </Value>
    <Name>$allRows</Name>
  </Step>
  <Step enable="True" id="89" name="# (comment)"/>
  <Step enable="True" id="103" name="Exit Script">
    <Calculation><![CDATA[JSONSetElement ( "{}" ;
	[ "status" ; "success" ; JSONString ] ;
	[ "rows" ; $allRows ; JSONArray ] ;
	[ "errors" ; $errors ; JSONArray ]
)]]></Calculation>
  </Step>
</fmxmlsnippet>

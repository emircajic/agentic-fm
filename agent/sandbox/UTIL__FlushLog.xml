<fmxmlsnippet type="FMObjectList">

	<Step enable="True" id="89" name="# (comment)">
		<Text>PURPOSE: Write $$~LOG entries for the current traceID to UTIL__ScriptLog via the native Data API step, then purge those entries from $$~LOG.
Called once by the root orchestrator on exit — success or fail.
Expects: { "traceID": &lt;text&gt; }
Returns: Response envelope (status only)</Text>
	</Step>

	<Step enable="True" id="85" name="Allow User Abort">
		<Set state="False"/>
	</Step>

	<Step enable="True" id="86" name="Set Error Capture">
		<Set state="True"/>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Params.parse ( Get ( ScriptParameter ) ; "traceID" )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Response_Init ( "{}" )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="89" name="# (comment)">
		<Text>── Nothing to flush ──────────────────────────────────────────────────────</Text>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[IsEmpty ( $traceID ) or IsEmpty ( $$~LOG ) or $$~LOG = "[]" or $$~LOG = ""]]></Calculation>
	</Step>
		<Step enable="True" id="103" name="Exit Script">
			<Calculation><![CDATA[Response_Finalize]]></Calculation>
		</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="89" name="# (comment)">
		<Text>── Partition $$~LOG: this trace vs remaining ──────────────────────────────</Text>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$count</Name>
		<Value><Calculation><![CDATA[ValueCount ( JSONListKeys ( $$~LOG ; "" ) )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$batch</Name>
		<Value><Calculation><![CDATA["[]"]]></Calculation></Value>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$remaining</Name>
		<Value><Calculation><![CDATA["[]"]]></Calculation></Value>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$i</Name>
		<Value><Calculation><![CDATA[0]]></Calculation></Value>
	</Step>

	<Step enable="True" id="71" name="Loop">
		<Restore state="True"/>
	</Step>

		<Step enable="True" id="72" name="Exit Loop If">
			<Calculation><![CDATA[$i ≥ $count]]></Calculation>
		</Step>

		<Step enable="True" id="141" name="Set Variable">
			<Name>$entry</Name>
			<Value><Calculation><![CDATA[JSONGetElement ( $$~LOG ; "[" & $i & "]" )]]></Calculation></Value>
		</Step>

		<Step enable="True" id="68" name="If">
			<Calculation><![CDATA[JSONGetElement ( $entry ; "traceID" ) = $traceID]]></Calculation>
		</Step>
			<Step enable="True" id="141" name="Set Variable">
				<Name>$batch</Name>
				<Value><Calculation><![CDATA[JSONSetElement ( $batch ; "[+]" ; $entry ; JSONObject )]]></Calculation></Value>
			</Step>
		<Step enable="True" id="69" name="Else">
		</Step>
			<Step enable="True" id="141" name="Set Variable">
				<Name>$remaining</Name>
				<Value><Calculation><![CDATA[JSONSetElement ( $remaining ; "[+]" ; $entry ; JSONObject )]]></Calculation></Value>
			</Step>
		<Step enable="True" id="70" name="End If"/>

		<Step enable="True" id="141" name="Set Variable">
			<Name>$i</Name>
			<Value><Calculation><![CDATA[$i + 1]]></Calculation></Value>
		</Step>

	<Step enable="True" id="73" name="End Loop"/>

	<Step enable="True" id="89" name="# (comment)">
		<Text>── Replace $$~LOG — preserve other sessions' entries ─────────────────────</Text>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$$~LOG</Name>
		<Value><Calculation><![CDATA[$remaining]]></Calculation></Value>
	</Step>

	<Step enable="True" id="89" name="# (comment)">
		<Text>── Nothing matched this trace ────────────────────────────────────────────</Text>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[$batch = "[]" or IsEmpty ( JSONListKeys ( $batch ; "" ) )]]></Calculation>
	</Step>
		<Step enable="True" id="103" name="Exit Script">
			<Calculation><![CDATA[Response_Finalize]]></Calculation>
		</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="89" name="# (comment)">
		<Text>── Build Data API payload (one record per trace) ────────────────────────</Text>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$rowCount</Name>
		<Value><Calculation><![CDATA[ValueCount ( JSONListKeys ( $batch ; "" ) )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$fieldData</Name>
		<Value><Calculation><![CDATA[JSONSetElement ( "{}" ;
	[ "TraceID"    ; $traceID                                              ; JSONString ] ;
	[ "LogJSON"    ; $batch                                                ; JSONString ] ;
	[ "SessionID"  ; Get ( PersistentID )                                  ; JSONString ] ;
	[ "RootScript" ; JSONGetElement ( $batch ; "[0].script" )              ; JSONString ] ;
	[ "CreatedAt"  ; GetAsText ( Get ( CurrentTimestamp ) )                ; JSONString ] ;
	[ "RowCount"   ; $rowCount                                             ; JSONNumber ]
)]]></Calculation></Value>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$payload</Name>
		<Value><Calculation><![CDATA[JSONSetElement ( "{}" ;
	[ "action"    ; "create"          ; JSONString ] ;
	[ "layouts"   ; "UTIL__ScriptLog" ; JSONString ] ;
	[ "fieldData" ; $fieldData        ; JSONObject ]
)]]></Calculation></Value>
	</Step>

	<Step enable="True" id="89" name="# (comment)">
		<Text>── Write via native Data API step ────────────────────────────────────────</Text>
	</Step>

	<Step enable="True" id="203" name="Execute FileMaker Data API">
		<SelectAll state="True"/>
		<Field>
			<Text/>
		</Field>
		<Calculation><![CDATA[$payload]]></Calculation>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$apiResult</Name>
		<Value><Calculation><![CDATA[Get ( ScriptResult )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$fmError</Name>
		<Value><Calculation><![CDATA[Get ( LastError )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[$fmError ≠ 0]]></Calculation>
	</Step>
		<Step enable="True" id="141" name="Set Variable">
			<Name>$void</Name>
			<Value><Calculation><![CDATA[Response_AddWarning (
	"LOG_FLUSH_FAILED" ;
	"Data API write failed (FM error " & $fmError & ") — log entries discarded" ;
	"" ;
	"{}" ;
	""
)]]></Calculation></Value>
		</Step>
		<Step enable="True" id="103" name="Exit Script">
			<Calculation><![CDATA[Response_Finalize]]></Calculation>
		</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[JSONGetElement ( $apiResult ; "messages[0].code" ) ≠ "0"]]></Calculation>
	</Step>
		<Step enable="True" id="141" name="Set Variable">
			<Name>$void</Name>
			<Value><Calculation><![CDATA[Response_AddWarning (
	"LOG_FLUSH_REJECTED" ;
	"Data API rejected log write: " & JSONGetElement ( $apiResult ; "messages[0].message" ) ;
	"" ;
	"{}" ;
	""
)]]></Calculation></Value>
		</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="103" name="Exit Script">
		<Calculation><![CDATA[Response_Finalize]]></Calculation>
	</Step>

</fmxmlsnippet>

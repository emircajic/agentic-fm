<fmxmlsnippet type="FMObjectList">
  <Step enable="True" id="86" name="Set Error Capture">
    <Set state="True"/>
  </Step>
  <Step enable="True" id="85" name="Allow User Abort">
    <Set state="False"/>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value><Calculation><![CDATA[Response_Init ( "{}" )]]></Calculation></Value>
    <Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
    <Name>$response</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value><Calculation><![CDATA[Settings_BuildJSON]]></Calculation></Value>
    <Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
    <Name>$settingsJSON</Name>
  </Step>
  <Step enable="True" id="68" name="If">
    <Restore state="False"/>
    <Calculation><![CDATA[JSONGetElementType ( $settingsJSON ; "" ) ≠ JSONObject]]></Calculation>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value><Calculation><![CDATA[Response_AddError (
    "SETTINGS_LOAD_INVALID_JSON" ;
    "Settings_BuildJSON did not return a JSON object." ;
    "Settings_BuildJSON" ;
    JSONSetElement (
        "{}" ;
        [ "result" ; $settingsJSON ; JSONString ]
    ) ;
    Get ( ScriptName )
)]]></Calculation></Value>
    <Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
    <Name>$response</Name>
  </Step>
  <Step enable="True" id="69" name="Else">
    <Restore state="False"/>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value><Calculation><![CDATA[$settingsJSON]]></Calculation></Value>
    <Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
    <Name>$$SETTINGS</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value><Calculation><![CDATA[JSONGetElement ( $$SETTINGS ; "_system.updated_at" )]]></Calculation></Value>
    <Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
    <Name>$$SETTINGS_UPDATED_AT</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value><Calculation><![CDATA[Response_SetData (
    JSONSetElement (
        "{}" ;
        [ "updated_at" ; $$SETTINGS_UPDATED_AT ; JSONString ] ;
        [ "settings" ; $$SETTINGS ; JSONObject ]
    )
)]]></Calculation></Value>
    <Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
    <Name>$response</Name>
  </Step>
  <Step enable="True" id="70" name="End If"/>
  <Step enable="True" id="141" name="Set Variable">
    <Value><Calculation><![CDATA[Response_Finalize]]></Calculation></Value>
    <Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
    <Name>$response</Name>
  </Step>
  <Step enable="True" id="103" name="Exit Script">
    <Calculation><![CDATA[$response]]></Calculation>
  </Step>
</fmxmlsnippet>

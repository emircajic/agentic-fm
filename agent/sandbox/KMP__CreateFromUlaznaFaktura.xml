<fmxmlsnippet type="FMObjectList">

	<Step enable="True" id="89" name="# (comment)">
		<Text>PURPOSE: Create a KalkulacijaMP header linked to the given UlaznaFakturaDobavljaca.
Idempotent: if a KMP already exists for this UFD, returns its ID without creating a duplicate.</Text>
	</Step>

	<Step enable="False" id="61" name="Insert Text">
		<SelectAll state="False"/>
		<Text>PARAMS: ulaznaFakturaID (text, required)
RETURNS: data.kalkulacijaID (text)</Text>
		<Field table="" id="0" name="$README"/>
	</Step>

	<Step enable="True" id="85" name="Allow User Abort">
		<Set state="False"/>
	</Step>

	<Step enable="True" id="86" name="Set Error Capture">
		<Set state="True"/>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Params.parse ( Get ( ScriptParameter ) ; "ulaznaFakturaID" )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Response_Init ( "{}" )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Log.add ( "info" ; "KMP_CREATE_START" ; "Creating KalkulacijaMP for UFD " & $ulaznaFakturaID ; $params )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="89" name="# (comment)">
		<Text>── Validate ──────────────────────────────────────────────────────────────</Text>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[IsEmpty ( $ulaznaFakturaID )]]></Calculation>
	</Step>
		<Step enable="True" id="141" name="Set Variable">
			<Name>$void</Name>
			<Value><Calculation><![CDATA[Response_AddError ( "MISSING_PARAM" ; "ulaznaFakturaID is required" ; "ulaznaFakturaID" ; "{}" ; "" )]]></Calculation></Value>
		</Step>
		<Step enable="True" id="68" name="If">
			<Calculation><![CDATA[$isRoot]]></Calculation>
		</Step>
			<Step enable="True" id="25" name="Perform Script">
				<Script id="780" name="UTIL__FlushLog"/>
				<Calculation><![CDATA[JSONSetElement ( "{}" ; "traceID" ; $traceID ; JSONString )]]></Calculation>
			</Step>
		<Step enable="True" id="70" name="End If"/>
		<Step enable="True" id="103" name="Exit Script">
			<Calculation><![CDATA[Response_Finalize]]></Calculation>
		</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="89" name="# (comment)">
		<Text>── Idempotency check — return existing KMP if one already exists for this UFD ──</Text>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$existingID</Name>
		<Value><Calculation><![CDATA[ExecuteSQL (
	"SELECT PrimaryKey FROM \"KalkulacijaMP\" WHERE ForeignKeyUlaznaFakturaID = ?" ;
	"" ; "" ;
	$ulaznaFakturaID
)]]></Calculation></Value>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[not IsEmpty ( $existingID ) and $existingID ≠ "?"]]></Calculation>
	</Step>
		<Step enable="True" id="141" name="Set Variable">
			<Name>$void</Name>
			<Value><Calculation><![CDATA[Log.add ( "info" ; "KMP_CREATE_IDEMPOTENT" ; "KMP already exists for UFD " & $ulaznaFakturaID & " — returning existing ID " & $existingID ; $params )]]></Calculation></Value>
		</Step>
		<Step enable="True" id="141" name="Set Variable">
			<Name>$void</Name>
			<Value><Calculation><![CDATA[Response_SetData ( JSONSetElement ( "{}" ; "kalkulacijaID" ; $existingID ; JSONString ) )]]></Calculation></Value>
		</Step>
		<Step enable="True" id="68" name="If">
			<Calculation><![CDATA[$isRoot]]></Calculation>
		</Step>
			<Step enable="True" id="25" name="Perform Script">
				<Script id="780" name="UTIL__FlushLog"/>
				<Calculation><![CDATA[JSONSetElement ( "{}" ; "traceID" ; $traceID ; JSONString )]]></Calculation>
			</Step>
		<Step enable="True" id="70" name="End If"/>
		<Step enable="True" id="103" name="Exit Script">
			<Calculation><![CDATA[Response_Finalize]]></Calculation>
		</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="89" name="# (comment)">
		<Text>── Create KalkulacijaMP record ────────────────────────────────────────────</Text>
	</Step>

	<Step enable="True" id="6" name="Go to Layout">
		<LayoutDestination value="SelectedLayout"/>
		<Layout id="241" name="KMP__KalkulacijaMP"/>
		<Animation value="None"/>
	</Step>

	<Step enable="True" id="7" name="New Record/Request"/>

	<Step enable="True" id="76" name="Set Field">
		<Calculation><![CDATA[$ulaznaFakturaID]]></Calculation>
		<Field table="KMP__KalkulacijaMP" id="8" name="ForeignKeyUlaznaFakturaID"/>
	</Step>

	<Step enable="True" id="76" name="Set Field">
		<Calculation><![CDATA[Get ( CurrentDate )]]></Calculation>
		<Field table="KMP__KalkulacijaMP" id="7" name="DatumKalkulacije"/>
	</Step>

	<Step enable="True" id="76" name="Set Field">
		<Calculation><![CDATA["Nova"]]></Calculation>
		<Field table="KMP__KalkulacijaMP" id="10" name="Status"/>
	</Step>

	<Step enable="True" id="75" name="Commit Records/Requests">
		<NoInteract state="True"/>
		<Option state="False"/>
		<ESSForceCommit state="False"/>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[Get ( LastError ) ≠ 0]]></Calculation>
	</Step>
		<Step enable="True" id="141" name="Set Variable">
			<Name>$void</Name>
			<Value><Calculation><![CDATA[Response_AddError ( "COMMIT_FAILED" ; "Failed to commit KalkulacijaMP record (FM error " & Get ( LastError ) & ")" ; "" ; "{}" ; "" )]]></Calculation></Value>
		</Step>
		<Step enable="True" id="141" name="Set Variable">
			<Name>$void</Name>
			<Value><Calculation><![CDATA[Log.add ( "error" ; "KMP_COMMIT_FAILED" ; "Commit failed for UFD " & $ulaznaFakturaID ; $params )]]></Calculation></Value>
		</Step>
		<Step enable="True" id="68" name="If">
			<Calculation><![CDATA[$isRoot]]></Calculation>
		</Step>
			<Step enable="True" id="25" name="Perform Script">
				<Script id="780" name="UTIL__FlushLog"/>
				<Calculation><![CDATA[JSONSetElement ( "{}" ; "traceID" ; $traceID ; JSONString )]]></Calculation>
			</Step>
		<Step enable="True" id="70" name="End If"/>
		<Step enable="True" id="103" name="Exit Script">
			<Calculation><![CDATA[Response_Finalize]]></Calculation>
		</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$kalkulacijaID</Name>
		<Value><Calculation><![CDATA[KMP__KalkulacijaMP::PrimaryKey]]></Calculation></Value>
	</Step>

	<Step enable="True" id="89" name="# (comment)">
		<Text>── Success ───────────────────────────────────────────────────────────────</Text>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Response_SetData ( JSONSetElement ( "{}" ; "kalkulacijaID" ; $kalkulacijaID ; JSONString ) )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="141" name="Set Variable">
		<Name>$void</Name>
		<Value><Calculation><![CDATA[Log.add ( "info" ; "KMP_CREATE_DONE" ; "KalkulacijaMP created: " & $kalkulacijaID & " for UFD " & $ulaznaFakturaID ; $params )]]></Calculation></Value>
	</Step>

	<Step enable="True" id="68" name="If">
		<Calculation><![CDATA[$isRoot]]></Calculation>
	</Step>
		<Step enable="True" id="25" name="Perform Script">
			<Script id="780" name="UTIL__FlushLog"/>
			<Calculation><![CDATA[JSONSetElement ( "{}" ; "traceID" ; $traceID ; JSONString )]]></Calculation>
		</Step>
	<Step enable="True" id="70" name="End If"/>

	<Step enable="True" id="103" name="Exit Script">
		<Calculation><![CDATA[Response_Finalize]]></Calculation>
	</Step>

</fmxmlsnippet>

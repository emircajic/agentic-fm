<fmxmlsnippet type="FMObjectList">

  <Step enable="True" id="89" name="# (comment)">
    <Text>PURPOSE: One-time migration — copies ForeignKeyUlaznaFakturaID from each Primka header down to its StavkePrimke lines. Only writes where the stavka field is currently empty; skips records already assigned.</Text>
  </Step>

  <Step enable="True" id="89" name="# (comment)"/>

  <Step enable="True" id="85" name="Allow User Abort">
    <Set state="False"/>
  </Step>
  <Step enable="True" id="86" name="Set Error Capture">
    <Set state="True"/>
  </Step>

  <Step enable="True" id="89" name="# (comment)"/>

  <Step enable="True" id="141" name="Set Variable">
    <Name>$startLayout</Name>
    <Value><Calculation><![CDATA[Get ( LayoutName )]]></Calculation></Value>
  </Step>

  <Step enable="True" id="89" name="# (comment)"/>

  <Step enable="False" id="89" name="# (comment)">
    <Text>MARK: Setup</Text>
  </Step>

  <Step enable="True" id="6" name="Go to Layout">
    <LayoutDestination value="SelectedLayout"/>
    <Layout id="227" name="Dev StavkePrimke"/>
    <Animation value=""/>
  </Step>

  <Step enable="True" id="23" name="Show All Records"/>

  <Step enable="True" id="141" name="Set Variable">
    <Name>$total</Name>
    <Value><Calculation><![CDATA[Get ( FoundCount )]]></Calculation></Value>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Name>$countSet</Name>
    <Value><Calculation><![CDATA[0]]></Calculation></Value>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Name>$countSkipped</Name>
    <Value><Calculation><![CDATA[0]]></Calculation></Value>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Name>$countNoUFD</Name>
    <Value><Calculation><![CDATA[0]]></Calculation></Value>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Name>$countError</Name>
    <Value><Calculation><![CDATA[0]]></Calculation></Value>
  </Step>

  <Step enable="True" id="16" name="Go to Record/Request/Page">
    <RowPageLocation value="First"/>
  </Step>

  <Step enable="True" id="89" name="# (comment)"/>

  <Step enable="False" id="89" name="# (comment)">
    <Text>MARK: Loop</Text>
  </Step>

  <Step enable="True" id="71" name="Loop"/>

    <Step enable="True" id="141" name="Set Variable">
      <Name>$ufdFK</Name>
      <Value><Calculation><![CDATA[Primke::ForeignKeyUlaznaFakturaID]]></Calculation></Value>
    </Step>

    <Step enable="True" id="68" name="If">
      <Calculation><![CDATA[IsEmpty ( $ufdFK )]]></Calculation>
    </Step>

      <Step enable="True" id="89" name="# (comment)">
        <Text>// parent Primka has no UFD assigned — nothing to migrate</Text>
      </Step>
      <Step enable="True" id="141" name="Set Variable">
        <Name>$countNoUFD</Name>
        <Value><Calculation><![CDATA[$countNoUFD + 1]]></Calculation></Value>
      </Step>

    <Step enable="True" id="125" name="Else If">
      <Calculation><![CDATA[not IsEmpty ( StavkePrimke::ForeignKeyUlaznaFakturaID )]]></Calculation>
    </Step>

      <Step enable="True" id="89" name="# (comment)">
        <Text>// already assigned — preserve any manual assignment, do not overwrite</Text>
      </Step>
      <Step enable="True" id="141" name="Set Variable">
        <Name>$countSkipped</Name>
        <Value><Calculation><![CDATA[$countSkipped + 1]]></Calculation></Value>
      </Step>

    <Step enable="True" id="69" name="Else"/>

      <Step enable="True" id="76" name="Set Field">
        <Field table="StavkePrimke" id="0" name="ForeignKeyUlaznaFakturaID"/>
        <Calculation><![CDATA[$ufdFK]]></Calculation>
      </Step>
      <Step enable="True" id="75" name="Commit Records/Requests">
        <NoInteract state="True"/>
        <Option state="False"/>
        <ESSForceCommit state="False"/>
      </Step>

      <Step enable="True" id="68" name="If">
        <Calculation><![CDATA[Get ( LastError ) ≠ 0]]></Calculation>
      </Step>
        <Step enable="True" id="141" name="Set Variable">
          <Name>$countError</Name>
          <Value><Calculation><![CDATA[$countError + 1]]></Calculation></Value>
        </Step>
      <Step enable="True" id="69" name="Else"/>
        <Step enable="True" id="141" name="Set Variable">
          <Name>$countSet</Name>
          <Value><Calculation><![CDATA[$countSet + 1]]></Calculation></Value>
        </Step>
      <Step enable="True" id="70" name="End If"/>

    <Step enable="True" id="70" name="End If"/>

    <Step enable="True" id="16" name="Go to Record/Request/Page">
      <Exit state="True"/>
      <RowPageLocation value="Next"/>
    </Step>

  <Step enable="True" id="72" name="End Loop"/>

  <Step enable="True" id="89" name="# (comment)"/>

  <Step enable="False" id="89" name="# (comment)">
    <Text>MARK: Report</Text>
  </Step>

  <Step enable="True" id="87" name="Show Custom Dialog">
    <Title>
      <Calculation><![CDATA["Migration Complete"]]></Calculation>
    </Title>
    <Message>
      <Calculation><![CDATA["Total stavki: " & $total & ¶ &
"FK set: " & $countSet & ¶ &
"Already assigned (skipped): " & $countSkipped & ¶ &
"No UFD on parent Primka: " & $countNoUFD & ¶ &
"Errors: " & $countError]]></Calculation>
    </Message>
    <Buttons>
      <Button CommitState="True">
        <Calculation><![CDATA["OK"]]></Calculation>
      </Button>
    </Buttons>
    <InputFields/>
  </Step>

  <Step enable="True" id="89" name="# (comment)"/>

  <Step enable="True" id="6" name="Go to Layout">
    <LayoutDestination value="LayoutNameByCalculation"/>
    <Calculation><![CDATA[$startLayout]]></Calculation>
    <Animation value=""/>
  </Step>

</fmxmlsnippet>

<?xml version="1.0"?>
<fmxmlsnippet type="FMObjectList">
  <Script includeInMenu="False" SiriShortcutVisible="False" runFullAccess="False" id="178004" name="AGENT__MarkXMLExportConsumed">
    <Step enable="True" id="89" name="# (comment)">
      <Text>PURPOSE: Mark one AgentExports job as consumed after successful local download.</Text>
    </Step>
    <Step enable="True" id="86" name="Set Error Capture">
      <Set state="True"/>
    </Step>
    <Step enable="True" id="85" name="Allow User Abort">
      <Set state="False"/>
    </Step>
    <Step enable="True" id="141" name="Set Variable">
      <Value>
        <Calculation><![CDATA[Response_Init ( "{}" )]]></Calculation>
      </Value>
      <Name>$response</Name>
    </Step>
    <Step enable="True" id="141" name="Set Variable">
      <Value>
        <Calculation><![CDATA[Get ( ScriptParameter )]]></Calculation>
      </Value>
      <Name>$param</Name>
    </Step>
    <Step enable="True" id="141" name="Set Variable">
      <Value>
        <Calculation><![CDATA[JSONGetElement ( $param ; "id" )]]></Calculation>
      </Value>
      <Name>$id</Name>
    </Step>
    <Step enable="True" id="68" name="If">
      <Restore state="False"/>
      <Calculation><![CDATA[IsEmpty ( $id )]]></Calculation>
    </Step>
    <Step enable="True" id="141" name="Set Variable">
      <Value>
        <Calculation><![CDATA[Response_AddError (
    "AGENT_CONSUME_ID_MISSING" ;
    "AgentExports id is required." ;
    "Get ( ScriptParameter )" ;
    "{}" ;
    Get ( ScriptName )
)]]></Calculation>
      </Value>
      <Name>$response</Name>
    </Step>
    <Step enable="True" id="69" name="Else">
      <Restore state="False"/>
    </Step>
    <Step enable="True" id="6" name="Go to Layout">
      <LayoutDestination value="SelectedLayout"/>
      <Layout id="250" name="AgentExports"/>
      <Animation value=""/>
    </Step>
    <Step enable="True" id="22" name="Enter Find Mode">
      <Pause state="False"/>
      <Restore state="False"/>
    </Step>
    <Step enable="True" id="76" name="Set Field">
      <Calculation><![CDATA["=" & $id]]></Calculation>
      <Field table="AgentExports" id="1" name="id"/>
    </Step>
    <Step enable="True" id="28" name="Perform Find">
      <Restore state="False"/>
    </Step>
    <Step enable="True" id="68" name="If">
      <Restore state="False"/>
      <Calculation><![CDATA[Get ( FoundCount ) ≠ 1]]></Calculation>
    </Step>
    <Step enable="True" id="141" name="Set Variable">
      <Value>
        <Calculation><![CDATA[Response_AddError (
    "AGENT_CONSUME_NOT_FOUND" ;
    "Expected exactly one AgentExports row for the supplied id." ;
    "AgentExports::id" ;
    JSONSetElement ( "{}" ; [ "id" ; $id ; JSONString ] ) ;
    Get ( ScriptName )
)]]></Calculation>
      </Value>
      <Name>$response</Name>
    </Step>
    <Step enable="True" id="69" name="Else">
      <Restore state="False"/>
    </Step>
    <Step enable="True" id="76" name="Set Field">
      <Calculation><![CDATA["consumed"]]></Calculation>
      <Field table="AgentExports" id="15" name="Status"/>
    </Step>
    <Step enable="True" id="76" name="Set Field">
      <Calculation><![CDATA[Get ( CurrentTimestamp )]]></Calculation>
      <Field table="AgentExports" id="24" name="consumedOn"/>
    </Step>
    <Step enable="True" id="75" name="Commit Records/Requests">
      <NoInteract state="True"/>
      <Option state="False"/>
      <ESSForceCommit state="False"/>
    </Step>
    <Step enable="True" id="141" name="Set Variable">
      <Value>
        <Calculation><![CDATA[Get ( LastError )]]></Calculation>
      </Value>
      <Name>$commitError</Name>
    </Step>
    <Step enable="True" id="68" name="If">
      <Restore state="False"/>
      <Calculation><![CDATA[$commitError ≠ 0]]></Calculation>
    </Step>
    <Step enable="True" id="141" name="Set Variable">
      <Value>
        <Calculation><![CDATA[Response_AddError (
    "AGENT_CONSUME_COMMIT_FAILED" ;
    "Failed to mark AgentExports row as consumed." ;
    "AgentExports::Status" ;
    JSONSetElement (
        "{}" ;
        [ "id" ; $id ; JSONString ] ;
        [ "error" ; $commitError ; JSONNumber ]
    ) ;
    Get ( ScriptName )
)]]></Calculation>
      </Value>
      <Name>$response</Name>
    </Step>
    <Step enable="True" id="69" name="Else">
      <Restore state="False"/>
    </Step>
    <Step enable="True" id="141" name="Set Variable">
      <Value>
        <Calculation><![CDATA[Response_SetData (
    JSONSetElement (
        "{}" ;
        [ "id" ; AgentExports::id ; JSONString ] ;
        [ "status" ; AgentExports::Status ; JSONString ] ;
        [ "consumedOn" ; GetAsText ( AgentExports::consumedOn ) ; JSONString ]
    )
)]]></Calculation>
      </Value>
      <Name>$response</Name>
    </Step>
    <Step enable="True" id="70" name="End If"/>
    <Step enable="True" id="70" name="End If"/>
    <Step enable="True" id="70" name="End If"/>
    <Step enable="True" id="6" name="Go to Layout">
      <LayoutDestination value="OriginalLayout"/>
      <Animation value=""/>
    </Step>
    <Step enable="True" id="141" name="Set Variable">
      <Value>
        <Calculation><![CDATA[Response_Finalize]]></Calculation>
      </Value>
      <Name>$response</Name>
    </Step>
    <Step enable="True" id="103" name="Exit Script">
      <Calculation><![CDATA[$response]]></Calculation>
    </Step>
  </Script>
</fmxmlsnippet>

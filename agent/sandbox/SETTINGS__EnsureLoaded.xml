<fmxmlsnippet type="FMObjectList">
  <Step enable="True" id="86" name="Set Error Capture">
    <Set state="True"/>
  </Step>
  <Step enable="True" id="85" name="Allow User Abort">
    <Set state="False"/>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value><Calculation><![CDATA[Response_Init ( "{}" )]]></Calculation></Value>
    <Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
    <Name>$response</Name>
  </Step>
  <Step enable="True" id="68" name="If">
    <Restore state="False"/>
    <Calculation><![CDATA[not Settings_IsLoaded ( )]]></Calculation>
  </Step>
  <Step enable="True" id="6" name="Perform Script">
    <Calculation><![CDATA["SETTINGS__Load"]]></Calculation>
    <Steps/>
  </Step>
  <Step enable="True" id="103" name="Exit Script">
    <Calculation><![CDATA[Get ( ScriptResult )]]></Calculation>
  </Step>
  <Step enable="True" id="70" name="End If"/>
  <Step enable="True" id="141" name="Set Variable">
    <Value><Calculation><![CDATA[$$SETTINGS_UPDATED_AT]]></Calculation></Value>
    <Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
    <Name>$cachedUpdatedAt</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value><Calculation><![CDATA[GetSetting ( "_system.updated_at" )]]></Calculation></Value>
    <Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
    <Name>$liveUpdatedAt</Name>
  </Step>
  <Step enable="True" id="68" name="If">
    <Restore state="False"/>
    <Calculation><![CDATA[$cachedUpdatedAt ≠ $liveUpdatedAt]]></Calculation>
  </Step>
  <Step enable="True" id="6" name="Perform Script">
    <Calculation><![CDATA["SETTINGS__Load"]]></Calculation>
    <Steps/>
  </Step>
  <Step enable="True" id="103" name="Exit Script">
    <Calculation><![CDATA[Get ( ScriptResult )]]></Calculation>
  </Step>
  <Step enable="True" id="70" name="End If"/>
  <Step enable="True" id="141" name="Set Variable">
    <Value><Calculation><![CDATA[Response_SetData (
    JSONSetElement (
        "{}" ;
        [ "loaded" ; False ; JSONBoolean ] ;
        [ "updated_at" ; $cachedUpdatedAt ; JSONString ]
    )
)]]></Calculation></Value>
    <Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
    <Name>$response</Name>
  </Step>
  <Step enable="True" id="141" name="Set Variable">
    <Value><Calculation><![CDATA[Response_Finalize]]></Calculation></Value>
    <Repetition><Calculation><![CDATA[1]]></Calculation></Repetition>
    <Name>$response</Name>
  </Step>
  <Step enable="True" id="103" name="Exit Script">
    <Calculation><![CDATA[$response]]></Calculation>
  </Step>
</fmxmlsnippet>
